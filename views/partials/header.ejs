<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarterBrain - Skill Barter Platform</title>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap"
        rel="stylesheet">
    <!-- App CSS -->
    <link rel="stylesheet" href="/css/style.css">

    <style>
        /* ── GLOBAL RESET & BASE ── */
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #07070f;
            color: #eeeeff;
            min-height: 100vh;
            padding-top: 68px;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* ── NAVBAR ── */
        .bb-nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            height: 68px;
            background: rgba(7, 7, 15, 0.88);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.065);
            display: flex;
            align-items: center;
        }

        .nav-inner {
            max-width: 1280px;
            width: 100%;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            align-items: center;
            gap: 0;
        }

        /* Brand */
        .nav-brand {
            font-family: 'Sora', sans-serif;
            font-size: 1.45rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(120deg, #818cf8, #a78bfa, #c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            flex-shrink: 0;
            margin-right: 36px;
        }

        /* Nav links */
        .nav-links {
            display: flex;
            align-items: center;
            gap: 2px;
            list-style: none;
            flex: 1;
        }

        .nav-links li a {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.84rem;
            font-weight: 500;
            color: #7a7a9a;
            padding: 7px 12px;
            border-radius: 8px;
            transition: color .2s, background .2s;
            white-space: nowrap;
        }

        .nav-links li a i {
            font-size: 0.85rem;
        }

        .nav-links li a:hover {
            color: #eeeeff;
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-links li a.active {
            color: #818cf8;
            background: rgba(79, 70, 229, 0.1);
        }

        /* Spacer */
        .nav-spacer {
            flex: 1;
        }

        /* Right side */
        .nav-right {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
            margin-left: 20px;
        }

        /* Dropdown */
        .nav-dropdown {
            position: relative;
        }

        .nav-dropdown-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            padding: 7px 14px 7px 10px;
            cursor: pointer;
            transition: all .2s;
            color: #eeeeff;
        }

        .nav-dropdown-btn:hover {
            background: rgba(255, 255, 255, 0.07);
            border-color: rgba(99, 102, 241, 0.3);
        }

        .nav-avatar {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: linear-gradient(135deg, rgba(79, 70, 229, 0.4), rgba(124, 58, 237, 0.3));
            border: 1px solid rgba(99, 102, 241, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Sora', sans-serif;
            font-size: 0.75rem;
            font-weight: 700;
            color: #a5b4fc;
            flex-shrink: 0;
        }

        .nav-username {
            font-size: 0.84rem;
            font-weight: 600;
            color: #eeeeff;
            max-width: 110px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .nav-dropdown-btn i.chevron {
            font-size: 0.7rem;
            color: #7a7a9a;
            transition: transform .2s;
        }

        .nav-dropdown:hover .nav-dropdown-btn i.chevron,
        .nav-dropdown.open .nav-dropdown-btn i.chevron {
            transform: rotate(180deg);
        }

        /* Dropdown menu */
        .nav-dropdown-menu {
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: #0e0e1c;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            padding: 6px;
            min-width: 160px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            opacity: 0;
            transform: translateY(-6px);
            pointer-events: none;
            transition: opacity .2s, transform .2s;
            z-index: 100;
        }

        .nav-dropdown:hover .nav-dropdown-menu,
        .nav-dropdown.open .nav-dropdown-menu {
            opacity: 1;
            transform: translateY(0);
            pointer-events: all;
        }

        .nav-dropdown-menu a {
            display: flex;
            align-items: center;
            gap: 9px;
            font-size: 0.83rem;
            font-weight: 500;
            color: #7a7a9a;
            padding: 9px 12px;
            border-radius: 9px;
            transition: background .15s, color .15s;
        }

        .nav-dropdown-menu a i {
            font-size: 0.85rem;
        }

        .nav-dropdown-menu a:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #eeeeff;
        }

        .nav-dropdown-menu .divider {
            height: 1px;
            background: rgba(255, 255, 255, 0.06);
            margin: 5px 6px;
        }

        .nav-dropdown-menu a.logout {
            color: #f87171;
        }

        .nav-dropdown-menu a.logout:hover {
            background: rgba(239, 68, 68, 0.08);
            color: #fca5a5;
        }

        /* Auth buttons (logged out) */
        .btn-nav-login {
            font-size: 0.83rem;
            font-weight: 600;
            color: #818cf8;
            background: transparent;
            border: 1px solid rgba(99, 102, 241, 0.35);
            padding: 8px 18px;
            border-radius: 9px;
            transition: all .2s;
        }

        .btn-nav-login:hover {
            background: rgba(99, 102, 241, 0.1);
            color: #a5b4fc;
        }

        .btn-nav-signup {
            font-size: 0.83rem;
            font-weight: 700;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: #fff;
            border: none;
            padding: 8px 18px;
            border-radius: 9px;
            box-shadow: 0 0 18px rgba(79, 70, 229, 0.35);
            transition: all .2s;
            cursor: pointer;
        }

        .btn-nav-signup:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 22px rgba(79, 70, 229, 0.5);
            color: #fff;
        }

        /* Mobile toggle */
        .nav-toggle {
            display: none;
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            padding: 7px 10px;
            cursor: pointer;
            color: #7a7a9a;
            font-size: 1rem;
            margin-left: auto;
        }

        /* Mobile drawer */
        .nav-drawer {
            display: none;
            position: fixed;
            top: 68px;
            left: 0;
            right: 0;
            background: rgba(10, 10, 20, 0.98);
            border-bottom: 1px solid rgba(255, 255, 255, 0.07);
            padding: 16px 20px 20px;
            z-index: 999;
            flex-direction: column;
            gap: 4px;
        }

        .nav-drawer.open {
            display: flex;
        }

        .nav-drawer a {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
            font-weight: 500;
            color: #7a7a9a;
            padding: 11px 14px;
            border-radius: 10px;
            transition: all .15s;
        }

        .nav-drawer a:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #eeeeff;
        }

        .nav-drawer a i {
            font-size: 0.9rem;
            color: #818cf8;
            opacity: .7;
        }

        .nav-drawer .drawer-divider {
            height: 1px;
            background: rgba(255, 255, 255, 0.06);
            margin: 8px 0;
        }

        .nav-drawer a.logout-link {
            color: #f87171;
        }

        .nav-drawer a.logout-link i {
            color: #f87171;
            opacity: .8;
        }

        @media (max-width: 900px) {

            .nav-links,
            .nav-right {
                display: none;
            }

            .nav-toggle {
                display: flex;
                align-items: center;
            }

            .nav-brand {
                margin-right: auto;
            }
        }

        /* Main content wrapper */
        main {
            width: 100%;
        }
    </style>
</head>

<body>

    <!-- ── NAVBAR ── -->
    <nav class="bb-nav">
        <div class="nav-inner">
            <a href="/dashboard" class="nav-brand">BarterBrain</a>

            <% if (locals.user) { %>
                <!-- Logged-in nav links -->
                <ul class="nav-links">
                    <li><a href="/dashboard"><i class="bi bi-grid-fill"></i> Dashboard</a></li>
                    <!-- Add this to your navigation menu -->
                    <li class="nav-item">
                        <a class="nav-link" href="/search">
                            <i class="bi bi-search"></i> Find People
                        </a>
                    </li>
                    <li><a href="/offers/all"><i class="bi bi-compass-fill"></i> Browse</a></li>
                    <li><a href="/requests"><i class="bi bi-journal-text"></i> Requests</a></li>
                    <li><a href="/offers"><i class="bi bi-briefcase-fill"></i> Offers</a></li>
                    <li><a href="/matches"><i class="bi bi-lightning-charge-fill"></i> Matches</a></li>
                    <li><a href="/availability"><i class="bi bi-calendar3"></i> Availability</a></li>
                </ul>

                <div class="nav-right">
                    <div class="nav-dropdown">
                        <button class="nav-dropdown-btn">
                            <div class="nav-avatar">
                                <%= user.name.charAt(0).toUpperCase() %>
                            </div>
                            <span class="nav-username">
                                <%= user.name %>
                            </span>
                            <i class="bi bi-chevron-down chevron"></i>
                        </button>
                        <div class="nav-dropdown-menu">
                            <a href="/profile"><i class="bi bi-person-fill"></i> Profile</a>
                            <div class="divider"></div>
                            <a href="/logout" class="logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                        </div>
                    </div>
                </div>

                <!-- Mobile toggle -->
                <button class="nav-toggle" id="nav-toggle" aria-label="Menu">
                    <i class="bi bi-list"></i>
                </button>

                <!-- Mobile drawer -->
                <div class="nav-drawer" id="nav-drawer">
                    <a href="/dashboard"><i class="bi bi-grid-fill"></i> Dashboard</a>
                    <a href="/offers/all"><i class="bi bi-compass-fill"></i> Browse Offers</a>
                    <a href="/requests"><i class="bi bi-journal-text"></i> My Requests</a>
                    <a href="/offers"><i class="bi bi-briefcase-fill"></i> My Offers</a>
                    <a href="/matches"><i class="bi bi-lightning-charge-fill"></i> Matches</a>
                    <a href="/availability"><i class="bi bi-calendar3"></i> Availability</a>
                    <div class="drawer-divider"></div>
                    <a href="/profile"><i class="bi bi-person-fill"></i> Profile</a>
                    <a href="/logout" class="logout-link"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>

                <% } else { %>
                    <div class="nav-right" style="margin-left:auto;">
                        <a href="/login" class="btn-nav-login">Login</a>
                        <a href="/register" class="btn-nav-signup">Sign Up Free</a>
                    </div>
                    <% } %>
        </div>
    </nav>

    <main>