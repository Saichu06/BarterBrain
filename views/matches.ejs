<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a;
        --indigo:#4f46e5; --violet:#7c3aed; --il:#818cf8; --iv:#a78bfa;
        --text:#eeeeff; --muted:#7a7a9a; --border:rgba(255,255,255,0.065);
        --green:#10b981; --amber:#f59e0b; --blue:#3b82f6; --red:#ef4444;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); }
    a { text-decoration:none; color:inherit; }

    .page-wrap { max-width:1100px; margin:0 auto; padding:36px 28px 100px; }

    /* Breadcrumb */
    .breadcrumb {
        display:flex; align-items:center; gap:8px;
        font-size:0.78rem; color:var(--muted); margin-bottom:24px;
    }
    .breadcrumb a { color:var(--muted); transition:color .2s; }
    .breadcrumb a:hover { color:var(--il); }
    .breadcrumb i { font-size:0.7rem; opacity:.5; }

    /* Page header */
    .page-top {
        display:flex; align-items:flex-end; justify-content:space-between;
        flex-wrap:wrap; gap:16px; margin-bottom:32px;
    }
    .page-top h1 {
        font-family:'Sora',sans-serif; font-size:clamp(1.5rem,2.5vw,2rem);
        font-weight:800; letter-spacing:-0.8px; margin-bottom:4px;
    }
    .page-top h1 span {
        background:linear-gradient(120deg,var(--il),var(--iv));
        -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .page-sub { font-size:0.86rem; color:var(--muted); }

    .btn-new {
        display:inline-flex; align-items:center; gap:8px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff;
        font-family:'Sora',sans-serif; font-size:0.85rem; font-weight:700;
        padding:10px 22px; border-radius:10px; border:none;
        box-shadow:0 0 24px rgba(79,70,229,0.35); transition:all .25s; cursor:pointer;
    }
    .btn-new:hover { transform:translateY(-2px); box-shadow:0 8px 32px rgba(79,70,229,0.5); color:#fff; }

    /* Tabs */
    .tabs-bar {
        display:flex; gap:6px; margin-bottom:28px;
        background:var(--bg-1); border:1px solid var(--border);
        border-radius:12px; padding:5px; width:fit-content; flex-wrap:wrap;
    }
    .tab-btn {
        background:transparent; border:none; cursor:pointer;
        font-family:'DM Sans',sans-serif; font-size:0.82rem; font-weight:600;
        color:var(--muted); padding:8px 16px; border-radius:8px; transition:all .2s;
        display:flex; align-items:center; gap:6px;
    }
    .tab-btn .cnt {
        font-size:0.65rem; padding:1px 6px; border-radius:100px;
        background:rgba(255,255,255,0.06); border:1px solid var(--border);
    }
    .tab-btn.active {
        background:linear-gradient(135deg,rgba(79,70,229,0.25),rgba(124,58,237,0.18));
        color:var(--il); border:1px solid rgba(99,102,241,0.3);
    }
    .tab-btn.active .cnt { background:rgba(99,102,241,0.2); border-color:rgba(99,102,241,0.3); color:var(--il); }
    .tab-btn:hover:not(.active) { color:var(--text); background:rgba(255,255,255,0.04); }

    /* Match card */
    .match-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:20px;
        padding:24px; margin-bottom:14px;
        transition:border-color .25s, transform .25s, box-shadow .25s;
        position:relative; overflow:hidden;
    }
    /* coloured left accent per status */
    .match-card::before {
        content:''; position:absolute; left:0; top:0; bottom:0; width:3px; border-radius:3px 0 0 3px;
    }
    .match-card[data-status="pending"]::before   { background:#f59e0b; }
    .match-card[data-status="accepted"]::before  { background:#10b981; }
    .match-card[data-status="completed"]::before { background:#3b82f6; }
    .match-card[data-status="rejected"]::before  { background:#ef4444; }

    .match-card:hover {
        transform:translateY(-2px); box-shadow:0 14px 38px rgba(0,0,0,0.32);
        border-color:rgba(99,102,241,0.18);
    }

    /* Card top row */
    .card-top {
        display:flex; align-items:center; justify-content:space-between;
        flex-wrap:wrap; gap:10px; margin-bottom:20px;
    }
    .card-date {
        font-size:0.72rem; color:rgba(122,122,154,0.6);
        display:flex; align-items:center; gap:4px;
    }

    /* Status badges */
    .status-badge {
        display:inline-flex; align-items:center; gap:5px;
        padding:3px 11px; border-radius:100px;
        font-size:0.68rem; font-weight:700; letter-spacing:.06em; text-transform:capitalize;
    }
    .status-badge::before { content:''; width:5px; height:5px; border-radius:50%; }
    .status-pending   { background:rgba(245,158,11,0.1);  color:#fbbf24; border:1px solid rgba(245,158,11,0.22); }
    .status-pending::before   { background:#fbbf24; box-shadow:0 0 4px #fbbf24; }
    .status-accepted  { background:rgba(16,185,129,0.1);  color:#34d399; border:1px solid rgba(16,185,129,0.22); }
    .status-accepted::before  { background:#34d399; }
    .status-completed { background:rgba(59,130,246,0.1);  color:#60a5fa; border:1px solid rgba(59,130,246,0.18); }
    .status-completed::before { background:#60a5fa; }
    .status-rejected  { background:rgba(239,68,68,0.1);   color:#f87171; border:1px solid rgba(239,68,68,0.18); }
    .status-rejected::before  { background:#f87171; }

    /* Match body — two sides */
    .match-body {
        display:grid; grid-template-columns:1fr auto 1fr; gap:12px;
        align-items:center; margin-bottom:20px;
    }
    .match-side {
        background:var(--bg-2); border:1px solid var(--border);
        border-radius:12px; padding:14px 16px;
    }
    .side-role {
        font-size:0.64rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
        color:var(--muted); margin-bottom:6px; display:flex; align-items:center; gap:5px;
    }
    .side-role i { opacity:.6; }
    .user-name {
        font-family:'Sora',sans-serif; font-size:0.92rem; font-weight:700;
        color:var(--il); cursor:pointer; transition:color .2s; margin-bottom:4px;
        display:inline-block;
    }
    .user-name:hover { color:var(--iv); text-decoration:underline; }
    .skill-label {
        font-size:0.76rem; color:var(--muted); display:flex; align-items:center; gap:5px; margin-top:4px;
    }
    .skill-label i { opacity:.5; }
    .match-arrow { text-align:center; font-size:1.2rem; color:var(--muted); opacity:.4; }

    /* Actions */
    .match-actions {
        display:flex; flex-wrap:wrap; gap:8px;
        padding-top:16px; border-top:1px solid rgba(255,255,255,0.05);
        align-items:flex-start;
    }
    .match-actions form { margin:0; }

    .btn-act {
        display:inline-flex; align-items:center; gap:6px;
        font-size:0.79rem; font-weight:700;
        padding:8px 16px; border-radius:9px; cursor:pointer;
        border:none; transition:all .2s; white-space:nowrap;
    }
    .btn-act:hover { transform:translateY(-1px); }

    .btn-accept  { background:linear-gradient(135deg,#10b981,#059669); color:#fff; box-shadow:0 0 14px rgba(16,185,129,0.28); }
    .btn-accept:hover  { box-shadow:0 4px 18px rgba(16,185,129,0.42); }
    .btn-reject  { background:rgba(239,68,68,0.1); color:#f87171; border:1px solid rgba(239,68,68,0.2) !important; }
    .btn-reject:hover  { background:rgba(239,68,68,0.18); }
    .btn-contact { background:linear-gradient(135deg,#7c3aed,#5b21b6); color:#fff; box-shadow:0 0 14px rgba(124,58,237,0.28); }
    .btn-contact:hover { box-shadow:0 4px 18px rgba(124,58,237,0.42); }
    .btn-complete{ background:linear-gradient(135deg,#3b82f6,#2563eb); color:#fff; box-shadow:0 0 14px rgba(59,130,246,0.25); }
    .btn-complete:hover{ box-shadow:0 4px 18px rgba(59,130,246,0.4); }
    .btn-view    { background:rgba(129,140,248,0.1); color:var(--il); border:1px solid rgba(99,102,241,0.22) !important; }
    .btn-view:hover    { background:rgba(129,140,248,0.18); }
    .btn-review  { background:linear-gradient(135deg,#f59e0b,#d97706); color:#1a0e00; font-weight:800; }
    .btn-review:hover  { box-shadow:0 4px 18px rgba(245,158,11,0.38); }

    .status-tag {
        display:inline-flex; align-items:center; gap:6px;
        font-size:0.78rem; color:var(--muted); padding:8px 14px;
        background:rgba(255,255,255,0.03); border:1px solid var(--border); border-radius:9px;
    }

    /* Contact info panel */
    .contact-info {
        background:rgba(16,185,129,0.07); border:1px solid rgba(16,185,129,0.18);
        border-radius:12px; padding:14px 18px;
        width:100%; font-size:0.84rem; line-height:1.85;
        animation:slideDown .25s ease-out;
    }
    .contact-info.hidden { display:none; }
    .contact-info a { color:#34d399; }
    @keyframes slideDown {
        from { opacity:0; transform:translateY(-8px); }
        to   { opacity:1; transform:translateY(0); }
    }

    /* Empty */
    .empty-wrap {
        display:flex; flex-direction:column; align-items:center;
        justify-content:center; padding:80px 24px; text-align:center; gap:16px;
        background:var(--bg-1); border:1px solid var(--border); border-radius:20px;
    }
    .empty-icon-big {
        width:64px; height:64px; border-radius:18px;
        background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.18);
        display:flex; align-items:center; justify-content:center; font-size:1.8rem;
    }
    .empty-wrap h3 { font-family:'Sora',sans-serif; font-size:1.05rem; font-weight:700; }
    .empty-wrap p  { font-size:0.86rem; color:var(--muted); max-width:300px; line-height:1.6; }
    .empty-actions { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; }

    @media(max-width:640px){
        .page-wrap { padding:20px 14px 80px; }
        .match-body { grid-template-columns:1fr; }
        .match-arrow { transform:rotate(90deg); }
        .tabs-bar { width:100%; }
    }
</style>

<div class="page-wrap">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a href="/dashboard"><i class="bi bi-grid-fill"></i> Dashboard</a>
        <i class="bi bi-chevron-right"></i>
        <span>My Matches</span>
    </div>

    <!-- Header -->
    <div class="page-top">
        <div>
            <h1>Skill <span>Exchanges</span></h1>
            <p class="page-sub">Manage all your skill exchange connections in one place.</p>
        </div>
        <a href="/matches/potential" class="btn-new">
            <i class="bi bi-search"></i> Find New Matches
        </a>
    </div>

    <% if (locals.matches && matches.length > 0) { %>
        <%
            const counts = { all: matches.length, pending: 0, accepted: 0, completed: 0, rejected: 0 };
            matches.forEach(m => { if (counts[m.status] !== undefined) counts[m.status]++; });
        %>

        <!-- Tabs -->
        <div class="tabs-bar">
            <button class="tab-btn active" data-status="all">All <span class="cnt"><%= counts.all %></span></button>
            <button class="tab-btn" data-status="pending">Pending <span class="cnt"><%= counts.pending %></span></button>
            <button class="tab-btn" data-status="accepted">Accepted <span class="cnt"><%= counts.accepted %></span></button>
            <button class="tab-btn" data-status="completed">Completed <span class="cnt"><%= counts.completed %></span></button>
            <button class="tab-btn" data-status="rejected">Rejected <span class="cnt"><%= counts.rejected %></span></button>
        </div>

        <div id="matches-container">
            <% matches.forEach(match => { %>
                <div class="match-card" data-status="<%= match.status %>">

                    <!-- Top: status + date -->
                    <div class="card-top">
                        <span class="status-badge status-<%= match.status %>"><%= match.status %></span>
                        <span class="card-date">
                            <i class="bi bi-calendar3"></i>
                            <%= new Date(match.created_at).toLocaleDateString() %>
                        </span>
                    </div>

                    <!-- Teacher ⇄ Learner -->
                    <div class="match-body">
                        <div class="match-side">
                            <div class="side-role"><i class="bi bi-person-fill"></i> Teacher</div>
                            <div class="user-name" onclick="window.location.href='/user/<%= match.offer_user_id %>'">
                                <%= match.offer_user_name %>
                            </div>
                            <div class="skill-label"><i class="bi bi-tag-fill"></i> Teaching: <%= match.offer_skill_name %></div>
                        </div>

                        <div class="match-arrow">⇄</div>

                        <div class="match-side">
                            <div class="side-role"><i class="bi bi-person-fill"></i> Learner</div>
                            <div class="user-name" onclick="window.location.href='/user/<%= match.request_user_id %>'">
                                <%= match.request_user_name %>
                            </div>
                            <div class="skill-label"><i class="bi bi-tag-fill"></i> Learning: <%= match.request_skill_name %></div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="match-actions">

                        <% if (match.status === 'pending') { %>
                            <% if (match.offer_user_id === user.id) { %>
                                <form action="/matches/<%= match.match_id %>/accept" method="POST">
                                    <button type="submit" class="btn-act btn-accept"
                                        onclick="return confirm('Accept this skill exchange request?')">
                                        <i class="bi bi-check-lg"></i> Accept
                                    </button>
                                </form>
                                <form action="/matches/<%= match.match_id %>/reject" method="POST">
                                    <button type="submit" class="btn-act btn-reject"
                                        onclick="return confirm('Reject this skill exchange request?')">
                                        <i class="bi bi-x-lg"></i> Reject
                                    </button>
                                </form>
                            <% } else { %>
                                <span class="status-tag">
                                    <i class="bi bi-clock-history"></i> Waiting for teacher's response
                                </span>
                            <% } %>
                            <button class="btn-act btn-view"
                                onclick="window.location.href='/user/<%= match.offer_user_id === user.id ? match.request_user_id : match.offer_user_id %>'">
                                <i class="bi bi-person"></i> View Profile
                            </button>
                        <% } %>

                        <% if (match.status === 'accepted') { %>
                            <button class="btn-act btn-contact" id="btn-<%= match.match_id %>"
                                onclick="showContact('<%= match.match_id %>', this)">
                                <i class="bi bi-envelope-fill"></i> Show Contact
                            </button>
                            <button class="btn-act btn-view"
                                onclick="window.location.href='/user/<%= match.offer_user_id === user.id ? match.request_user_id : match.offer_user_id %>'">
                                <i class="bi bi-person"></i> View Profile
                            </button>
                            <form action="/matches/<%= match.match_id %>/complete" method="POST">
                                <button type="submit" class="btn-act btn-complete"
                                    onclick="return confirm('Mark this exchange as complete?')">
                                    <i class="bi bi-check-circle-fill"></i> Complete Exchange
                                </button>
                            </form>
                            <div id="contact-<%= match.match_id %>" class="contact-info hidden"></div>
                        <% } %>

                        <% if (match.status === 'completed') { %>
                            <button class="btn-act btn-view"
                                onclick="window.location.href='/user/<%= match.offer_user_id === user.id ? match.request_user_id : match.offer_user_id %>'">
                                <i class="bi bi-person"></i> View Profile
                            </button>
                            <a href="/matches/<%= match.match_id %>/review" class="btn-act btn-review">
                                <i class="bi bi-star-fill"></i> Leave Review
                            </a>
                        <% } %>

                        <% if (match.status === 'rejected') { %>
                            <button class="btn-act btn-view"
                                onclick="window.location.href='/user/<%= match.offer_user_id === user.id ? match.request_user_id : match.offer_user_id %>'">
                                <i class="bi bi-person"></i> View Profile
                            </button>
                            <span class="status-tag" style="color:#f87171; border-color:rgba(239,68,68,0.18);">
                                <i class="bi bi-x-circle-fill"></i> This request was rejected
                            </span>
                        <% } %>

                    </div>
                </div>
            <% }) %>
        </div>

    <% } else { %>
        <div class="empty-wrap">
            <div class="empty-icon-big">⚡</div>
            <h3>No matches yet</h3>
            <p>When you create offers or requests and connect with others, your matches will appear here.</p>
            <div class="empty-actions">
                <a href="/offers/new" class="btn-new">
                    <i class="bi bi-plus-lg"></i> Create Offer
                </a>
                <a href="/requests/new" class="btn-new"
                   style="background:linear-gradient(135deg,#7c3aed,#5b21b6);box-shadow:0 0 24px rgba(124,58,237,0.35);">
                    <i class="bi bi-journal-text"></i> Request a Skill
                </a>
            </div>
        </div>
    <% } %>

</div>

<script>
    // Tab filtering
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            const status = this.dataset.status;
            document.querySelectorAll('.match-card').forEach(card => {
                card.style.display = (status === 'all' || card.dataset.status === status) ? 'block' : 'none';
            });
        });
    });

    // Show / hide contact info
    async function showContact(matchId, btn) {
        const contactDiv = document.getElementById('contact-' + matchId);

        if (contactDiv.classList.contains('hidden')) {
            try {
                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Loading...';
                btn.disabled = true;

                const response = await fetch('/api/match/' + matchId + '/contact');
                const data = await response.json();

                if (response.ok) {
                    contactDiv.innerHTML = `
                        <strong style="color:var(--text); display:block; margin-bottom:6px;">${data.name}</strong>
                        📧 <a href="mailto:${data.email}">${data.email}</a><br>
                        📞 ${data.phone || 'Not provided'}
                    `;
                    contactDiv.classList.remove('hidden');
                    btn.innerHTML = '<i class="bi bi-eye-slash-fill"></i> Hide Contact';
                } else {
                    alert('Error: ' + (data.error || 'Failed to load contact info'));
                    btn.innerHTML = '<i class="bi bi-envelope-fill"></i> Show Contact';
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Failed to load contact information. Please try again.');
                btn.innerHTML = '<i class="bi bi-envelope-fill"></i> Show Contact';
            } finally {
                btn.disabled = false;
            }
        } else {
            contactDiv.classList.add('hidden');
            btn.innerHTML = '<i class="bi bi-envelope-fill"></i> Show Contact';
        }
    }
</script>

<%- include('partials/footer') %>
