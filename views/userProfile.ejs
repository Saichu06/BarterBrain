<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a; --bg-3:#1a1a30;
        --indigo:#4f46e5; --violet:#7c3aed; --il:#818cf8; --iv:#a78bfa;
        --text:#eeeeff; --muted:#7a7a9a; --border:rgba(255,255,255,0.065);
        --green:#10b981; --amber:#f59e0b; --blue:#3b82f6;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); }
    a { text-decoration:none; color:inherit; }

    .page-wrap { max-width:1200px; margin:0 auto; padding:36px 28px 100px; }

    /* ── HERO ── */
    .profile-hero {
        position:relative; overflow:hidden;
        background:linear-gradient(135deg,#1b1640 0%,#200e4a 55%,#130d2e 100%);
        border:1px solid rgba(99,102,241,0.22); border-radius:24px;
        padding:44px 48px; margin-bottom:28px;
    }
    .profile-hero::before {
        content:''; position:absolute;
        width:500px; height:500px;
        background:radial-gradient(circle,rgba(124,58,237,0.22),transparent 65%);
        top:-180px; right:-80px; border-radius:50%; pointer-events:none;
    }
    .profile-hero::after {
        content:''; position:absolute;
        width:280px; height:280px;
        background:radial-gradient(circle,rgba(79,70,229,0.16),transparent 65%);
        bottom:-90px; left:80px; border-radius:50%; pointer-events:none;
    }

    .hero-inner {
        position:relative; z-index:1;
        display:flex; align-items:center; justify-content:space-between;
        flex-wrap:wrap; gap:28px;
    }

    .hero-left { display:flex; align-items:center; gap:28px; flex-wrap:wrap; }

    .profile-avatar {
        width:96px; height:96px; border-radius:22px; flex-shrink:0;
        background:linear-gradient(135deg,rgba(79,70,229,0.4),rgba(124,58,237,0.3));
        border:2px solid rgba(99,102,241,0.4);
        display:flex; align-items:center; justify-content:center;
        font-family:'Sora',sans-serif; font-size:2.4rem; font-weight:800;
        color:#c4b5fd; line-height:1; user-select:none;
    }

    .hero-info h1 {
        font-family:'Sora',sans-serif; font-size:clamp(1.5rem,2.5vw,2rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text); margin-bottom:4px;
    }

    .hero-handle {
        font-size:0.88rem; color:rgba(165,180,252,0.6); margin-bottom:14px;
    }

    .hero-meta { display:flex; align-items:center; gap:14px; flex-wrap:wrap; }

    .rep-pill {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.22);
        color:#fbbf24; padding:5px 14px; border-radius:100px;
        font-size:0.82rem; font-weight:700;
    }
    .rep-stars { display:flex; gap:2px; }
    .rep-stars .sf { color:#fbbf24; font-size:0.85rem; }
    .rep-stars .se { color:rgba(251,191,36,0.2); font-size:0.85rem; }

    .hero-meta-item {
        display:flex; align-items:center; gap:6px;
        font-size:0.8rem; color:rgba(165,180,252,0.6);
    }
    .hero-meta-item i { font-size:0.82rem; }

    .hero-right { position:relative; z-index:1; }

    .btn-edit-own {
        display:inline-flex; align-items:center; gap:8px;
        background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1);
        color:var(--text); font-size:0.84rem; font-weight:600;
        padding:10px 20px; border-radius:10px; cursor:pointer;
        transition:all .2s; white-space:nowrap;
    }
    .btn-edit-own:hover {
        background:rgba(99,102,241,0.15); border-color:rgba(99,102,241,0.35); color:#a5b4fc;
    }

    /* ── STATS STRIP ── */
    .stats-strip {
        display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:28px;
    }
    .stat-item {
        background:var(--bg-1); border:1px solid var(--border); border-radius:16px;
        padding:18px 20px; display:flex; align-items:center; gap:14px;
        transition:border-color .25s, transform .2s;
    }
    .stat-item:hover { border-color:rgba(99,102,241,0.22); transform:translateY(-2px); }
    .stat-icon-box {
        width:42px; height:42px; border-radius:11px; flex-shrink:0;
        display:flex; align-items:center; justify-content:center; font-size:1.1rem;
    }
    .c-indigo { background:rgba(79,70,229,0.15); }
    .c-green   { background:rgba(16,185,129,0.13); }
    .c-amber   { background:rgba(245,158,11,0.12); }
    .stat-val { font-family:'Sora',sans-serif; font-size:1.5rem; font-weight:800; letter-spacing:-0.8px; line-height:1; }
    .stat-lbl { font-size:0.74rem; color:var(--muted); margin-top:3px; }

    /* ── CONTENT GRID ── */
    .content-grid { display:grid; grid-template-columns:320px 1fr; gap:20px; align-items:start; }

    /* ── SEC CARDS ── */
    .sec-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:18px;
        padding:24px; margin-bottom:18px;
    }
    .sec-card:last-child { margin-bottom:0; }

    .sec-head {
        display:flex; align-items:center; gap:9px;
        margin-bottom:18px; padding-bottom:14px; border-bottom:1px solid var(--border);
    }
    .sec-head-icon {
        width:30px; height:30px; border-radius:8px; flex-shrink:0;
        display:flex; align-items:center; justify-content:center; font-size:0.85rem;
    }
    .sec-head h2 {
        font-family:'Sora',sans-serif; font-size:0.9rem; font-weight:700; color:var(--text);
        letter-spacing:-0.2px;
    }

    /* Contact rows */
    .info-row {
        display:flex; align-items:flex-start; gap:12px;
        padding:10px 0; border-bottom:1px solid rgba(255,255,255,0.04);
    }
    .info-row:last-child { border-bottom:none; }
    .info-row i { color:var(--il); font-size:0.85rem; margin-top:2px; opacity:.65; width:18px; text-align:center; flex-shrink:0; }
    .info-lbl { font-size:0.78rem; color:var(--muted); font-weight:500; min-width:60px; flex-shrink:0; }
    .info-val { font-size:0.85rem; color:var(--text); font-weight:500; word-break:break-all; }

    /* Skill grids */
    .skills-grid {
        display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:10px;
    }
    .skill-card {
        background:var(--bg-2); border:1px solid var(--border); border-radius:12px;
        padding:14px 16px; transition:border-color .2s, transform .2s;
    }
    .skill-card:hover { border-color:rgba(99,102,241,0.22); transform:translateX(3px); }
    .skill-card h3 {
        font-family:'Sora',sans-serif; font-size:0.88rem; font-weight:700;
        color:var(--text); margin-bottom:5px; letter-spacing:-0.2px;
    }
    .skill-card p { font-size:0.78rem; color:var(--muted); line-height:1.55; }

    .skill-card.green { border-left:2px solid rgba(16,185,129,0.3); }
    .skill-card.green:hover { border-color:rgba(16,185,129,0.3); }

    /* Review tabs */
    .reviews-tabs {
        display:flex; gap:6px; margin-bottom:18px;
        background:var(--bg-2); border:1px solid var(--border);
        border-radius:10px; padding:4px; width:fit-content;
    }
    .rtab {
        background:transparent; border:none; cursor:pointer;
        font-family:'DM Sans',sans-serif; font-size:0.8rem; font-weight:600;
        color:var(--muted); padding:7px 16px; border-radius:7px; transition:all .2s;
        display:flex; align-items:center; gap:6px;
    }
    .rtab.active {
        background:linear-gradient(135deg,rgba(79,70,229,0.22),rgba(124,58,237,0.15));
        color:var(--il); border:1px solid rgba(99,102,241,0.25);
    }
    .rtab:hover:not(.active) { color:var(--text); background:rgba(255,255,255,0.04); }
    .rtab .cnt {
        font-size:0.68rem; background:rgba(99,102,241,0.15);
        border:1px solid rgba(99,102,241,0.2); color:var(--il);
        padding:1px 7px; border-radius:100px;
    }

    .review-panel { display:none; }
    .review-panel.active { display:flex; flex-direction:column; gap:10px; }

    .review-card {
        background:var(--bg-2); border:1px solid var(--border); border-radius:12px;
        padding:16px 18px; border-left:3px solid rgba(99,102,241,0.35);
        transition:border-color .2s;
    }
    .review-card:hover { border-left-color:var(--il); }

    .rev-stars { display:flex; gap:2px; margin-bottom:8px; }
    .rev-stars .sf { color:#fbbf24; font-size:0.88rem; }
    .rev-stars .se { color:rgba(251,191,36,0.18); font-size:0.88rem; }

    .rev-comment {
        font-size:0.82rem; color:var(--muted); line-height:1.6;
        font-style:italic; margin-bottom:10px;
    }

    .rev-footer { display:flex; flex-wrap:wrap; gap:14px; align-items:center; }
    .rev-footer span {
        font-size:0.7rem; color:rgba(122,122,154,0.65);
        display:flex; align-items:center; gap:4px;
    }
    .rev-skill {
        font-size:0.7rem; font-weight:700; padding:2px 9px; border-radius:100px;
        background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.18); color:var(--il);
    }

    /* empty */
    .empty-mini {
        display:flex; flex-direction:column; align-items:center;
        padding:28px 12px; text-align:center; gap:8px;
    }
    .empty-mini-icon {
        width:42px; height:42px; border-radius:11px;
        background:rgba(255,255,255,0.04); border:1px solid var(--border);
        display:flex; align-items:center; justify-content:center; font-size:1.1rem; opacity:.4;
    }
    .empty-mini p { font-size:0.8rem; color:var(--muted); max-width:200px; line-height:1.5; }

    @media(max-width:1024px) { .content-grid{grid-template-columns:1fr;} .stats-strip{grid-template-columns:repeat(3,1fr);} }
    @media(max-width:640px)  { .page-wrap{padding:20px 14px 80px;} .profile-hero{padding:26px 22px;} .stats-strip{grid-template-columns:1fr 1fr;} .skills-grid{grid-template-columns:1fr;} }
</style>

<div class="page-wrap">

    <!-- ── HERO ── -->
    <div class="profile-hero">
        <div class="hero-inner">
            <div class="hero-left">
                <div class="profile-avatar">
                    <%= profileUser.full_name.charAt(0).toUpperCase() %>
                </div>
                <div class="hero-info">
                    <h1><%= profileUser.full_name %></h1>
                    <p class="hero-handle">@<%= profileUser.username %></p>
                    <div class="hero-meta">
                        <div class="rep-pill">
                            <%
                            const rating = typeof avgRating === 'number' ? avgRating : parseFloat(avgRating) || 0;
                            %>
                            <i class="bi bi-star-fill"></i>
                            <%= rating.toFixed(1) %> / 5.0
                        </div>
                        <div class="rep-stars">
                            <% const full = Math.floor(rating); %>
                            <% for(let i=0;i<full;i++) { %><span class="sf">★</span><% } %>
                            <% for(let i=full;i<5;i++) { %><span class="se">★</span><% } %>
                        </div>
                        <div class="hero-meta-item">
                            <i class="bi bi-calendar3"></i>
                            Member since <%= new Date(profileUser.created_at).toLocaleDateString('en-US',{month:'short',year:'numeric'}) %>
                        </div>
                    </div>
                </div>
            </div>
            <div class="hero-right">
                <% if (profileUser.user_id === user.id) { %>
                    <a href="/profile" class="btn-edit-own">
                        <i class="bi bi-pencil-square"></i> Edit Your Profile
                    </a>
                <% } %>
            </div>
        </div>
    </div>

    <!-- ── STATS STRIP ── -->
    <div class="stats-strip">
        <div class="stat-item">
            <div class="stat-icon-box c-indigo">💼</div>
            <div>
                <div class="stat-val"><%= offers ? offers.length : 0 %></div>
                <div class="stat-lbl">Skills Offered</div>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon-box c-green">📋</div>
            <div>
                <div class="stat-val"><%= requests ? requests.length : 0 %></div>
                <div class="stat-lbl">Skills Wanted</div>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon-box c-amber">⭐</div>
            <div>
                <div class="stat-val"><%= (reviewsAsTeacher ? reviewsAsTeacher.length : 0) + (reviewsAsLearner ? reviewsAsLearner.length : 0) %></div>
                <div class="stat-lbl">Total Reviews</div>
            </div>
        </div>
    </div>

    <!-- ── CONTENT GRID ── -->
    <div class="content-grid">

        <!-- LEFT — Contact -->
        <div>
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-indigo"><i class="bi bi-person-lines-fill" style="color:var(--il);"></i></div>
                    <h2>Contact Information</h2>
                </div>
                <div class="info-row">
                    <i class="bi bi-envelope"></i>
                    <span class="info-lbl">Email</span>
                    <span class="info-val"><%= profileUser.email %></span>
                </div>
                <% if (profileUser.phone_number) { %>
                <div class="info-row">
                    <i class="bi bi-telephone"></i>
                    <span class="info-lbl">Phone</span>
                    <span class="info-val"><%= profileUser.phone_number %></span>
                </div>
                <% } %>
                <div class="info-row">
                    <i class="bi bi-person-badge"></i>
                    <span class="info-lbl">Username</span>
                    <span class="info-val">@<%= profileUser.username %></span>
                </div>
            </div>
        </div>

        <!-- RIGHT — Skills + Reviews -->
        <div>

            <!-- Skills Offered -->
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-indigo"><i class="bi bi-briefcase-fill" style="color:var(--il);"></i></div>
                    <h2>Skills Offered</h2>
                </div>
                <% if (offers && offers.length > 0) { %>
                    <div class="skills-grid">
                        <% offers.forEach(offer => { %>
                            <div class="skill-card">
                                <h3><%= offer.skill_name %></h3>
                                <p><%= offer.description || 'No description provided' %></p>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="empty-mini">
                        <div class="empty-mini-icon">💼</div>
                        <p>No skills offered yet.</p>
                    </div>
                <% } %>
            </div>

            <!-- Skills Wanted -->
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-green"><i class="bi bi-journal-bookmark-fill" style="color:#34d399;"></i></div>
                    <h2>Skills Wanted</h2>
                </div>
                <% if (requests && requests.length > 0) { %>
                    <div class="skills-grid">
                        <% requests.forEach(request => { %>
                            <div class="skill-card green">
                                <h3><%= request.skill_name %></h3>
                                <p><%= request.description || 'No description provided' %></p>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="empty-mini">
                        <div class="empty-mini-icon">📋</div>
                        <p>No skill requests yet.</p>
                    </div>
                <% } %>
            </div>

            <!-- Reviews -->
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-amber"><i class="bi bi-chat-square-text-fill" style="color:#fbbf24;"></i></div>
                    <h2>Reviews</h2>
                </div>

                <% const hasTeacher = reviewsAsTeacher && reviewsAsTeacher.length > 0; %>
                <% const hasLearner = reviewsAsLearner && reviewsAsLearner.length > 0; %>

                <% if (hasTeacher || hasLearner) { %>
                    <div class="reviews-tabs">
                        <button class="rtab active" data-tab="teacher" onclick="switchTab(this,'teacher')">
                            As Teacher
                            <span class="cnt"><%= reviewsAsTeacher ? reviewsAsTeacher.length : 0 %></span>
                        </button>
                        <button class="rtab" data-tab="learner" onclick="switchTab(this,'learner')">
                            As Learner
                            <span class="cnt"><%= reviewsAsLearner ? reviewsAsLearner.length : 0 %></span>
                        </button>
                    </div>

                    <!-- Teacher reviews -->
                    <div class="review-panel active" id="panel-teacher">
                        <% if (hasTeacher) { %>
                            <% reviewsAsTeacher.forEach(review => { %>
                                <div class="review-card">
                                    <div class="rev-stars">
                                        <% for(let i=0;i<review.rating;i++) { %><span class="sf">★</span><% } %>
                                        <% for(let i=review.rating;i<5;i++) { %><span class="se">★</span><% } %>
                                    </div>
                                    <p class="rev-comment">"<%= review.comment || 'No comment left' %>"</p>
                                    <div class="rev-footer">
                                        <span><i class="bi bi-person"></i> <%= review.reviewer_name %></span>
                                        <span class="rev-skill"><%= review.skill_name %></span>
                                        <span><i class="bi bi-calendar3"></i> <%= new Date(review.created_at).toLocaleDateString() %></span>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-mini"><div class="empty-mini-icon">⭐</div><p>No teacher reviews yet.</p></div>
                        <% } %>
                    </div>

                    <!-- Learner reviews -->
                    <div class="review-panel" id="panel-learner">
                        <% if (hasLearner) { %>
                            <% reviewsAsLearner.forEach(review => { %>
                                <div class="review-card">
                                    <div class="rev-stars">
                                        <% for(let i=0;i<review.rating;i++) { %><span class="sf">★</span><% } %>
                                        <% for(let i=review.rating;i<5;i++) { %><span class="se">★</span><% } %>
                                    </div>
                                    <p class="rev-comment">"<%= review.comment || 'No comment left' %>"</p>
                                    <div class="rev-footer">
                                        <span><i class="bi bi-person"></i> <%= review.reviewer_name %></span>
                                        <span class="rev-skill"><%= review.skill_name %></span>
                                        <span><i class="bi bi-calendar3"></i> <%= new Date(review.created_at).toLocaleDateString() %></span>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="empty-mini"><div class="empty-mini-icon">⭐</div><p>No learner reviews yet.</p></div>
                        <% } %>
                    </div>

                <% } else { %>
                    <div class="empty-mini">
                        <div class="empty-mini-icon">⭐</div>
                        <p>No reviews yet. Complete skill exchanges to earn them!</p>
                    </div>
                <% } %>
            </div>

        </div><!-- end right col -->
    </div><!-- end content-grid -->
</div>

<script>
    function switchTab(btn, tab) {
        document.querySelectorAll('.rtab').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.review-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('panel-' + tab).classList.add('active');
    }
</script>

<%- include('partials/footer') %>
