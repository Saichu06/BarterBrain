<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a; --bg-3:#1a1a30;
        --indigo:#4f46e5; --violet:#7c3aed; --il:#818cf8; --iv:#a78bfa;
        --text:#eeeeff; --muted:#7a7a9a; --border:rgba(255,255,255,0.065);
        --green:#10b981; --amber:#f59e0b;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); }
    a { text-decoration:none; }

    .page-wrap { max-width:1100px; margin:0 auto; padding:36px 28px 100px; }

    .page-top { margin-bottom:36px; }
    .page-top h1 {
        font-family:'Sora',sans-serif; font-size:clamp(1.5rem,2.5vw,2rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text); margin-bottom:5px;
    }
    .page-top h1 span {
        background:linear-gradient(120deg,var(--il),var(--iv));
        -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .page-sub { font-size:0.86rem; color:var(--muted); }

    /* Request section */
    .request-section {
        margin-bottom:36px;
    }

    .req-header {
        background:linear-gradient(135deg,rgba(79,70,229,0.12),rgba(124,58,237,0.08));
        border:1px solid rgba(99,102,241,0.22); border-radius:16px;
        padding:20px 24px; margin-bottom:16px; display:flex;
        align-items:flex-start; gap:14px;
    }

    .req-icon {
        width:42px; height:42px; border-radius:11px;
        background:rgba(79,70,229,0.18); display:flex;
        align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0;
    }

    .req-info h2 {
        font-family:'Sora',sans-serif; font-size:1rem; font-weight:700;
        color:var(--text); margin-bottom:4px;
    }

    .req-info p { font-size:0.82rem; color:var(--muted); line-height:1.5; }

    .req-info .req-label {
        font-size:0.65rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
        color:var(--il); margin-bottom:5px; display:block;
    }

    /* Matching offers sub-heading */
    .offers-label {
        font-size:0.68rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
        color:var(--muted); margin-bottom:12px; display:flex; align-items:center; gap:8px;
    }
    .offers-label::after {
        content:''; flex:1; height:1px; background:var(--border);
    }

    /* Offers grid */
    .offers-list {
        display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:12px;
    }

    .offer-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:14px;
        padding:18px; display:flex; flex-direction:column; gap:10px;
        transition:border-color .25s, transform .25s, box-shadow .25s;
    }
    .offer-card:hover {
        border-color:rgba(99,102,241,0.25); transform:translateY(-3px);
        box-shadow:0 12px 32px rgba(0,0,0,0.3);
    }

    .offer-card h4 {
        font-family:'Sora',sans-serif; font-size:0.9rem; font-weight:700;
        color:var(--text); margin-bottom:2px;
    }

    .offer-user {
        display:flex; align-items:center; gap:6px;
        font-size:0.76rem; color:var(--muted);
    }
    .offer-user i { color:var(--il); opacity:.6; font-size:0.8rem; }

    .offer-card p.desc {
        font-size:0.8rem; color:var(--muted); line-height:1.55; flex:1;
    }

    .offer-card form { margin:0; }

    .btn-match {
        width:100%; display:flex; align-items:center; justify-content:center; gap:7px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed);
        color:#fff; font-family:'Sora',sans-serif; font-size:0.82rem; font-weight:700;
        padding:10px; border-radius:9px; border:none; cursor:pointer;
        box-shadow:0 0 20px rgba(79,70,229,0.3); transition:all .25s;
    }
    .btn-match:hover { transform:translateY(-1px); box-shadow:0 6px 24px rgba(79,70,229,0.45); }

    .no-offers {
        background:var(--bg-1); border:1px dashed rgba(255,255,255,0.07);
        border-radius:12px; padding:22px; text-align:center;
        font-size:0.82rem; color:var(--muted);
    }

    /* empty state */
    .empty-wrap {
        display:flex; flex-direction:column; align-items:center;
        justify-content:center; padding:80px 20px; text-align:center; gap:16px;
    }
    .empty-icon-big {
        width:64px; height:64px; border-radius:18px;
        background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.18);
        display:flex; align-items:center; justify-content:center; font-size:1.8rem;
    }
    .empty-wrap h3 { font-family:'Sora',sans-serif; font-size:1.05rem; font-weight:700; color:var(--text); }
    .empty-wrap p  { font-size:0.86rem; color:var(--muted); max-width:280px; line-height:1.6; }
    .btn-new {
        display:inline-flex; align-items:center; gap:8px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff;
        font-family:'Sora',sans-serif; font-size:0.85rem; font-weight:700;
        padding:10px 22px; border-radius:10px; border:none;
        box-shadow:0 0 24px rgba(79,70,229,0.35); transition:all .25s;
    }
    .btn-new:hover { transform:translateY(-2px); box-shadow:0 8px 32px rgba(79,70,229,0.5); color:#fff; }

    @media(max-width:640px){ .page-wrap{padding:22px 14px 80px;} }
</style>

<div class="page-wrap">
    <div class="page-top">
        <h1>Potential <span>Matches</span></h1>
        <p class="page-sub">Skill offers that align with your learning requests.</p>
    </div>

    <% if (locals.potentialMatches && potentialMatches.length > 0) { %>
        <% potentialMatches.forEach(item => { %>
            <div class="request-section">
                <div class="req-header">
                    <div class="req-icon">📋</div>
                    <div class="req-info">
                        <span class="req-label">Your Request</span>
                        <h2><%= item.request.skill_name %></h2>
                        <p><%= item.request.description || 'No description provided' %></p>
                    </div>
                </div>

                <% if (item.offers && item.offers.length > 0) { %>
                    <div class="offers-label">
                        <%= item.offers.length %> matching offer<%= item.offers.length > 1 ? 's' : '' %> found
                    </div>
                    <div class="offers-list">
                        <% item.offers.forEach(offer => { %>
                            <div class="offer-card">
                                <div>
                                    <h4><%= offer.full_name %></h4>
                                    <div class="offer-user">
                                        <i class="bi bi-person-circle"></i> Skill match for your request
                                    </div>
                                </div>
                                <p class="desc"><%= offer.description || 'No description provided' %></p>
                                <form action="/matches/create" method="POST">
                                    <input type="hidden" name="offerId"   value="<%= offer.offer_id %>">
                                    <input type="hidden" name="requestId" value="<%= item.request.request_id %>">
                                    <button type="submit" class="btn-match">
                                        <i class="bi bi-lightning-charge-fill"></i> Create Match
                                    </button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="no-offers">No matching offers found for this request yet.</div>
                <% } %>
            </div>
        <% }) %>
    <% } else { %>
        <div class="empty-wrap">
            <div class="empty-icon-big">🔍</div>
            <h3>No requests to match</h3>
            <p>Create a skill request first, and we'll find people who can teach you!</p>
            <a href="/requests/new" class="btn-new"><i class="bi bi-plus-lg"></i> Create a Request</a>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
