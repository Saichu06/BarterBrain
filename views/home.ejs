<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BarterBrain — Exchange Skills, Not Money</title>
    <link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Cabinet+Grotesk:wght@400;500;700;800;900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --bg: #06060f;
            --bg-2: #0d0d1e;
            --bg-3: #111128;
            --indigo: #5b52ff;
            --violet: #8b5cf6;
            --pink: #e040fb;
            --cyan: #06b6d4;
            --gold: #f5c842;
            --text: #f4f4ff;
            --muted: #7070a0;
            --border: rgba(255,255,255,0.07);
            --border-glow: rgba(91,82,255,0.4);
            --card: rgba(255,255,255,0.03);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Cabinet Grotesk', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        /* ─────────────────── BRAIN CLASH LOADER ─────────────────── */
        #loader {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: var(--bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            transition: opacity 0.9s cubic-bezier(.4,0,.2,1), transform 0.9s cubic-bezier(.4,0,.2,1);
        }
        #loader.hidden {
            opacity: 0;
            transform: scale(1.06);
            pointer-events: none;
        }

        /* ambient background orbs */
        .loader-orbs {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }
        .loader-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
        }
        .loader-orb-1 {
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(91,82,255,0.2), transparent 70%);
            top: -150px; left: -150px;
        }
        .loader-orb-2 {
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(224,64,251,0.15), transparent 70%);
            bottom: -100px; right: -100px;
        }

        /* ── clash arena ── */
        .clash-arena {
            position: relative;
            width: 420px;
            height: 220px;
            margin-bottom: 40px;
        }

        /* ── brains ── */
        .brain {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        .brain-left  { left: 0;   animation: brainSlideLeft  1s 0.3s cubic-bezier(.22,1,.36,1) both; }
        .brain-right { right: 0;  animation: brainSlideRight 1s 0.3s cubic-bezier(.22,1,.36,1) both; }

        @keyframes brainSlideLeft {
            from { transform: translateY(-50%) translateX(-180px); opacity: 0; }
            to   { transform: translateY(-50%) translateX(0);       opacity: 1; }
        }
        @keyframes brainSlideRight {
            from { transform: translateY(-50%) translateX(180px);  opacity: 0; }
            to   { transform: translateY(-50%) translateX(0);      opacity: 1; }
        }

        .brain svg {
            width: 100px;
            height: 100px;
            filter: drop-shadow(0 0 18px rgba(91,82,255,0.7));
            animation: brainPulse 2s ease-in-out infinite;
        }
        .brain-right svg {
            filter: drop-shadow(0 0 18px rgba(224,64,251,0.7));
            animation: brainPulseR 2s ease-in-out infinite;
            transform: scaleX(-1);
        }

        @keyframes brainPulse {
            0%,100% { filter: drop-shadow(0 0 18px rgba(91,82,255,0.7)); }
            50%      { filter: drop-shadow(0 0 36px rgba(91,82,255,1)) drop-shadow(0 0 60px rgba(91,82,255,0.4)); }
        }
        @keyframes brainPulseR {
            0%,100% { filter: drop-shadow(0 0 18px rgba(224,64,251,0.7)); }
            50%      { filter: drop-shadow(0 0 36px rgba(224,64,251,1)) drop-shadow(0 0 60px rgba(224,64,251,0.4)); }
        }

        .brain-label {
            font-family: 'Clash Display', sans-serif;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            opacity: 0;
            animation: fadeIn 0.4s 1.1s forwards;
        }
        .brain-left  .brain-label { color: #818cf8; }
        .brain-right .brain-label { color: #e040fb; }

        /* ── VS / clash ── */
        .clash-center {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }
        .vs-badge {
            font-family: 'Clash Display', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #818cf8, #e040fb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            opacity: 0;
            animation: vsPop 0.5s 1.3s cubic-bezier(.34,1.56,.64,1) forwards;
        }
        @keyframes vsPop {
            from { opacity: 0; transform: scale(0.3) rotate(-15deg); }
            to   { opacity: 1; transform: scale(1) rotate(0deg); }
        }

        /* ── lightning bolts ── */
        .lightning {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            opacity: 0;
            animation: lightningFlash 0.5s 1.4s ease-out forwards;
        }
        @keyframes lightningFlash {
            0%   { opacity: 0; transform: translate(-50%,-50%) scale(0.6); }
            30%  { opacity: 1; transform: translate(-50%,-50%) scale(1.1); }
            60%  { opacity: 0.7; }
            100% { opacity: 0; transform: translate(-50%,-50%) scale(1.3); }
        }

        /* ── shockwave ring ── */
        .shockwave {
            position: absolute;
            top: 50%; left: 50%;
            width: 20px; height: 20px;
            border-radius: 50%;
            border: 2px solid rgba(139,92,246,0.8);
            transform: translate(-50%, -50%) scale(1);
            opacity: 0;
            animation: shockwaveExpand 0.8s 1.45s ease-out forwards;
        }
        .shockwave:nth-child(2) {
            border-color: rgba(224,64,251,0.6);
            animation-delay: 1.55s;
        }
        .shockwave:nth-child(3) {
            border-color: rgba(91,82,255,0.4);
            animation-delay: 1.65s;
        }
        @keyframes shockwaveExpand {
            0%   { transform: translate(-50%,-50%) scale(1);   opacity: 1; }
            100% { transform: translate(-50%,-50%) scale(22);  opacity: 0; }
        }

        /* ── energy sparks canvas ── */
        #sparkCanvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        /* ── bottom bar ── */
        .loader-bottom {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 14px;
            opacity: 0;
            animation: fadeSlideUp 0.5s 1.0s forwards;
        }
        .loader-logo-text {
            font-family: 'Clash Display', sans-serif;
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #818cf8, #a78bfa, #e040fb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .loader-bar-wrap {
            width: 260px;
            height: 2px;
            background: rgba(255,255,255,0.07);
            border-radius: 99px;
            overflow: hidden;
        }
        .loader-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #5b52ff, #e040fb);
            border-radius: 99px;
            animation: loadProgress 2s 1.1s cubic-bezier(.4,0,.2,1) forwards;
        }
        @keyframes loadProgress { to { width: 100%; } }
        .loader-tagline {
            font-size: 0.78rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--muted);
        }

        /* ─────────────────── GLOBAL KEYFRAMES ─────────────────── */
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeIn {
            from { opacity: 0; } to { opacity: 1; }
        }
        @keyframes orbFloat {
            from { transform: translate(0, 0) scale(1); }
            to   { transform: translate(30px, 20px) scale(1.08); }
        }
        @keyframes spin3d {
            from { transform: rotateY(0deg) rotateX(5deg); }
            to   { transform: rotateY(360deg) rotateX(5deg); }
        }
        @keyframes floatY {
            0%, 100% { transform: translateY(0px); }
            50%       { transform: translateY(-12px); }
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: 0.5; transform: scale(0.8); }
        }
        @keyframes shimmer {
            from { background-position: -200% center; }
            to   { background-position: 200% center; }
        }
        @keyframes cardFloat1 {
            0%,100% { transform: translateY(0) rotate(-2deg); }
            50%     { transform: translateY(-18px) rotate(-2deg); }
        }
        @keyframes cardFloat2 {
            0%,100% { transform: translateY(0) rotate(2deg); }
            50%     { transform: translateY(-12px) rotate(2deg); }
        }
        @keyframes cardFloat3 {
            0%,100% { transform: translateY(0) rotate(-1deg); }
            50%     { transform: translateY(-20px) rotate(-1deg); }
        }
        @keyframes glowPulse {
            0%,100% { box-shadow: 0 0 40px rgba(91,82,255,0.3); }
            50%      { box-shadow: 0 0 80px rgba(91,82,255,0.55), 0 0 120px rgba(224,64,251,0.2); }
        }

        /* ─────────────────── NAVBAR ─────────────────── */
        body { padding-top: 72px; }

        .navbar {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            padding: 0 5%;
            height: 72px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(6,6,15,0.7);
            backdrop-filter: blur(24px) saturate(1.5);
            border-bottom: 1px solid var(--border);
            transition: background 0.3s;
        }
        .nav-brand {
            font-family: 'Clash Display', sans-serif;
            font-size: 1.55rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(120deg, #818cf8, #a78bfa, #e040fb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
        }
        .nav-links {
            display: flex;
            align-items: center;
            gap: 4px;
            list-style: none;
        }
        .nav-links a {
            display: block;
            padding: 7px 15px;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--muted);
            text-decoration: none;
            transition: color 0.2s, background 0.2s;
        }
        .nav-links a:hover { color: var(--text); background: rgba(255,255,255,0.05); }
        .nav-actions { display: flex; align-items: center; gap: 10px; }
        .btn-login {
            padding: 8px 20px; border-radius: 9px;
            font-size: 0.88rem; font-weight: 600;
            border: 1px solid rgba(91,82,255,0.4);
            color: #818cf8; background: transparent;
            text-decoration: none;
            transition: all 0.25s;
        }
        .btn-login:hover { background: rgba(91,82,255,0.1); color: #a5b4fc; }
        .btn-signup {
            padding: 8px 22px; border-radius: 9px;
            font-size: 0.88rem; font-weight: 600;
            background: linear-gradient(135deg, #5b52ff, #8b5cf6);
            color: #fff; text-decoration: none; border: none;
            box-shadow: 0 0 24px rgba(91,82,255,0.4);
            transition: all 0.25s;
        }
        .btn-signup:hover { transform: translateY(-1px); box-shadow: 0 4px 32px rgba(91,82,255,0.6); color: #fff; }
        .nav-toggle { display: none; background: none; border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; cursor: pointer; color: var(--text); }
        @media (max-width: 768px) {
            .nav-links, .nav-actions { display: none; }
            .nav-toggle { display: block; }
        }

        /* ─────────────────── SCENE CANVAS ─────────────────── */
        #scene-canvas {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        /* ─────────────────── HERO ─────────────────── */
        .hero {
            position: relative;
            min-height: calc(100vh - 72px);
            display: flex;
            align-items: center;
            padding: 80px 5% 100px;
            overflow: hidden;
        }
        .hero-content { position: relative; z-index: 2; }

        .grid-floor {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 60%;
            background-image:
                linear-gradient(rgba(91,82,255,0.12) 1px, transparent 1px),
                linear-gradient(90deg, rgba(91,82,255,0.12) 1px, transparent 1px);
            background-size: 60px 60px;
            transform: perspective(600px) rotateX(55deg);
            transform-origin: bottom center;
            mask-image: linear-gradient(to top, black 0%, transparent 70%);
            -webkit-mask-image: linear-gradient(to top, black 0%, transparent 70%);
        }

        .hero-glow {
            position: absolute;
            width: 900px; height: 700px;
            background: radial-gradient(ellipse at center,
                rgba(91,82,255,0.22) 0%,
                rgba(139,92,246,0.12) 40%,
                transparent 70%);
            top: 50%; left: 50%;
            transform: translate(-50%, -55%);
            pointer-events: none;
        }

        .hero-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }
        @media (max-width: 900px) {
            .hero-row { grid-template-columns: 1fr; }
            .hero-3d-scene { display: none; }
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(91,82,255,0.1);
            border: 1px solid rgba(91,82,255,0.28);
            color: #a5b4fc;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 6px 16px;
            border-radius: 100px;
            margin-bottom: 26px;
        }
        .hero-eyebrow .dot { width: 6px; height: 6px; background: #818cf8; border-radius: 50%; animation: pulse 2s infinite; }

        .hero-title {
            font-family: 'Clash Display', sans-serif;
            font-size: clamp(3rem, 5.5vw, 5rem);
            font-weight: 700;
            line-height: 1.0;
            letter-spacing: -2px;
            margin-bottom: 24px;
        }
        .hero-title .line { display: block; }
        .hero-title .accent {
            background: linear-gradient(120deg, #818cf8 0%, #a78bfa 40%, #e040fb 80%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shimmer 4s linear infinite;
        }
        .hero-title em {
            font-family: 'Instrument Serif', serif;
            font-style: italic;
            -webkit-text-fill-color: transparent;
            background: inherit;
            -webkit-background-clip: text;
        }

        .hero-sub {
            font-size: 1.1rem;
            color: var(--muted);
            line-height: 1.75;
            max-width: 480px;
            margin-bottom: 40px;
        }

        .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 56px; }
        .btn-hero-primary {
            padding: 15px 36px; border-radius: 12px;
            font-size: 0.95rem; font-weight: 700;
            background: linear-gradient(135deg, #5b52ff, #8b5cf6);
            color: #fff; text-decoration: none; border: none;
            box-shadow: 0 0 40px rgba(91,82,255,0.45), inset 0 1px 0 rgba(255,255,255,0.18);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        .btn-hero-primary::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .btn-hero-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 50px rgba(91,82,255,0.6); color: #fff; }
        .btn-hero-primary:hover::before { opacity: 1; }
        .btn-hero-ghost {
            padding: 15px 32px; border-radius: 12px;
            font-size: 0.95rem; font-weight: 600;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--text); text-decoration: none;
            backdrop-filter: blur(10px);
            transition: all 0.25s;
        }
        .btn-hero-ghost:hover { background: rgba(255,255,255,0.09); color: var(--text); border-color: rgba(255,255,255,0.18); }

        .trust-row {
            display: flex;
            align-items: center;
            gap: 22px;
            flex-wrap: wrap;
        }
        .trust-avatars { display: flex; }
        .trust-avatars img {
            width: 34px; height: 34px; border-radius: 50%;
            border: 2px solid var(--bg);
            margin-left: -9px; object-fit: cover;
        }
        .trust-avatars img:first-child { margin-left: 0; }
        .trust-info { font-size: 0.84rem; color: var(--muted); line-height: 1.4; }
        .trust-info strong { color: var(--text); }
        .trust-sep { width: 1px; height: 28px; background: var(--border); }
        .trust-num strong { display: block; font-family: 'Clash Display', sans-serif; font-size: 1.2rem; color: var(--text); }
        .trust-num span { font-size: 0.78rem; color: var(--muted); }

        /* ─────────────────── 3D SCENE ─────────────────── */
        .hero-3d-scene {
            perspective: 1000px;
            position: relative;
            height: 480px;
        }
        .scene-inner {
            position: relative;
            width: 100%;
            height: 100%;
            transform-style: preserve-3d;
        }

        .orb-center {
            position: absolute;
            top: 50%; left: 50%;
            width: 180px; height: 180px;
            transform: translate(-50%, -50%);
            border-radius: 50%;
            background: radial-gradient(circle at 35% 35%,
                rgba(139,92,246,0.9),
                rgba(91,82,255,0.7) 40%,
                rgba(6,182,212,0.3) 70%,
                transparent);
            box-shadow:
                0 0 60px rgba(91,82,255,0.6),
                0 0 120px rgba(139,92,246,0.3),
                inset 0 0 60px rgba(255,255,255,0.08);
            animation: floatY 5s ease-in-out infinite, glowPulse 4s ease-in-out infinite;
        }
        .orb-center::before {
            content: '';
            position: absolute;
            inset: 12px;
            border-radius: 50%;
            border: 1px solid rgba(255,255,255,0.25);
            background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.15), transparent 50%);
        }
        .orb-center::after {
            content: '';
            position: absolute;
            top: 15%; left: 20%;
            width: 30%; height: 15%;
            background: rgba(255,255,255,0.35);
            border-radius: 50%;
            filter: blur(8px);
            transform: rotate(-20deg);
        }

        .orb-ring {
            position: absolute;
            top: 50%; left: 50%;
            width: 260px; height: 260px;
            transform: translate(-50%, -50%) rotateX(70deg);
            border-radius: 50%;
            border: 1.5px solid rgba(91,82,255,0.5);
            box-shadow: 0 0 20px rgba(91,82,255,0.3);
            animation: spin3d 12s linear infinite;
        }
        .orb-ring-2 {
            position: absolute;
            top: 50%; left: 50%;
            width: 320px; height: 320px;
            transform: translate(-50%, -50%) rotateX(70deg) rotateZ(45deg);
            border-radius: 50%;
            border: 1px solid rgba(224,64,251,0.25);
            animation: spin3d 18s linear infinite reverse;
        }

        .skill-card-3d {
            position: absolute;
            background: rgba(13,13,30,0.9);
            border: 1px solid rgba(91,82,255,0.3);
            border-radius: 16px;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            backdrop-filter: blur(20px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(91,82,255,0.15);
            transition: transform 0.3s, box-shadow 0.3s;
            cursor: default;
        }
        .skill-card-3d:hover {
            box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(91,82,255,0.4), 0 0 40px rgba(91,82,255,0.2);
            transform: scale(1.04) !important;
        }
        .skill-card-3d .icon {
            width: 40px; height: 40px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem; flex-shrink: 0;
        }
        .skill-card-3d .info h4 { font-size: 0.84rem; font-weight: 700; color: var(--text); margin-bottom: 2px; }
        .skill-card-3d .info p { font-size: 0.72rem; color: var(--muted); }
        .skill-badge {
            font-size: 0.68rem; font-weight: 700;
            padding: 3px 9px; border-radius: 100px;
            white-space: nowrap; margin-left: auto;
        }
        .badge-green { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.2); }
        .badge-blue  { background: rgba(91,82,255,0.15);  color: #818cf8; border: 1px solid rgba(91,82,255,0.2); }
        .badge-amber { background: rgba(245,196,66,0.12); color: #fbbf24; border: 1px solid rgba(245,196,66,0.2); }

        .card-tl { top: 10%;  left: -5%;  width: 230px; animation: cardFloat1 7s ease-in-out infinite; }
        .card-tr { top: 5%;   right: 0%;  width: 220px; animation: cardFloat2 8s ease-in-out infinite 1s; }
        .card-bl { bottom: 15%; left: -2%; width: 210px; animation: cardFloat3 6.5s ease-in-out infinite 0.5s; }
        .card-br { bottom: 10%; right: 2%; width: 220px; animation: cardFloat1 7.5s ease-in-out infinite 2s; }

        /* ─────────────────── SKILLS BAR ─────────────────── */
        .skills-bar {
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            background: rgba(255,255,255,0.015);
            padding: 22px 0;
            overflow: hidden;
        }
        .skills-track {
            display: flex;
            gap: 16px;
            animation: scrollTrack 30s linear infinite;
            width: max-content;
        }
        @keyframes scrollTrack {
            from { transform: translateX(0); }
            to   { transform: translateX(-50%); }
        }
        .skill-chip {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--card);
            border: 1px solid var(--border);
            padding: 7px 16px;
            border-radius: 100px;
            font-size: 0.82rem;
            font-weight: 500;
            color: var(--muted);
            white-space: nowrap;
            transition: all 0.25s;
        }
        .skill-chip:hover { border-color: var(--border-glow); color: var(--text); }

        /* ─────────────────── SECTIONS ─────────────────── */
        section { position: relative; z-index: 1; }

        .section-header {
            text-align: center;
            margin-bottom: 64px;
        }
        .eyebrow {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: #818cf8;
            margin-bottom: 14px;
        }
        .section-title {
            font-family: 'Clash Display', sans-serif;
            font-size: clamp(1.9rem, 3vw, 2.8rem);
            font-weight: 700;
            letter-spacing: -1px;
            line-height: 1.1;
            margin-bottom: 16px;
        }
        .section-sub {
            font-size: 1rem;
            color: var(--muted);
            max-width: 520px;
            margin: 0 auto;
            line-height: 1.75;
        }

        /* ─────────────────── FEATURES ─────────────────── */
        .features { padding: 110px 5%; }
        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            max-width: 1100px;
            margin: 0 auto;
        }
        @media (max-width: 900px) { .features-grid { grid-template-columns: 1fr 1fr; } }
        @media (max-width: 600px) { .features-grid { grid-template-columns: 1fr; } }

        .feat-card {
            background: var(--bg-2);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 32px 26px;
            transition: all 0.35s cubic-bezier(.4,0,.2,1);
            position: relative;
            overflow: hidden;
            transform-style: preserve-3d;
        }
        .feat-card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(91,82,255,0.08), transparent 60%);
            opacity: 0;
            transition: opacity 0.35s;
            border-radius: 24px;
        }
        .feat-card:hover {
            border-color: rgba(91,82,255,0.35);
            transform: translateY(-6px) rotateX(2deg);
            box-shadow: 0 30px 70px rgba(0,0,0,0.5), 0 0 0 1px rgba(91,82,255,0.2);
        }
        .feat-card:hover::after { opacity: 1; }

        .feat-card-top {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(91,82,255,0.6), transparent);
            opacity: 0;
            transition: opacity 0.35s;
        }
        .feat-card:hover .feat-card-top { opacity: 1; }

        .feat-icon {
            width: 52px; height: 52px;
            background: linear-gradient(135deg, rgba(91,82,255,0.2), rgba(139,92,246,0.12));
            border: 1px solid rgba(91,82,255,0.22);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 22px;
            font-size: 1.35rem;
        }
        .feat-icon i {
            background: linear-gradient(135deg, #818cf8, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .feat-card h3 {
            font-family: 'Clash Display', sans-serif;
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 10px;
        }
        .feat-card p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }

        /* ─────────────────── HOW IT WORKS ─────────────────── */
        .hiw { padding: 110px 5%; background: linear-gradient(180deg, transparent 0%, rgba(91,82,255,0.04) 50%, transparent 100%); }
        .hiw-steps {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
            max-width: 900px;
            margin: 0 auto;
            position: relative;
        }
        @media (max-width: 700px) { .hiw-steps { grid-template-columns: 1fr; } }
        .hiw-steps::before {
            content: '';
            position: absolute;
            top: 36px;
            left: calc(16.6% + 36px);
            right: calc(16.6% + 36px);
            height: 1px;
            background: linear-gradient(90deg, rgba(91,82,255,0.5), rgba(224,64,251,0.5));
        }
        @media (max-width: 700px) { .hiw-steps::before { display: none; } }

        .hiw-step { text-align: center; }
        .step-num {
            width: 72px; height: 72px;
            background: linear-gradient(135deg, #5b52ff, #8b5cf6);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px;
            font-family: 'Clash Display', sans-serif;
            font-size: 1.6rem; font-weight: 700; color: #fff;
            box-shadow: 0 0 40px rgba(91,82,255,0.45);
            position: relative; z-index: 1;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .hiw-step:hover .step-num {
            transform: scale(1.1);
            box-shadow: 0 0 60px rgba(91,82,255,0.65);
        }
        .hiw-step h3 {
            font-family: 'Clash Display', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 10px;
            color: var(--text);
        }
        .hiw-step p { font-size: 0.86rem; color: var(--muted); line-height: 1.7; max-width: 220px; margin: 0 auto; }

        /* ─────────────────── STATS ─────────────────── */
        .stats {
            padding: 80px 5%;
            background: var(--bg-2);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }
        .stats::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 80% 200% at 50% 50%, rgba(91,82,255,0.07), transparent);
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            max-width: 800px;
            margin: 0 auto;
            position: relative; z-index: 1;
        }
        @media (max-width: 600px) { .stats-grid { grid-template-columns: 1fr 1fr; } }
        .stat-item { text-align: center; padding: 24px; }
        .stat-num {
            font-family: 'Clash Display', sans-serif;
            font-size: 3.2rem; font-weight: 700;
            letter-spacing: -2px;
            background: linear-gradient(135deg, #818cf8, #e040fb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1;
            margin-bottom: 8px;
        }
        .stat-lbl { font-size: 0.9rem; color: var(--muted); font-weight: 500; }

        /* ─────────────────── ABOUT ─────────────────── */
        .about {
            padding: 110px 5%;
            background: var(--bg-2);
            border-top: 1px solid var(--border);
        }
        .team-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            max-width: 860px;
            margin: 0 auto;
        }
        @media (max-width: 700px) { .team-grid { grid-template-columns: 1fr; } }

        .team-card {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 24px;
            overflow: hidden;
            transition: all 0.35s cubic-bezier(.4,0,.2,1);
            position: relative;
        }
        .team-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(91,82,255,0.5), rgba(224,64,251,0.5), transparent);
            opacity: 0;
            transition: opacity 0.35s;
        }
        .team-card:hover {
            border-color: rgba(91,82,255,0.35);
            transform: translateY(-8px) rotateX(2deg);
            box-shadow: 0 32px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(91,82,255,0.2);
        }
        .team-card:hover::before { opacity: 1; }

        .team-head {
            display: flex;
            align-items: center;
            gap: 18px;
            padding: 24px 24px 12px;
        }
        .team-photo {
            width: 88px; height: 88px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
            border: 2px solid rgba(91,82,255,0.3);
            box-shadow: 0 0 30px rgba(91,82,255,0.25);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .team-card:hover .team-photo {
            transform: scale(1.06);
            box-shadow: 0 0 50px rgba(91,82,255,0.45);
        }
        .team-name {
            font-family: 'Clash Display', sans-serif;
            font-size: 1.25rem;
            font-weight: 700;
            letter-spacing: -0.3px;
            color: var(--text);
            margin-bottom: 10px;
        }
        .roles { display: flex; flex-wrap: wrap; gap: 7px; }
        .role {
            font-size: 0.72rem;
            font-weight: 700;
            padding: 4px 11px;
            border-radius: 100px;
        }
        .role-founder { background: rgba(91,82,255,0.14); color: #818cf8; border: 1px solid rgba(91,82,255,0.24); }
        .role-dev     { background: rgba(6,182,212,0.1);  color: #22d3ee; border: 1px solid rgba(6,182,212,0.18); }
        .role-backend { background: rgba(16,185,129,0.1); color: #34d399; border: 1px solid rgba(16,185,129,0.18); }
        .role-cofounder { background: rgba(139,92,246,0.14); color: #a78bfa; border: 1px solid rgba(139,92,246,0.24); }

        .team-body { padding: 8px 24px 24px; }
        .team-meta {
            display: flex;
            align-items: flex-start;
            gap: 9px;
            font-size: 0.83rem;
            color: var(--muted);
            line-height: 1.55;
            margin-bottom: 8px;
        }
        .team-meta i { color: #818cf8; flex-shrink: 0; margin-top: 2px; }

        /* ─────────────────── CTA ─────────────────── */
        .cta {
            padding: 130px 5%;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .cta-bg-img {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1531482615713-2afd69097998?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            filter: brightness(0.08) saturate(0.4);
        }
        .cta-overlay {
            position: absolute; inset: 0;
            background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(91,82,255,0.22), transparent),
                        linear-gradient(to bottom, rgba(6,6,15,0.5), rgba(6,6,15,0.5));
        }
        .cta-content { position: relative; z-index: 2; }
        .cta h2 {
            font-family: 'Clash Display', sans-serif;
            font-size: clamp(2.2rem, 4vw, 3.5rem);
            font-weight: 700;
            letter-spacing: -1.5px;
            line-height: 1.1;
            margin-bottom: 18px;
        }
        .cta p { font-size: 1.05rem; color: var(--muted); max-width: 440px; margin: 0 auto 40px; line-height: 1.7; }

        /* ─────────────────── FOOTER ─────────────────── */
        .footer {
            background: var(--bg-2);
            border-top: 1px solid var(--border);
            padding: 64px 5% 28px;
        }
        .footer-inner {
            max-width: 1100px;
            margin: 0 auto;
        }
        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 48px;
        }
        @media (max-width: 800px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
        @media (max-width: 500px) { .footer-grid { grid-template-columns: 1fr; } }

        .footer-brand {
            font-family: 'Clash Display', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(120deg, #818cf8, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 12px;
        }
        .footer-desc { font-size: 0.87rem; color: var(--muted); line-height: 1.7; max-width: 240px; margin-bottom: 20px; }
        .socials { display: flex; gap: 8px; }
        .socials a {
            width: 36px; height: 36px;
            border: 1px solid var(--border);
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            color: var(--muted); text-decoration: none;
            font-size: 0.95rem;
            transition: all 0.22s;
        }
        .socials a:hover { background: rgba(91,82,255,0.12); border-color: rgba(91,82,255,0.3); color: #818cf8; }
        .footer-col h5 {
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 16px;
        }
        .footer-col ul { list-style: none; }
        .footer-col ul li { margin-bottom: 10px; }
        .footer-col ul a {
            font-size: 0.87rem;
            color: #555575;
            text-decoration: none;
            transition: color 0.2s;
        }
        .footer-col ul a:hover { color: var(--text); }
        .footer-bottom {
            border-top: 1px solid var(--border);
            padding-top: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            font-size: 0.82rem;
            color: var(--muted);
        }

        /* ─────────────────── SCROLL ANIMATIONS ─────────────────── */
        .fade-up {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* ─────────────────── CURSOR GLOW ─────────────────── */
        .cursor-glow {
            position: fixed;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(91,82,255,0.08), transparent 70%);
            pointer-events: none;
            z-index: 0;
            transform: translate(-50%, -50%);
            transition: transform 0.15s ease-out;
        }
    </style>
</head>
<body>

<!-- ── CURSOR GLOW ── -->
<div class="cursor-glow" id="cursorGlow"></div>

<!-- ══════════════════════════════════════
     BRAIN CLASH LOADER
══════════════════════════════════════ -->
<div id="loader">
    <div class="loader-orbs">
        <div class="loader-orb loader-orb-1"></div>
        <div class="loader-orb loader-orb-2"></div>
    </div>

    <!-- spark canvas fills entire loader -->
    <canvas id="sparkCanvas"></canvas>

    <!-- clash arena -->
    <div class="clash-arena">

        <!-- shockwave rings -->
        <div class="shockwave"></div>
        <div class="shockwave"></div>
        <div class="shockwave"></div>

        <!-- lightning burst SVG -->
        <svg class="lightning" width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- main bolt -->
            <polyline points="100,10 85,90 100,85 80,190" stroke="url(#lgGrad)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" opacity="0.95"/>
            <!-- side rays -->
            <line x1="100" y1="100" x2="30" y2="60"  stroke="#a78bfa" stroke-width="1.5" opacity="0.7"/>
            <line x1="100" y1="100" x2="170" y2="55" stroke="#e040fb" stroke-width="1.5" opacity="0.7"/>
            <line x1="100" y1="110" x2="20" y2="130" stroke="#818cf8" stroke-width="1"   opacity="0.5"/>
            <line x1="100" y1="110" x2="180" y2="140" stroke="#e040fb" stroke-width="1" opacity="0.5"/>
            <line x1="100" y1="90"  x2="55" y2="30"  stroke="#a78bfa" stroke-width="1"  opacity="0.4"/>
            <line x1="100" y1="90"  x2="148" y2="28" stroke="#818cf8" stroke-width="1"  opacity="0.4"/>
            <!-- impact glow circle -->
            <circle cx="100" cy="100" r="16" fill="url(#circGrad)" opacity="0.85"/>
            <circle cx="100" cy="100" r="8"  fill="white" opacity="0.6"/>
            <defs>
                <linearGradient id="lgGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%"   stop-color="#818cf8"/>
                    <stop offset="100%" stop-color="#e040fb"/>
                </linearGradient>
                <radialGradient id="circGrad" cx="50%" cy="50%" r="50%">
                    <stop offset="0%"   stop-color="#ffffff"/>
                    <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0"/>
                </radialGradient>
            </defs>
        </svg>

        <!-- LEFT BRAIN -->
        <div class="brain brain-left">
            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <radialGradient id="brainGradL" cx="40%" cy="35%" r="65%">
                        <stop offset="0%"   stop-color="#a78bfa"/>
                        <stop offset="55%"  stop-color="#5b52ff"/>
                        <stop offset="100%" stop-color="#312e81"/>
                    </radialGradient>
                    <filter id="glowL">
                        <feGaussianBlur stdDeviation="3" result="blur"/>
                        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                    </filter>
                </defs>
                <g filter="url(#glowL)">
                    <!-- brain body left hemisphere -->
                    <path d="M60,20 C42,18 28,25 22,38 C16,50 18,64 24,74 C28,82 36,88 44,90 C50,92 56,91 60,90"
                          fill="url(#brainGradL)" stroke="#818cf8" stroke-width="1.5" opacity="0.95"/>
                    <!-- right hemisphere -->
                    <path d="M60,20 C78,18 92,25 98,38 C104,50 102,64 96,74 C92,82 84,88 76,90 C70,92 64,91 60,90"
                          fill="url(#brainGradL)" stroke="#818cf8" stroke-width="1.5" opacity="0.85"/>
                    <!-- stem/base -->
                    <path d="M50,90 C50,98 54,104 60,105 C66,104 70,98 70,90" fill="#3730a3" stroke="#818cf8" stroke-width="1"/>
                    <!-- center groove -->
                    <line x1="60" y1="20" x2="60" y2="90" stroke="rgba(129,140,248,0.4)" stroke-width="1.5" stroke-dasharray="3,4"/>
                    <!-- folds left -->
                    <path d="M30,42 Q22,50 26,60" fill="none" stroke="rgba(167,139,250,0.6)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M28,55 Q20,64 26,74" fill="none" stroke="rgba(167,139,250,0.5)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M36,30 Q28,38 34,46" fill="none" stroke="rgba(167,139,250,0.5)" stroke-width="1.2" stroke-linecap="round"/>
                    <path d="M46,24 Q38,28 38,36" fill="none" stroke="rgba(167,139,250,0.4)" stroke-width="1.2" stroke-linecap="round"/>
                    <!-- folds right -->
                    <path d="M90,42 Q98,50 94,60" fill="none" stroke="rgba(167,139,250,0.5)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M92,55 Q100,64 94,74" fill="none" stroke="rgba(167,139,250,0.45)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M82,30 Q90,38 86,46"  fill="none" stroke="rgba(167,139,250,0.4)" stroke-width="1.2" stroke-linecap="round"/>
                    <!-- top folds -->
                    <path d="M45,20 Q50,14 60,13 Q70,14 75,20" fill="none" stroke="rgba(167,139,250,0.5)" stroke-width="1.5" stroke-linecap="round"/>
                    <!-- glow dot highlight -->
                    <circle cx="42" cy="36" r="5" fill="rgba(255,255,255,0.18)"/>
                </g>
            </svg>
            <span class="brain-label">Your Skills</span>
        </div>

        <!-- CENTER elements -->
        <div class="clash-center">
            <div class="vs-badge">VS</div>
        </div>

        <!-- RIGHT BRAIN -->
        <div class="brain brain-right">
            <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <radialGradient id="brainGradR" cx="60%" cy="35%" r="65%">
                        <stop offset="0%"   stop-color="#f0abfc"/>
                        <stop offset="55%"  stop-color="#e040fb"/>
                        <stop offset="100%" stop-color="#86198f"/>
                    </radialGradient>
                    <filter id="glowR">
                        <feGaussianBlur stdDeviation="3" result="blur"/>
                        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                    </filter>
                </defs>
                <g filter="url(#glowR)">
                    <path d="M60,20 C42,18 28,25 22,38 C16,50 18,64 24,74 C28,82 36,88 44,90 C50,92 56,91 60,90"
                          fill="url(#brainGradR)" stroke="#e040fb" stroke-width="1.5" opacity="0.85"/>
                    <path d="M60,20 C78,18 92,25 98,38 C104,50 102,64 96,74 C92,82 84,88 76,90 C70,92 64,91 60,90"
                          fill="url(#brainGradR)" stroke="#e040fb" stroke-width="1.5" opacity="0.95"/>
                    <path d="M50,90 C50,98 54,104 60,105 C66,104 70,98 70,90" fill="#701a75" stroke="#e040fb" stroke-width="1"/>
                    <line x1="60" y1="20" x2="60" y2="90" stroke="rgba(240,171,252,0.4)" stroke-width="1.5" stroke-dasharray="3,4"/>
                    <path d="M30,42 Q22,50 26,60" fill="none" stroke="rgba(240,171,252,0.5)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M28,55 Q20,64 26,74" fill="none" stroke="rgba(240,171,252,0.45)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M36,30 Q28,38 34,46" fill="none" stroke="rgba(240,171,252,0.4)" stroke-width="1.2" stroke-linecap="round"/>
                    <path d="M46,24 Q38,28 38,36" fill="none" stroke="rgba(240,171,252,0.35)" stroke-width="1.2" stroke-linecap="round"/>
                    <path d="M90,42 Q98,50 94,60" fill="none" stroke="rgba(240,171,252,0.6)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M92,55 Q100,64 94,74" fill="none" stroke="rgba(240,171,252,0.5)" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M82,30 Q90,38 86,46"  fill="none" stroke="rgba(240,171,252,0.4)" stroke-width="1.2" stroke-linecap="round"/>
                    <path d="M45,20 Q50,14 60,13 Q70,14 75,20" fill="none" stroke="rgba(240,171,252,0.5)" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="78" cy="36" r="5" fill="rgba(255,255,255,0.18)"/>
                </g>
            </svg>
            <span class="brain-label">Their Skills</span>
        </div>
    </div>

    <!-- branding + progress -->
    <div class="loader-bottom">
