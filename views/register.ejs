<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - BarterBrain</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --indigo: #4f46e5;
            --violet: #7c3aed;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #0a0812;
            color: white;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ── Scene ── */
        .scene {
            position: fixed; inset: 0; z-index: 0;
            background:
                radial-gradient(ellipse 70% 55% at 15% 30%, #1e1060 0%, transparent 60%),
                radial-gradient(ellipse 55% 50% at 85% 75%, #220850 0%, transparent 55%),
                linear-gradient(150deg, #080612 0%, #0c0a22 60%, #080612 100%);
        }
        .orb {
            position: absolute; border-radius: 50%;
            filter: blur(80px); opacity: 0.45;
            animation: orb-drift linear infinite;
        }
        .orb-a { width: 550px; height: 550px; background: radial-gradient(circle, #4f46e5, transparent 65%); top: -150px; left: -120px; animation-duration: 20s; }
        .orb-b { width: 400px; height: 400px; background: radial-gradient(circle, #7c3aed, transparent 65%); bottom: 10%; right: -80px; animation-duration: 26s; animation-delay: -8s; }
        .orb-c { width: 280px; height: 280px; background: radial-gradient(circle, #a855f7, transparent 65%); top: 55%; left: 45%; animation-duration: 32s; animation-delay: -14s; }

        @keyframes orb-drift {
            0%   { transform: translate(0,0) scale(1); }
            33%  { transform: translate(25px,-35px) scale(1.04); }
            66%  { transform: translate(-20px,25px) scale(0.96); }
            100% { transform: translate(0,0) scale(1); }
        }

        .grid-lines {
            position: absolute; inset: 0;
            background-image:
                linear-gradient(rgba(79,70,229,0.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(79,70,229,0.06) 1px, transparent 1px);
            background-size: 55px 55px;
            mask-image: radial-gradient(ellipse 65% 65% at 50% 50%, black 15%, transparent 75%);
        }
        .stars { position: absolute; inset: 0; }
        .star {
            position: absolute; border-radius: 50%; background: white;
            animation: twinkle ease-in-out infinite;
        }
        @keyframes twinkle {
            0%,100% { opacity: 0.08; } 50% { opacity: 0.85; }
        }

        /* ── Layout ── */
        .page-wrap {
            position: relative; z-index: 1;
            max-width: 1320px; margin: 0 auto;
            padding: 0 40px;
            min-height: 100vh;
            display: flex; flex-direction: column;
        }

        /* ── Nav ── */
        nav {
            display: flex; align-items: center; justify-content: space-between;
            padding: 28px 0;
        }
        .brand {
            font-family: 'Sora', sans-serif;
            font-size: 1.75rem; font-weight: 800; letter-spacing: -0.5px;
            text-decoration: none;
            background: linear-gradient(135deg, #a78bfa, #818cf8, #60a5fa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .nav-links { display: flex; gap: 28px; align-items: center; }
        .nav-links a { color: rgba(255,255,255,0.6); text-decoration: none; font-weight: 500; font-size: 0.95rem; transition: color 0.2s; }
        .nav-links a:hover { color: white; }
        .nav-pill {
            background: rgba(79,70,229,0.2);
            border: 1px solid rgba(129,140,248,0.4);
            color: #a78bfa !important; padding: 8px 22px; border-radius: 40px;
            backdrop-filter: blur(8px); transition: all 0.25s !important;
        }
        .nav-pill:hover { background: rgba(79,70,229,0.4) !important; border-color: rgba(129,140,248,0.7) !important; color: white !important; }

        /* ── Main ── */
        main {
            flex: 1;
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 72px; align-items: start;
            padding: 40px 0 80px;
        }

        /* ── Hero ── */
        .hero { position: sticky; top: 100px; padding-right: 16px; }

        .badge-pill {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(79,70,229,0.15);
            border: 1px solid rgba(129,140,248,0.3);
            color: #a78bfa; font-size: 0.78rem; font-weight: 700;
            letter-spacing: 0.08em; text-transform: uppercase;
            padding: 7px 16px; border-radius: 40px; margin-bottom: 28px;
            backdrop-filter: blur(6px);
        }
        .badge-dot { width: 6px; height: 6px; background: #a78bfa; border-radius: 50%; box-shadow: 0 0 8px #a78bfa; animation: pulse-dot 2s ease-in-out infinite; }
        @keyframes pulse-dot { 0%,100%{box-shadow:0 0 4px #a78bfa;} 50%{box-shadow:0 0 14px #a78bfa,0 0 28px rgba(167,139,250,0.5);} }

        .hero-title {
            font-family: 'Sora', sans-serif;
            font-size: clamp(2.4rem, 3.2vw, 3.6rem);
            font-weight: 800; line-height: 1.15; letter-spacing: -1.5px;
            margin-bottom: 22px;
        }
        .hero-title .g { background: linear-gradient(135deg, #fbbf24, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

        .hero-desc {
            font-size: 1.05rem; line-height: 1.75;
            color: rgba(255,255,255,0.5); margin-bottom: 40px; max-width: 420px;
        }

        /* Benefit grid */
        .benefits {
            display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 40px;
        }
        .benefit-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 18px; padding: 20px;
            transition: all 0.25s; cursor: default;
        }
        .benefit-card:hover {
            background: rgba(79,70,229,0.1);
            border-color: rgba(129,140,248,0.25);
            transform: translateY(-2px);
        }
        .b-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, rgba(79,70,229,0.35), rgba(124,58,237,0.25));
            border: 1px solid rgba(129,140,248,0.25);
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            margin-bottom: 12px; font-size: 1rem; color: #a78bfa;
        }
        .benefit-card h4 { font-family: 'Sora', sans-serif; font-size: 0.92rem; font-weight: 700; margin-bottom: 5px; }
        .benefit-card p { font-size: 0.8rem; color: rgba(255,255,255,0.45); line-height: 1.5; margin: 0; }

        /* Stats */
        .stats-row {
            display: flex; gap: 0;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 18px; overflow: hidden;
        }
        .stat { flex: 1; padding: 20px 16px; text-align: center; border-right: 1px solid rgba(255,255,255,0.07); transition: background 0.2s; }
        .stat:last-child { border-right: none; }
        .stat:hover { background: rgba(79,70,229,0.1); }
        .stat-num {
            font-family: 'Sora', sans-serif; font-size: 1.7rem; font-weight: 800;
            background: linear-gradient(135deg, #818cf8, #a78bfa);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .stat-lbl { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 4px; }

        /* ── Register card ── */
        .card-3d { perspective: 1400px; }
        .reg-card {
            background: rgba(12, 10, 28, 0.8);
            backdrop-filter: blur(40px) saturate(180%);
            -webkit-backdrop-filter: blur(40px) saturate(180%);
            border: 1px solid rgba(129,140,248,0.18);
            border-radius: 32px; padding: 48px 44px;
            position: relative; overflow: hidden;
            box-shadow: 0 0 0 1px rgba(255,255,255,0.04) inset, 0 40px 80px rgba(0,0,0,0.55), 0 0 80px rgba(79,70,229,0.12);
            transform-style: preserve-3d; transition: transform 0.12s ease-out;
        }
        .card-shimmer { position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(167,139,250,0.75) 40%, rgba(129,140,248,0.75) 60%, transparent); }
        .card-glow { position: absolute; top: -50px; left: 50%; transform: translateX(-50%); width: 280px; height: 130px; background: radial-gradient(ellipse, rgba(79,70,229,0.22), transparent 70%); pointer-events: none; }

        .card-title { font-family: 'Sora', sans-serif; font-size: 1.9rem; font-weight: 700; letter-spacing: -0.4px; margin-bottom: 5px; }
        .card-sub { font-size: 0.93rem; color: rgba(255,255,255,0.4); margin-bottom: 30px; }

        /* Alert */
        .error-box { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; padding: 13px 16px; border-radius: 13px; font-size: 0.88rem; margin-bottom: 22px; display: flex; align-items: center; gap: 9px; }
        .success-box { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: #86efac; padding: 13px 16px; border-radius: 13px; font-size: 0.88rem; margin-bottom: 22px; display: flex; align-items: center; gap: 9px; }

        /* Grid */
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .full { grid-column: span 2; }

        .field { margin-bottom: 0; }
        .field label { display: block; font-size: 0.76rem; font-weight: 700; letter-spacing: 0.05em; color: rgba(255,255,255,0.45); text-transform: uppercase; margin-bottom: 8px; }
        .input-wrap { position: relative; }
        .input-icon { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.22); font-size: 0.95rem; pointer-events: none; transition: color 0.2s; }
        .input-wrap:focus-within .input-icon { color: #818cf8; }

        input[type="email"],
        input[type="password"],
        input[type="text"],
        input[type="tel"] {
            width: 100%;
            background: rgba(255,255,255,0.055);
            border: 1px solid rgba(255,255,255,0.09);
            border-radius: 13px; color: white;
            font-family: 'DM Sans', sans-serif; font-size: 0.93rem;
            padding: 14px 14px 14px 44px;
            outline: none; transition: all 0.25s;
            caret-color: #818cf8;
        }
        input::placeholder { color: rgba(255,255,255,0.18); }
        input:focus { background: rgba(79,70,229,0.1); border-color: rgba(129,140,248,0.55); box-shadow: 0 0 0 3px rgba(79,70,229,0.12), 0 0 16px rgba(79,70,229,0.08); }

        .field-hint { font-size: 0.72rem; color: rgba(255,255,255,0.3); margin-top: 5px; display: flex; align-items: center; gap: 5px; }
        .field-hint i { color: #818cf8; }

        /* Username feedback */
        #username-feedback { font-size: 0.73rem; margin-top: 5px; }

        /* Strength */
        .strength-track { height: 3px; background: rgba(255,255,255,0.08); border-radius: 4px; margin-top: 8px; overflow: hidden; }
        .strength-fill { height: 100%; border-radius: 4px; width: 0; transition: all 0.35s; }
        .sw { width:25%; background:#ef4444; }
        .sf { width:50%; background:#f59e0b; }
        .sg { width:75%; background:#10b981; }
        .ss { width:100%; background:#22c55e; }

        /* Match */
        #passwordMatch { font-size: 0.73rem; margin-top: 5px; }
        .ok { color: #6ee7b7; } .no { color: #fca5a5; }

        /* Req pills */
        .req-pills { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
        .req-pill { font-size: 0.67rem; color: rgba(255,255,255,0.35); background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); padding: 4px 11px; border-radius: 100px; transition: all 0.2s; }
        .req-pill.valid { color: #6ee7b7; background: rgba(110,231,183,0.1); border-color: rgba(110,231,183,0.25); }

        /* Checkbox */
        .check-row { display: flex; align-items: flex-start; gap: 10px; margin: 22px 0; }
        .check-row input[type="checkbox"] { width: 17px; height: 17px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.18); border-radius: 5px; padding: 0; cursor: pointer; margin-top: 2px; accent-color: #4f46e5; flex-shrink: 0; }
        .check-row label { font-size: 0.84rem; color: rgba(255,255,255,0.45); cursor: pointer; line-height: 1.55; }
        .check-row label a { color: #818cf8; text-decoration: none; font-weight: 600; }
        .check-row label a:hover { color: #a78bfa; }

        /* Submit */
        .btn-submit {
            width: 100%; position: relative;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white; font-family: 'Sora', sans-serif;
            font-size: 0.97rem; font-weight: 700;
            padding: 16px; border-radius: 14px; border: none;
            cursor: pointer; overflow: hidden; transition: all 0.3s;
            box-shadow: 0 8px 28px rgba(79,70,229,0.38), 0 0 0 1px rgba(255,255,255,0.08) inset;
            display: flex; align-items: center; justify-content: center; gap: 9px;
            margin-top: 6px;
        }
        .btn-submit::before {
            content: ''; position: absolute;
            top: 0; left: -100%; width: 200%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            transition: left 0.5s;
        }
        .btn-submit:hover::before { left: 100%; }
        .btn-submit:hover { transform: translateY(-3px); box-shadow: 0 16px 38px rgba(79,70,229,0.48), 0 0 0 1px rgba(255,255,255,0.12) inset; }

        /* Footer */
        .card-footer-link { text-align: center; font-size: 0.88rem; color: rgba(255,255,255,0.38); margin-top: 20px; }
        .card-footer-link a { color: #818cf8; font-weight: 700; text-decoration: none; }
        .card-footer-link a:hover { color: #a78bfa; }
        .terms { font-size: 0.73rem; color: rgba(255,255,255,0.22); text-align: center; margin-top: 13px; line-height: 1.6; }
        .terms a { color: #818cf8; text-decoration: none; }

        /* Responsive */
        @media (max-width: 1024px) {
            main { grid-template-columns: 1fr; gap: 44px; }
            .hero { position: static; padding-right: 0; text-align: center; }
            .hero-desc { margin: 0 auto 40px; }
            .benefits { grid-template-columns: 1fr 1fr; }
        }
        @media (max-width: 640px) {
            .page-wrap { padding: 0 18px; }
            .nav-links { display: none; }
            .form-grid { grid-template-columns: 1fr; }
            .full { grid-column: span 1; }
            .reg-card { padding: 32px 20px; }
            .benefits { grid-template-columns: 1fr; }
            .hero-title { font-size: 2.2rem; }
        }
    </style>
</head>
<body>

<div class="scene">
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>
    <div class="orb orb-c"></div>
    <div class="grid-lines"></div>
    <div class="stars" id="stars"></div>
</div>

<div class="page-wrap">
    <nav>
        <a href="/" class="brand">BarterBrain</a>
        <div class="nav-links">
            <a href="/features">Features</a>
            <a href="/how-it-works">How it works</a>
            <a href="/community">Community</a>
            <a href="/login" class="nav-pill">Sign in</a>
        </div>
    </nav>

    <main>
        <!-- Hero -->
        <div class="hero">
            <div class="badge-pill">
                <span class="badge-dot"></span>
                Join 50,000+ learners
            </div>
            <h1 class="hero-title">
                Start your<br>
                <span class="g">learning journey</span>
            </h1>
            <p class="hero-desc">
                Create your free account and start exchanging skills with experts worldwide. No credit card required, ever.
            </p>

            <div class="benefits">
                <div class="benefit-card">
                    <div class="b-icon"><i class="bi bi-infinity"></i></div>
                    <h4>Learn Anything</h4>
                    <p>From coding to cooking, there's always something new to explore.</p>
                </div>
                <div class="benefit-card">
                    <div class="b-icon"><i class="bi bi-people-fill"></i></div>
                    <h4>Teach Others</h4>
                    <p>Share your expertise and build a reputation that opens doors.</p>
                </div>
                <div class="benefit-card">
                    <div class="b-icon"><i class="bi bi-star-fill"></i></div>
                    <h4>Build Reputation</h4>
                    <p>Get recognised for your skills after every exchange.</p>
                </div>
                <div class="benefit-card">
                    <div class="b-icon"><i class="bi bi-shield-check"></i></div>
                    <h4>Safe & Secure</h4>
                    <p>Your contact info is only shared after a confirmed match.</p>
                </div>
            </div>

            <div class="stats-row">
                <div class="stat"><div class="stat-num">5+</div><div class="stat-lbl">Active learners</div></div>
                <div class="stat"><div class="stat-num">10+</div><div class="stat-lbl">Skills shared</div></div>
                <div class="stat"><div class="stat-num">15+</div><div class="stat-lbl">Countries</div></div>
            </div>
        </div>

        <!-- Register Card -->
        <div class="card-3d" id="cardWrap">
            <div class="reg-card" id="regCard">
                <div class="card-shimmer"></div>
                <div class="card-glow"></div>

                <h2 class="card-title">Create your account</h2>
                <p class="card-sub">Free forever. No credit card required.</p>

                <!-- EJS blocks preserved:
                <% if (locals.error) { %>
                <div class="error-box"><i class="bi bi-exclamation-triangle-fill"></i><%= error %></div>
                <% } %>
                <% if (locals.success) { %>
                <div class="success-box"><i class="bi bi-check-circle-fill"></i><%= success %></div>
                <% } %>
                -->

                <form action="/register" method="POST" id="registerForm">
                    <div class="form-grid">

                        <div class="field">
                            <label for="full_name">Full Name</label>
                            <div class="input-wrap">
                                <input type="text" id="full_name" name="full_name" placeholder="John Doe" required>
                                <i class="bi bi-person input-icon"></i>
                            </div>
                        </div>

                        <div class="field">
                            <label for="username">Username</label>
                            <div class="input-wrap">
                                <input type="text" id="username" name="username" placeholder="johndoe123" required>
                                <i class="bi bi-at input-icon"></i>
                            </div>
                            <div id="username-feedback"></div>
                        </div>

                        <div class="field full">
                            <label for="email">Email Address</label>
                            <div class="input-wrap">
                                <input type="email" id="email" name="email" placeholder="you@example.com" required>
                                <i class="bi bi-envelope input-icon"></i>
                            </div>
                        </div>

                        <div class="field full">
                            <label for="phone_number">Phone Number <span style="font-weight:400;text-transform:none;font-size:0.7rem;color:rgba(255,255,255,0.25)">(optional)</span></label>
                            <div class="input-wrap">
                                <input type="tel" id="phone_number" name="phone_number" placeholder="+91 98765 43210">
                                <i class="bi bi-phone input-icon"></i>
                            </div>
                            <div class="field-hint"><i class="bi bi-shield-lock"></i> Only shared after a confirmed match</div>
                        </div>

                        <div class="field">
                            <label for="password">Password</label>
                            <div class="input-wrap">
                                <input type="password" id="password" name="password" placeholder="Create a password" required>
                                <i class="bi bi-lock input-icon"></i>
                            </div>
                            <div class="strength-track"><div class="strength-fill" id="strengthBar"></div></div>
                        </div>

                        <div class="field">
                            <label for="confirm_password">Confirm Password</label>
                            <div class="input-wrap">
                                <input type="password" id="confirm_password" name="confirm_password" placeholder="Confirm password" required>
                                <i class="bi bi-lock-fill input-icon"></i>
                            </div>
                            <div id="passwordMatch"></div>
                        </div>

                        <div class="full">
                            <div class="req-pills" id="reqs">
                                <span class="req-pill" id="r-len">8+ chars</span>
                                <span class="req-pill" id="r-low">Lowercase</span>
                                <span class="req-pill" id="r-up">Uppercase</span>
                                <span class="req-pill" id="r-num">Number</span>
                                <span class="req-pill" id="r-sp">Special</span>
                            </div>
                        </div>
                    </div>

                    <div class="check-row">
                        <input type="checkbox" id="terms" name="terms" required>
                        <label for="terms">
                            I agree to the <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a>
                        </label>
                    </div>

                    <button type="submit" class="btn-submit">
                        <i class="bi bi-person-plus"></i>
                        Create Account
                    </button>
                </form>

                <div class="card-footer-link">Already have an account? <a href="/login">Sign in →</a></div>
                <p class="terms">By signing up, you may receive occasional emails about your matches and platform updates.</p>
            </div>
        </div>
    </main>
</div>

<script>
    /* Stars */
    const starsEl = document.getElementById('stars');
    for (let i = 0; i < 130; i++) {
        const s = document.createElement('div');
        s.className = 'star';
        const sz = Math.random() * 2.2 + 0.4;
        s.style.cssText = `width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;animation-duration:${Math.random()*4+2}s;animation-delay:${Math.random()*6}s;`;
        starsEl.appendChild(s);
    }

    /* 3D tilt */
    const wrap = document.getElementById('cardWrap');
    const card = document.getElementById('regCard');
    wrap.addEventListener('mousemove', e => {
        const r = wrap.getBoundingClientRect();
        const dx = (e.clientX - r.left - r.width/2) / (r.width/2);
        const dy = (e.clientY - r.top - r.height/2) / (r.height/2);
        card.style.transform = `rotateY(${dx*5}deg) rotateX(${-dy*4}deg)`;
    });
    wrap.addEventListener('mouseleave', () => { card.style.transform = 'rotateY(0) rotateX(0)'; });

    /* Password */
    const pwd = document.getElementById('password');
    const cpwd = document.getElementById('confirm_password');
    const bar = document.getElementById('strengthBar');
    const matchEl = document.getElementById('passwordMatch');

    const reqs = {
        'r-len': p => p.length >= 8,
        'r-low': p => /[a-z]/.test(p),
        'r-up':  p => /[A-Z]/.test(p),
        'r-num': p => /[0-9]/.test(p),
        'r-sp':  p => /[!@#$%^&*(),.?":{}|<>]/.test(p)
    };

    pwd.addEventListener('input', function() {
        const v = this.value;
        let score = 0;
        for (const [id, fn] of Object.entries(reqs)) {
            const ok = fn(v);
            document.getElementById(id).className = 'req-pill' + (ok ? ' valid' : '');
            if (ok) score++;
        }
        bar.className = 'strength-fill';
        if (!v.length) { bar.style.width='0'; return; }
        if (score<=2) bar.classList.add('sw');
        else if (score===3) bar.classList.add('sf');
        else if (score===4) bar.classList.add('sg');
        else bar.classList.add('ss');
        if (cpwd.value) checkMatch();
    });

    cpwd.addEventListener('input', checkMatch);

    function checkMatch() {
        if (!cpwd.value) { matchEl.innerHTML=''; return; }
        matchEl.innerHTML = pwd.value === cpwd.value
            ? '<span class="ok"><i class="bi bi-check-circle"></i> Passwords match</span>'
            : '<span class="no"><i class="bi bi-exclamation-circle"></i> Passwords do not match</span>';
    }

    document.getElementById('username').addEventListener('input', function() {
        const fb = document.getElementById('username-feedback');
        fb.innerHTML = this.value.length < 3
            ? '<span style="color:rgba(255,255,255,0.3);font-size:0.71rem">At least 3 characters</span>'
            : '<span class="ok" style="font-size:0.71rem"><i class="bi bi-check-circle"></i> Looks good!</span>';
    });
</script>
</body>
</html>