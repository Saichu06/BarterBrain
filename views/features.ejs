<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a;
        --il:#818cf8; --iv:#a78bfa; --text:#eeeeff; --muted:#7a7a9a;
        --border:rgba(255,255,255,0.065); --green:#10b981; --amber:#f59e0b;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); }
    a { text-decoration:none; color:inherit; }

    .page-wrap { max-width:1100px; margin:0 auto; padding:48px 28px 100px; }

    /* Hero */
    .feat-hero {
        position:relative; overflow:hidden;
        background:linear-gradient(135deg,#1b1640,#200e4a 55%,#130d2e);
        border:1px solid rgba(99,102,241,0.22); border-radius:24px;
        padding:72px 60px; margin-bottom:72px; text-align:center;
    }
    .feat-hero::before {
        content:''; position:absolute; width:600px; height:600px;
        background:radial-gradient(circle,rgba(124,58,237,0.2),transparent 65%);
        top:-200px; right:-100px; border-radius:50%; pointer-events:none;
    }
    .hero-eyebrow {
        display:inline-flex; align-items:center; gap:7px;
        font-size:0.7rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
        color:#a5b4fc; background:rgba(99,102,241,0.12); border:1px solid rgba(99,102,241,0.2);
        padding:5px 14px; border-radius:100px; margin-bottom:22px;
        position:relative; z-index:1;
    }
    .feat-hero h1 {
        font-family:'Sora',sans-serif; font-size:clamp(2rem,4vw,3rem);
        font-weight:800; letter-spacing:-1.5px; color:var(--text);
        margin-bottom:18px; position:relative; z-index:1; line-height:1.15;
    }
    .feat-hero h1 span {
        background:linear-gradient(120deg,var(--il),var(--iv),#c084fc);
        -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .feat-hero p {
        font-size:1rem; color:var(--muted); max-width:560px;
        margin:0 auto 32px; line-height:1.75; position:relative; z-index:1;
    }
    .btn-start {
        display:inline-flex; align-items:center; gap:9px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff;
        font-family:'Sora',sans-serif; font-size:0.92rem; font-weight:700;
        padding:13px 32px; border-radius:11px; border:none;
        box-shadow:0 0 28px rgba(79,70,229,0.4); transition:all .25s;
        position:relative; z-index:1;
    }
    .btn-start:hover { transform:translateY(-2px); box-shadow:0 8px 36px rgba(79,70,229,0.55); color:#fff; }

    /* Section header */
    .sec-hdr { margin-bottom:36px; }
    .sec-hdr .label {
        font-size:0.7rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
        color:var(--muted); margin-bottom:10px; display:block;
    }
    .sec-hdr h2 {
        font-family:'Sora',sans-serif; font-size:clamp(1.5rem,2.5vw,2rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text); margin-bottom:8px;
    }
    .sec-hdr p { font-size:0.9rem; color:var(--muted); max-width:540px; line-height:1.7; }

    /* Core features grid */
    .core-grid {
        display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
        gap:16px; margin-bottom:72px;
    }
    .feat-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:18px;
        padding:26px; display:flex; flex-direction:column; gap:14px;
        transition:border-color .25s, transform .25s, box-shadow .25s;
        position:relative; overflow:hidden;
    }
    .feat-card::before {
        content:''; position:absolute; top:0; left:0; right:0; height:1px;
        background:linear-gradient(90deg,transparent,rgba(99,102,241,0.4),transparent);
        opacity:0; transition:opacity .25s;
    }
    .feat-card:hover { border-color:rgba(99,102,241,0.22); transform:translateY(-4px); box-shadow:0 18px 44px rgba(0,0,0,0.35); }
    .feat-card:hover::before { opacity:1; }
    .feat-icon {
        width:50px; height:50px; border-radius:14px;
        background:linear-gradient(135deg,rgba(79,70,229,0.17),rgba(124,58,237,0.12));
        border:1px solid rgba(99,102,241,0.22);
        display:flex; align-items:center; justify-content:center; font-size:1.4rem;
    }
    .feat-card h3 {
        font-family:'Sora',sans-serif; font-size:1rem; font-weight:700;
        color:var(--text); letter-spacing:-0.2px;
    }
    .feat-card p { font-size:0.84rem; color:var(--muted); line-height:1.7; }

    /* How it works */
    .hiw-section { margin-bottom:72px; }
    .steps-row {
        display:grid; grid-template-columns:repeat(3,1fr); gap:0; position:relative;
    }
    .steps-row::before {
        content:''; position:absolute; top:36px; left:calc(16.66% + 12px); right:calc(16.66% + 12px);
        height:1px; background:linear-gradient(90deg,rgba(99,102,241,0.5),rgba(124,58,237,0.5));
    }
    .step {
        display:flex; flex-direction:column; align-items:center;
        text-align:center; padding:20px 28px;
    }
    .step-num {
        width:72px; height:72px; border-radius:50%; margin-bottom:20px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed);
        display:flex; align-items:center; justify-content:center;
        font-family:'Sora',sans-serif; font-size:1.5rem; font-weight:800; color:#fff;
        box-shadow:0 0 36px rgba(79,70,229,0.4); position:relative; z-index:1;
    }
    .step h3 {
        font-family:'Sora',sans-serif; font-size:0.97rem; font-weight:700;
        color:var(--text); margin-bottom:10px;
    }
    .step p { font-size:0.83rem; color:var(--muted); line-height:1.65; max-width:220px; }

    /* Comparison table */
    .compare-section { margin-bottom:72px; }
    .compare-table { width:100%; border-collapse:collapse; }
    .compare-table th {
        font-family:'Sora',sans-serif; font-size:0.8rem; font-weight:700;
        padding:14px 20px; text-align:left; background:var(--bg-2);
        border-bottom:1px solid var(--border); color:var(--muted);
        letter-spacing:.05em;
    }
    .compare-table th:first-child { border-radius:12px 0 0 0; }
    .compare-table th:last-child  { border-radius:0 12px 0 0; }
    .compare-table th.hl { color:var(--il); background:rgba(79,70,229,0.1); }
    .compare-table td {
        font-size:0.84rem; color:var(--muted); padding:14px 20px;
        border-bottom:1px solid rgba(255,255,255,0.04);
    }
    .compare-table td:first-child { color:var(--text); font-weight:600; }
    .compare-table tr:last-child td { border-bottom:none; }
    .compare-table .yes { color:#34d399; font-weight:700; font-size:1rem; }
    .compare-table .no  { color:#6b7280; font-size:1rem; }

    /* CTA */
    .feat-cta {
        background:var(--bg-1); border:1px solid var(--border); border-radius:22px;
        padding:52px; text-align:center;
    }
    .feat-cta h2 {
        font-family:'Sora',sans-serif; font-size:clamp(1.4rem,2.5vw,1.9rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text); margin-bottom:12px;
    }
    .feat-cta p { font-size:0.9rem; color:var(--muted); max-width:440px; margin:0 auto 28px; line-height:1.7; }

    @media(max-width:900px){ .steps-row{grid-template-columns:1fr; } .steps-row::before{display:none;} }
    @media(max-width:768px){ .feat-hero{padding:44px 28px;} .feat-cta{padding:36px 22px;} }
    @media(max-width:640px){ .page-wrap{padding:24px 14px 80px;} }
</style>

<div class="page-wrap">

    <!-- Hero -->
    <div class="feat-hero">
        <div class="hero-eyebrow">✨ Platform Features</div>
        <h1>Everything you need to<br><span>learn and teach</span></h1>
        <p>BarterBrain is packed with features designed to make skill exchanges seamless, safe, and rewarding — all completely free.</p>
        <a href="/register" class="btn-start"><i class="bi bi-lightning-charge-fill"></i> Get Started Free</a>
    </div>

    <!-- Core Features -->
    <div class="sec-hdr">
        <span class="label">Core Features</span>
        <h2>Built for skill exchangers</h2>
        <p>From matching to reputation — every feature is designed around one goal: connecting the right people to exchange the right skills.</p>
    </div>

    <div class="core-grid">
        <div class="feat-card">
            <div class="feat-icon">⚡</div>
            <h3>Smart Skill Matching</h3>
            <p>Our matching engine connects your skill requests with the best available offers in the community, making it easy to find the right partner.</p>
        </div>
        <div class="feat-card">
            <div class="feat-icon">⭐</div>
            <h3>Reputation System</h3>
            <p>Every completed exchange earns you a review. Build your reputation score and let your expertise speak for itself across the community.</p>
        </div>
        <div class="feat-card">
            <div class="feat-icon">🔒</div>
            <h3>Private by Default</h3>
            <p>Your contact information is never public. It's only revealed to your match partner after both of you have agreed to connect.</p>
        </div>
        <div class="feat-card">
            <div class="feat-icon">📅</div>
            <h3>Availability Scheduling</h3>
            <p>Set your weekly availability so potential match partners know when you're free. No back-and-forth scheduling hassle.</p>
        </div>
        <div class="feat-card">
            <div class="feat-icon">🌍</div>
            <h3>Diverse Skill Categories</h3>
            <p>From programming to painting, language learning to fitness coaching — if you can teach it, you can offer it on BarterBrain.</p>
        </div>
        <div class="feat-card">
            <div class="feat-icon">💬</div>
            <h3>Review & Feedback</h3>
            <p>Leave detailed reviews after each exchange. Honest feedback keeps the community quality high and helps everyone improve.</p>
        </div>
        <div class="feat-card">
            <div class="feat-icon">📊</div>
            <h3>Personal Dashboard</h3>
            <p>Track your offers, requests, matches, and reputation all in one clean dashboard. See your exchange activity at a glance.</p>
        </div>
        <div class="feat-card">
            <div class="feat-icon">🆓</div>
            <h3>Completely Free</h3>
            <p>No subscriptions. No transaction fees. No paywalls. BarterBrain is and will always be 100% free to use — forever.</p>
        </div>
        <div class="feat-card">
            <div class="feat-icon">📱</div>
            <h3>Mobile Friendly</h3>
            <p>BarterBrain works beautifully on any device — desktop, tablet, or phone. Exchange skills wherever you are.</p>
        </div>
    </div>

    <!-- How It Works -->
    <div class="hiw-section">
        <div class="sec-hdr">
            <span class="label">How It Works</span>
            <h2>Up and running in 3 steps</h2>
        </div>
        <div class="steps-row">
            <div class="step">
                <div class="step-num">1</div>
                <h3>Create Your Profile</h3>
                <p>Sign up and list the skills you can teach and the ones you want to learn. It takes less than 2 minutes.</p>
            </div>
            <div class="step">
                <div class="step-num">2</div>
                <h3>Find Your Match</h3>
                <p>Browse offers and requests. Our smart matching surfaces the most relevant people for your needs.</p>
            </div>
            <div class="step">
                <div class="step-num">3</div>
                <h3>Start Exchanging</h3>
                <p>Connect, schedule sessions, learn, teach, and build your reputation with every exchange.</p>
            </div>
        </div>
    </div>

    <!-- Comparison -->
    <div class="compare-section">
        <div class="sec-hdr">
            <span class="label">Why BarterBrain</span>
            <h2>How we compare</h2>
        </div>
        <div style="background:var(--bg-1);border:1px solid var(--border);border-radius:16px;overflow:hidden;">
            <table class="compare-table">
                <thead>
                    <tr>
                        <th>Feature</th>
                        <th class="hl">BarterBrain</th>
                        <th>Paid Platforms</th>
                        <th>Tutoring Sites</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>Completely Free</td><td class="yes">✓</td><td class="no">✗</td><td class="no">✗</td></tr>
                    <tr><td>Skill Exchange (No Money)</td><td class="yes">✓</td><td class="no">✗</td><td class="no">✗</td></tr>
                    <tr><td>Privacy-First Contact</td><td class="yes">✓</td><td class="no">✗</td><td class="no">✗</td></tr>
                    <tr><td>Reputation System</td><td class="yes">✓</td><td class="yes">✓</td><td class="yes">✓</td></tr>
                    <tr><td>Availability Scheduling</td><td class="yes">✓</td><td class="yes">✓</td><td class="yes">✓</td></tr>
                    <tr><td>No Transaction Fees</td><td class="yes">✓</td><td class="no">✗</td><td class="no">✗</td></tr>
                    <tr><td>Community Driven</td><td class="yes">✓</td><td class="no">✗</td><td class="no">✗</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- CTA -->
    <div class="feat-cta">
        <h2>Ready to start learning?</h2>
        <p>Join thousands of learners and teachers exchanging skills every day — completely free.</p>
        <a href="/register" class="btn-start"><i class="bi bi-person-plus-fill"></i> Create Your Free Account</a>
    </div>

</div>

<%- include('partials/footer') %>
