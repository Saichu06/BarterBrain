<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - BarterBrain</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --indigo: #4f46e5;
            --violet: #7c3aed;
            --indigo-light: #818cf8;
            --indigo-glow: rgba(79, 70, 229, 0.35);
            --violet-glow: rgba(124, 58, 237, 0.25);
            --text-main: #0f0e1a;
            --text-muted: #5b6b8c;
            --text-light: #9aa5be;
            --border: rgba(79, 70, 229, 0.15);
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.9);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #0a0812;
            color: var(--text-main);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ── Scene / Canvas ── */
        .scene {
            position: fixed;
            inset: 0;
            z-index: 0;
            background: radial-gradient(ellipse 80% 60% at 20% 40%, #1a1060 0%, transparent 60%),
                        radial-gradient(ellipse 60% 50% at 80% 70%, #1e0a40 0%, transparent 55%),
                        linear-gradient(160deg, #080612 0%, #0d0a24 50%, #0a0615 100%);
        }

        /* Floating orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(70px);
            opacity: 0.55;
            animation: float linear infinite;
        }
        .orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, #4f46e5, transparent 70%); top: -120px; left: -100px; animation-duration: 18s; }
        .orb-2 { width: 380px; height: 380px; background: radial-gradient(circle, #7c3aed, transparent 70%); bottom: -80px; right: -60px; animation-duration: 22s; animation-delay: -5s; }
        .orb-3 { width: 260px; height: 260px; background: radial-gradient(circle, #a855f7, transparent 70%); top: 50%; left: 50%; transform: translate(-50%,-50%); animation-duration: 28s; animation-delay: -10s; }

        @keyframes float {
            0%   { transform: translate(0, 0) scale(1); }
            25%  { transform: translate(30px, -40px) scale(1.05); }
            50%  { transform: translate(-20px, 30px) scale(0.97); }
            75%  { transform: translate(40px, 10px) scale(1.03); }
            100% { transform: translate(0, 0) scale(1); }
        }

        /* Particle grid */
        .grid-overlay {
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(79,70,229,0.07) 1px, transparent 1px),
                linear-gradient(90deg, rgba(79,70,229,0.07) 1px, transparent 1px);
            background-size: 60px 60px;
            mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 20%, transparent 75%);
        }

        /* Stars */
        .stars { position: absolute; inset: 0; }
        .star {
            position: absolute;
            border-radius: 50%;
            background: white;
            animation: twinkle ease-in-out infinite;
        }
        @keyframes twinkle {
            0%, 100% { opacity: 0.1; transform: scale(1); }
            50%       { opacity: 0.9; transform: scale(1.4); }
        }

        /* ── Layout ── */
        .page-wrap {
            position: relative;
            z-index: 1;
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 40px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Navbar ── */
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 28px 0;
        }

        .brand {
            font-family: 'Sora', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            text-decoration: none;
            background: linear-gradient(135deg, #a78bfa, #818cf8, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-links { display: flex; gap: 28px; align-items: center; }
        .nav-links a {
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: white; }
        .nav-pill {
            background: rgba(79,70,229,0.2);
            border: 1px solid rgba(129,140,248,0.4);
            color: #a78bfa !important;
            padding: 8px 22px;
            border-radius: 40px;
            backdrop-filter: blur(8px);
            transition: all 0.25s !important;
        }
        .nav-pill:hover {
            background: rgba(79,70,229,0.4) !important;
            border-color: rgba(129,140,248,0.7) !important;
            color: white !important;
        }

        /* ── Main grid ── */
        main {
            flex: 1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
            padding: 40px 0 80px;
        }

        /* ── Hero ── */
        .hero { padding-right: 20px; }

        .badge-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(79,70,229,0.15);
            border: 1px solid rgba(129,140,248,0.3);
            color: #a78bfa;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 7px 16px;
            border-radius: 40px;
            margin-bottom: 28px;
            backdrop-filter: blur(6px);
        }
        .badge-dot {
            width: 6px; height: 6px;
            background: #a78bfa;
            border-radius: 50%;
            box-shadow: 0 0 8px #a78bfa;
            animation: pulse-dot 2s ease-in-out infinite;
        }
        @keyframes pulse-dot {
            0%,100% { box-shadow: 0 0 4px #a78bfa; }
            50%      { box-shadow: 0 0 12px #a78bfa, 0 0 24px rgba(167,139,250,0.5); }
        }

        .hero-title {
            font-family: 'Sora', sans-serif;
            font-size: clamp(2.6rem, 3.5vw, 4rem);
            font-weight: 800;
            line-height: 1.15;
            letter-spacing: -1.5px;
            color: white;
            margin-bottom: 24px;
        }
        .hero-title .gradient-text {
            background: linear-gradient(135deg, #818cf8 0%, #a78bfa 50%, #c084fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-desc {
            font-size: 1.1rem;
            line-height: 1.75;
            color: rgba(255,255,255,0.55);
            margin-bottom: 44px;
            max-width: 440px;
        }

        /* Feature list */
        .feat-list { list-style: none; padding: 0; margin-bottom: 52px; }
        .feat-list li {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 0;
            color: rgba(255,255,255,0.75);
            font-size: 0.97rem;
            font-weight: 500;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            transition: color 0.2s;
        }
        .feat-list li:last-child { border-bottom: none; }
        .feat-list li:hover { color: white; }
        .feat-icon {
            width: 32px; height: 32px;
            background: linear-gradient(135deg, rgba(79,70,229,0.4), rgba(124,58,237,0.3));
            border: 1px solid rgba(129,140,248,0.3);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            font-size: 0.85rem;
            color: #a78bfa;
        }

        /* Stats */
        .stats-row {
            display: flex;
            gap: 0;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            overflow: hidden;
        }
        .stat {
            flex: 1;
            padding: 22px 20px;
            text-align: center;
            border-right: 1px solid rgba(255,255,255,0.08);
            transition: background 0.2s;
        }
        .stat:last-child { border-right: none; }
        .stat:hover { background: rgba(79,70,229,0.1); }
        .stat-num {
            font-family: 'Sora', sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #818cf8, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .stat-lbl { font-size: 0.78rem; color: rgba(255,255,255,0.45); margin-top: 4px; }

        /* ── Card ── */
        .card-3d-wrap {
            perspective: 1200px;
        }
        .login-card {
            background: rgba(15, 12, 30, 0.75);
            backdrop-filter: blur(40px) saturate(180%);
            -webkit-backdrop-filter: blur(40px) saturate(180%);
            border: 1px solid rgba(129, 140, 248, 0.2);
            border-radius: 32px;
            padding: 52px 48px;
            position: relative;
            overflow: hidden;
            box-shadow:
                0 0 0 1px rgba(255,255,255,0.05) inset,
                0 40px 80px rgba(0,0,0,0.5),
                0 0 80px rgba(79,70,229,0.15);
            transform-style: preserve-3d;
            transition: transform 0.1s ease-out;
        }

        /* Top shimmer line */
        .card-shimmer {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent 0%, rgba(167,139,250,0.8) 40%, rgba(129,140,248,0.8) 60%, transparent 100%);
        }

        /* Inner glow */
        .card-glow {
            position: absolute;
            top: -60px; left: 50%;
            transform: translateX(-50%);
            width: 300px; height: 150px;
            background: radial-gradient(ellipse, rgba(79,70,229,0.25), transparent 70%);
            pointer-events: none;
        }

        .card-title {
            font-family: 'Sora', sans-serif;
            font-size: 2.1rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: white;
            margin-bottom: 6px;
        }
        .card-sub { font-size: 0.95rem; color: rgba(255,255,255,0.45); margin-bottom: 36px; }

        /* Error */
        .error-box {
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.35);
            color: #fca5a5;
            padding: 14px 18px;
            border-radius: 14px;
            font-size: 0.9rem;
            margin-bottom: 24px;
            display: flex; align-items: center; gap: 10px;
        }

        /* Fields */
        .field { margin-bottom: 22px; }
        .field label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.04em;
            color: rgba(255,255,255,0.55);
            text-transform: uppercase;
            margin-bottom: 9px;
        }
        .input-wrap { position: relative; }
        .input-icon {
            position: absolute;
            left: 16px; top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.25);
            font-size: 1rem;
            pointer-events: none;
            transition: color 0.2s;
        }
        .input-wrap:focus-within .input-icon { color: #818cf8; }

        input[type="email"],
        input[type="password"],
        input[type="text"],
        input[type="tel"] {
            width: 100%;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px;
            color: white;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.97rem;
            padding: 15px 16px 15px 48px;
            outline: none;
            transition: all 0.25s;
            caret-color: #818cf8;
        }
        input::placeholder { color: rgba(255,255,255,0.2); }
        input:focus {
            background: rgba(79,70,229,0.12);
            border-color: rgba(129,140,248,0.6);
            box-shadow: 0 0 0 4px rgba(79,70,229,0.15), 0 0 20px rgba(79,70,229,0.1);
        }

        /* Row */
        .row-between {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 28px; gap: 8px;
        }
        .check-wrap { display: flex; align-items: center; gap: 8px; }
        .check-wrap input[type="checkbox"] {
            width: 17px; height: 17px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 5px;
            padding: 0;
            cursor: pointer;
            accent-color: #4f46e5;
        }
        .check-wrap label { font-size: 0.88rem; color: rgba(255,255,255,0.5); cursor: pointer; }
        .forgot { font-size: 0.88rem; color: #818cf8; text-decoration: none; font-weight: 600; }
        .forgot:hover { color: #a78bfa; }

        /* Submit button */
        .btn-submit {
            width: 100%;
            position: relative;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            font-family: 'Sora', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.01em;
            padding: 17px;
            border-radius: 14px;
            border: none;
            cursor: pointer;
            overflow: hidden;
            transition: all 0.3s;
            box-shadow: 0 8px 30px rgba(79,70,229,0.4), 0 0 0 1px rgba(255,255,255,0.1) inset;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            margin-bottom: 28px;
        }
        .btn-submit::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 200%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            transition: left 0.5s;
        }
        .btn-submit:hover::before { left: 100%; }
        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 40px rgba(79,70,229,0.5), 0 0 0 1px rgba(255,255,255,0.15) inset;
        }
        .btn-submit:active { transform: translateY(-1px); }

        /* Divider */
        .divider {
            display: flex; align-items: center; gap: 14px;
            margin-bottom: 22px;
        }
        .divider::before, .divider::after {
            content: ''; flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.08);
        }
        .divider span { font-size: 0.8rem; color: rgba(255,255,255,0.3); white-space: nowrap; }

        /* Social button */
        .btn-social {
            width: 100%;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px;
            color: rgba(255,255,255,0.45);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            padding: 15px;
            cursor: not-allowed;
            display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        .btn-social i { color: rgba(219,68,55,0.5); }

        /* Footer links */
        .card-footer-link {
            text-align: center;
            font-size: 0.9rem;
            color: rgba(255,255,255,0.4);
            margin-top: 22px;
        }
        .card-footer-link a { color: #818cf8; font-weight: 700; text-decoration: none; }
        .card-footer-link a:hover { color: #a78bfa; }

        .terms { font-size: 0.76rem; color: rgba(255,255,255,0.25); text-align: center; margin-top: 14px; }
        .terms a { color: #818cf8; text-decoration: none; }

        /* Responsive */
        @media (max-width: 960px) {
            main { grid-template-columns: 1fr; gap: 48px; padding: 24px 0 60px; }
            .hero { padding-right: 0; text-align: center; }
            .hero-desc { margin: 0 auto 44px; }
            .feat-list li { justify-content: flex-start; }
        }
        @media (max-width: 640px) {
            .page-wrap { padding: 0 20px; }
            nav { padding: 20px 0; }
            .nav-links { display: none; }
            .login-card { padding: 36px 24px; }
            .hero-title { font-size: 2.4rem; }
        }
    </style>
</head>
<body>

<div class="scene">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-overlay"></div>
    <div class="stars" id="stars"></div>
</div>

<div class="page-wrap">
    <nav>
        <a href="/" class="brand">BarterBrain</a>
        <div class="nav-links">
            <a href="/features">Features</a>
            <a href="/how-it-works">How it works</a>
            <a href="/community">Community</a>
            <a href="/register" class="nav-pill">Sign up free</a>
        </div>
    </nav>

    <main>
        <!-- Hero -->
        <div class="hero">
            <div class="badge-pill">
                <span class="badge-dot"></span>
                Skill Exchange Platform
            </div>
            <h1 class="hero-title">
                Trade skills,<br>
                <span class="gradient-text">not money</span>
            </h1>
            <p class="hero-desc">
                Join thousands of learners and experts exchanging knowledge.
                Learn anything from coding to cooking, completely free.
            </p>

            <ul class="feat-list">
                <li>
                    <span class="feat-icon"><i class="bi bi-stars"></i></span>
                    50,000+ skills available to learn
                </li>
                <li>
                    <span class="feat-icon"><i class="bi bi-globe2"></i></span>
                    Connect with experts worldwide
                </li>
                <li>
                    <span class="feat-icon"><i class="bi bi-patch-check"></i></span>
                    Build your reputation and earn badges
                </li>
                <li>
                    <span class="feat-icon"><i class="bi bi-infinity"></i></span>
                    Zero cost, pure knowledge exchange
                </li>
            </ul>

            <div class="stats-row">
                <div class="stat">
                    <div class="stat-num">5+</div>
                    <div class="stat-lbl">Active learners</div>
                </div>
                <div class="stat">
                    <div class="stat-num">10+</div>
                    <div class="stat-lbl">Skills shared</div>
                </div>
                <div class="stat">
                    <div class="stat-num">15+</div>
                    <div class="stat-lbl">Countries</div>
                </div>
            </div>
        </div>

        <!-- Login Card -->
        <div class="card-3d-wrap" id="cardWrap">
            <div class="login-card" id="loginCard">
                <div class="card-shimmer"></div>
                <div class="card-glow"></div>

                <h2 class="card-title">Welcome back</h2>
                <p class="card-sub">Sign in to continue your learning journey</p>

                <!-- EJS error block preserved -->
                <!-- <% if (locals.error) { %>
                <div class="error-box">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <%= error %>
                </div>
                <% } %> -->

                <form action="/login" method="POST">
                    <div class="field">
                        <label for="email">Email address</label>
                        <div class="input-wrap">
                            <input type="email" id="email" name="email" placeholder="you@example.com" required>
                            <i class="bi bi-envelope input-icon"></i>
                        </div>
                    </div>

                    <div class="field">
                        <label for="password">Password</label>
                        <div class="input-wrap">
                            <input type="password" id="password" name="password" placeholder="Enter your password" required>
                            <i class="bi bi-lock input-icon"></i>
                        </div>
                    </div>

                    <div class="row-between">
                        <div class="check-wrap">
                            <input type="checkbox" id="remember" name="remember">
                            <label for="remember">Remember me</label>
                        </div>
                        <a href="/forgot-password" class="forgot">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn-submit">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Sign In
                    </button>

                    <div class="divider"><span>or continue with</span></div>

                    <button type="button" class="btn-social" disabled>
                        <i class="bi bi-google"></i>
                        Google (Coming Soon)
                    </button>
                </form>

                <div class="card-footer-link">
                    Don't have an account? <a href="/register">Sign up free →</a>
                </div>
                <p class="terms">
                    By signing in you agree to our <a href="/terms">Terms</a> &amp; <a href="/privacy">Privacy Policy</a>
                </p>
            </div>
        </div>
    </main>
</div>

<script>
    /* Stars */
    const starsEl = document.getElementById('stars');
    for (let i = 0; i < 120; i++) {
        const s = document.createElement('div');
        s.className = 'star';
        const size = Math.random() * 2.5 + 0.5;
        s.style.cssText = `
            width:${size}px; height:${size}px;
            top:${Math.random()*100}%; left:${Math.random()*100}%;
            animation-duration:${Math.random()*4+2}s;
            animation-delay:${Math.random()*5}s;
        `;
        starsEl.appendChild(s);
    }

    /* 3D tilt on card */
    const wrap = document.getElementById('cardWrap');
    const card = document.getElementById('loginCard');
    wrap.addEventListener('mousemove', e => {
        const r = wrap.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height / 2;
        const dx = (e.clientX - cx) / (r.width / 2);
        const dy = (e.clientY - cy) / (r.height / 2);
        card.style.transform = `rotateY(${dx * 6}deg) rotateX(${-dy * 5}deg)`;
    });
    wrap.addEventListener('mouseleave', () => {
        card.style.transform = 'rotateY(0deg) rotateX(0deg)';
    });
</script>
</body>
</html>