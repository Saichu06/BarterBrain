<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a;
        --il:#818cf8; --iv:#a78bfa; --text:#eeeeff; --muted:#7a7a9a;
        --border:rgba(255,255,255,0.065); --green:#10b981; --amber:#f59e0b;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); }
    a { text-decoration:none; color:inherit; }

    .page-wrap { max-width:1100px; margin:0 auto; padding:48px 28px 100px; }

    /* Hero */
    .about-hero {
        position:relative; overflow:hidden;
        background:linear-gradient(135deg,#1b1640,#200e4a 55%,#130d2e);
        border:1px solid rgba(99,102,241,0.22); border-radius:24px;
        padding:72px 60px; margin-bottom:60px; text-align:center;
    }
    .about-hero::before {
        content:''; position:absolute; width:600px; height:600px;
        background:radial-gradient(circle,rgba(124,58,237,0.2),transparent 65%);
        top:-200px; right:-100px; border-radius:50%; pointer-events:none;
    }
    .about-hero::after {
        content:''; position:absolute; width:400px; height:400px;
        background:radial-gradient(circle,rgba(79,70,229,0.14),transparent 65%);
        bottom:-130px; left:-60px; border-radius:50%; pointer-events:none;
    }
    .hero-eyebrow {
        display:inline-flex; align-items:center; gap:7px;
        font-size:0.7rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
        color:#a5b4fc; background:rgba(99,102,241,0.12); border:1px solid rgba(99,102,241,0.2);
        padding:5px 14px; border-radius:100px; margin-bottom:22px;
        position:relative; z-index:1;
    }
    .hero-eyebrow .dot { width:6px; height:6px; background:#818cf8; border-radius:50%; animation:blink 2s ease-in-out infinite; }
    @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.3;} }
    .about-hero h1 {
        font-family:'Sora',sans-serif; font-size:clamp(2rem,4vw,3rem);
        font-weight:800; letter-spacing:-1.5px; color:var(--text);
        margin-bottom:18px; position:relative; z-index:1; line-height:1.15;
    }
    .about-hero h1 span {
        background:linear-gradient(120deg,var(--il),var(--iv),#c084fc);
        -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .about-hero p {
        font-size:1rem; color:var(--muted); max-width:560px; margin:0 auto;
        line-height:1.75; position:relative; z-index:1;
    }

    /* Mission */
    .mission-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:22px;
        padding:48px; margin-bottom:28px; text-align:center;
    }
    .mission-card .quote-mark {
        font-family:'Sora',sans-serif; font-size:5rem; line-height:1;
        background:linear-gradient(135deg,var(--il),var(--iv));
        -webkit-background-clip:text; -webkit-text-fill-color:transparent;
        margin-bottom:-10px; display:block;
    }
    .mission-card blockquote {
        font-family:'Sora',sans-serif; font-size:clamp(1.2rem,2vw,1.6rem);
        font-weight:700; color:var(--text); letter-spacing:-0.5px;
        line-height:1.4; max-width:700px; margin:0 auto 20px;
    }
    .mission-card p { font-size:0.9rem; color:var(--muted); max-width:560px; margin:0 auto; line-height:1.7; }

    /* Values grid */
    .section-label {
        font-size:0.7rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
        color:var(--muted); margin-bottom:16px; display:block;
    }
    .section-title {
        font-family:'Sora',sans-serif; font-size:clamp(1.4rem,2.5vw,1.9rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text);
        margin-bottom:8px;
    }
    .section-sub { font-size:0.9rem; color:var(--muted); margin-bottom:36px; line-height:1.6; }

    .values-grid {
        display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:16px; margin-bottom:60px;
    }
    .value-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:18px;
        padding:26px; transition:border-color .25s, transform .25s;
    }
    .value-card:hover { border-color:rgba(99,102,241,0.22); transform:translateY(-3px); }
    .val-icon {
        width:48px; height:48px; border-radius:14px; margin-bottom:16px;
        background:linear-gradient(135deg,rgba(79,70,229,0.15),rgba(124,58,237,0.1));
        border:1px solid rgba(99,102,241,0.2); display:flex; align-items:center;
        justify-content:center; font-size:1.3rem;
    }
    .value-card h3 {
        font-family:'Sora',sans-serif; font-size:0.95rem; font-weight:700;
        color:var(--text); margin-bottom:8px;
    }
    .value-card p { font-size:0.83rem; color:var(--muted); line-height:1.65; }

    /* Stats banner */
    .stats-banner {
        background:linear-gradient(135deg,#1b1640,#200e4a 55%,#130d2e);
        border:1px solid rgba(99,102,241,0.2); border-radius:22px;
        padding:48px; margin-bottom:60px;
        display:grid; grid-template-columns:repeat(3,1fr); gap:0;
        position:relative; overflow:hidden;
    }
    .stats-banner::before {
        content:''; position:absolute; width:400px; height:400px;
        background:radial-gradient(circle,rgba(124,58,237,0.18),transparent 65%);
        top:-150px; right:-80px; border-radius:50%; pointer-events:none;
    }
    .stat-col {
        text-align:center; padding:20px 32px; position:relative; z-index:1;
        border-right:1px solid rgba(255,255,255,0.06);
    }
    .stat-col:last-child { border-right:none; }
    .stat-col .num {
        font-family:'Sora',sans-serif; font-size:2.8rem; font-weight:800;
        letter-spacing:-2px; line-height:1;
        background:linear-gradient(135deg,#e0e7ff,#c4b5fd);
        -webkit-background-clip:text; -webkit-text-fill-color:transparent;
        margin-bottom:8px; display:block;
    }
    .stat-col .lbl { font-size:0.84rem; color:rgba(165,180,252,0.6); font-weight:500; }

    /* Team section */
    .team-grid {
        display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px; margin-bottom:60px;
    }
    .team-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:20px;
        overflow:hidden; transition:border-color .25s, transform .25s;
    }
    .team-card:hover { border-color:rgba(99,102,241,0.3); transform:translateY(-4px); box-shadow:0 20px 50px rgba(0,0,0,0.4); }

    .team-photo-wrap {
        width:100%; aspect-ratio:1/1; max-height:240px;
        background:linear-gradient(135deg,rgba(79,70,229,0.1),rgba(124,58,237,0.07));
        display:flex; align-items:center; justify-content:center;
        border-bottom:1px solid var(--border); overflow:hidden;
    }
    .team-photo { width:100%; height:100%; object-fit:cover; object-position:top center; }
    .team-placeholder {
        width:100%; height:100%; display:flex; flex-direction:column;
        align-items:center; justify-content:center; gap:10px;
    }
    .team-placeholder i { font-size:4rem; color:rgba(129,140,248,0.25); }
    .team-placeholder span {
        font-size:0.75rem; color:var(--muted); background:rgba(99,102,241,0.08);
        border:1px dashed rgba(99,102,241,0.25); padding:4px 14px; border-radius:100px;
    }

    .team-info { padding:22px 24px 26px; }
    .team-name {
        font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:800;
        color:var(--text); letter-spacing:-0.3px; margin-bottom:10px;
    }
    .team-roles { display:flex; flex-wrap:wrap; gap:7px; margin-bottom:14px; }
    .role-badge {
        font-size:0.7rem; font-weight:700; padding:3px 11px; border-radius:100px;
        letter-spacing:.03em;
    }
    .role-badge.founder   { background:rgba(79,70,229,0.14);  color:#818cf8; border:1px solid rgba(79,70,229,0.24); }
    .role-badge.cofounder { background:rgba(124,58,237,0.14); color:#a78bfa; border:1px solid rgba(124,58,237,0.24); }
    .role-badge.dev       { background:rgba(59,130,246,0.1);  color:#60a5fa; border:1px solid rgba(59,130,246,0.2); }
    .role-badge.backend   { background:rgba(16,185,129,0.1);  color:#34d399; border:1px solid rgba(16,185,129,0.2); }
    .team-meta { display:flex; align-items:flex-start; gap:8px; margin-bottom:7px; font-size:0.8rem; color:var(--muted); }
    .team-meta:last-child { margin-bottom:0; }
    .team-meta i { color:var(--il); font-size:0.8rem; flex-shrink:0; margin-top:2px; opacity:.7; }

    /* CTA */
    .about-cta {
        background:var(--bg-1); border:1px solid var(--border); border-radius:22px;
        padding:52px; text-align:center;
    }
    .about-cta h2 {
        font-family:'Sora',sans-serif; font-size:clamp(1.4rem,2.5vw,1.9rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text); margin-bottom:12px;
    }
    .about-cta p { font-size:0.9rem; color:var(--muted); max-width:440px; margin:0 auto 28px; line-height:1.7; }
    .btn-cta {
        display:inline-flex; align-items:center; gap:9px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff;
        font-family:'Sora',sans-serif; font-size:0.92rem; font-weight:700;
        padding:13px 32px; border-radius:11px; border:none;
        box-shadow:0 0 28px rgba(79,70,229,0.4); transition:all .25s;
    }
    .btn-cta:hover { transform:translateY(-2px); box-shadow:0 8px 36px rgba(79,70,229,0.55); color:#fff; }

    @media(max-width:768px){
        .about-hero{padding:44px 28px;}
        .stats-banner{grid-template-columns:1fr; padding:32px 24px;}
        .stat-col{border-right:none; border-bottom:1px solid rgba(255,255,255,0.06); padding:16px 0;}
        .stat-col:last-child{border-bottom:none;}
        .about-cta{padding:36px 22px;}
        .mission-card{padding:32px 22px;}
    }
    @media(max-width:640px){ .page-wrap{padding:24px 14px 80px;} }
</style>

<div class="page-wrap">

    <!-- Hero -->
    <div class="about-hero">
        <div class="hero-eyebrow"><span class="dot"></span> Our Story</div>
        <h1>Built by students,<br>for <span>everyone</span></h1>
        <p>BarterBrain started with a simple belief — that knowledge shouldn't have a price tag. We're two undergrads who wanted to change the way people learn and teach.</p>
    </div>

    <!-- Mission -->
    <div class="mission-card">
        <span class="quote-mark">"</span>
        <blockquote>Exchange skills, not money. Learn anything, teach anything — free forever.</blockquote>
        <p>BarterBrain is a community-driven skill exchange platform where your expertise is the only currency. We connect people who have something to teach with people who have something to learn.</p>
    </div>

    <!-- Values -->
    <span class="section-label">What We Stand For</span>
    <h2 class="section-title">Our Core Values</h2>
    <p class="section-sub">Everything we build is guided by these principles.</p>

    <div class="values-grid">
        <div class="value-card">
            <div class="val-icon">🌍</div>
            <h3>Free for Everyone</h3>
            <p>Knowledge belongs to everyone. BarterBrain is and will always be free — no subscriptions, no hidden fees, no paywalls.</p>
        </div>
        <div class="value-card">
            <div class="val-icon">🤝</div>
            <h3>Community First</h3>
            <p>We're not a marketplace — we're a community. Every decision we make puts users and their learning journeys first.</p>
        </div>
        <div class="value-card">
            <div class="val-icon">🔒</div>
            <h3>Privacy by Design</h3>
            <p>Your contact information is never exposed publicly. We only share it after both parties agree to connect.</p>
        </div>
        <div class="value-card">
            <div class="val-icon">⭐</div>
            <h3>Trust & Reputation</h3>
            <p>Our review and reputation system helps you find reliable teachers and learners you can trust to exchange with.</p>
        </div>
        <div class="value-card">
            <div class="val-icon">🚀</div>
            <h3>Student-Built</h3>
            <p>We're students building for students — and everyone else. We understand the value of accessible learning first-hand.</p>
        </div>
        <div class="value-card">
            <div class="val-icon">🌱</div>
            <h3>Always Growing</h3>
            <p>We're constantly improving based on community feedback. Every feature is built with real user needs in mind.</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-banner">
        <div class="stat-col">
            <span class="num">1,000+</span>
            <span class="lbl">Active Users</span>
        </div>
        <div class="stat-col">
            <span class="num">500+</span>
            <span class="lbl">Successful Exchanges</span>
        </div>
        <div class="stat-col">
            <span class="num">50+</span>
            <span class="lbl">Skills Available</span>
        </div>
    </div>

    <!-- Team -->
    <span class="section-label">The People Behind It</span>
    <h2 class="section-title">Meet the Team</h2>
    <p class="section-sub">Two passionate 2nd-year undergrads from SRM IST KTR who believe knowledge should be free.</p>

    <section id="about" class="about-section">
        <div class="container">
            <div class="text-center mb-5 fade-up">
                <span class="section-eyebrow">Meet the Team</span>
                <h2 class="section-title">Built by students,<br>for everyone</h2>
                <p class="section-sub">Two passionate 2nd-year undergrads from SRM IST KTR who believe knowledge should
                    be free.</p>
            </div>

            <div class="row g-4 justify-content-center">
                <!-- Saicharan -->
                <div class="col-md-6 col-lg-5 fade-up">
                    <div class="team-card">
                        <div class="team-header">
                            <img src="/images/Saicharan.png" class="team-photo" alt="A S Saicharan">
                            <div class="team-title">
                                <h3 class="team-name">A S Saicharan</h3>
                                <div class="team-roles">
                                    <span class="role-badge founder">Founder</span>
                                    <span class="role-badge dev">Lead Developer</span>
                                </div>
                            </div>
                        </div>
                        <div class="team-info">
                            <div class="team-meta">
                                <i class="bi bi-building"></i>
                                SRM Institute of Science & Technology, KTR
                            </div>
                            <div class="team-meta">
                                <i class="bi bi-mortarboard-fill"></i>
                                2nd Year · Computer Technology · C1 Section
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hariharan -->
                <div class="col-md-6 col-lg-5 fade-up" style="transition-delay: 0.15s;">
                    <div class="team-card">
                        <div class="team-header">
                            <img src="/images/Hariharan.jpeg" class="team-photo" alt="Hariharan K">
                            <div class="team-title">
                                <h3 class="team-name">Hariharan K</h3>
                                <div class="team-roles">
                                    <span class="role-badge founder">Co-Founder</span>
                                    <span class="role-badge dev">Backend Developer</span>
                                </div>
                            </div>
                        </div>
                        <div class="team-info">
                            <div class="team-meta">
                                <i class="bi bi-building"></i>
                                SRM Institute of Science & Technology, KTR
                            </div>
                            <div class="team-meta">
                                <i class="bi bi-mortarboard-fill"></i>
                                2nd Year · Computer Technology · C1 Section
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    <!-- CTA -->
    <div class="about-cta">
        <h2>Ready to start exchanging?</h2>
        <p>Join over 1,000 learners and teachers already sharing skills on BarterBrain — completely free.</p>
        <a href="/register" class="btn-cta"><i class="bi bi-lightning-charge-fill"></i> Create Your Free Account</a>
    </div>

</div>

<%- include('partials/footer') %>
