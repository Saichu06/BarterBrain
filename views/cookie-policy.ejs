<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a;
        --il:#818cf8; --iv:#a78bfa; --text:#eeeeff; --muted:#7a7a9a;
        --border:rgba(255,255,255,0.065); --amber:#f59e0b;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); }
    a { color:var(--il); text-decoration:none; }
    a:hover { color:var(--iv); }
    .page-wrap { max-width:860px; margin:0 auto; padding:48px 28px 100px; }

    .doc-hero {
        position:relative; overflow:hidden;
        background:linear-gradient(135deg,#1a1200,#2a1d00 55%,#150f00);
        border:1px solid rgba(245,158,11,0.2); border-radius:22px;
        padding:44px 48px; margin-bottom:40px; text-align:center;
    }
    .doc-hero::before {
        content:''; position:absolute; width:400px; height:400px;
        background:radial-gradient(circle,rgba(245,158,11,0.12),transparent 65%);
        top:-150px; right:-80px; border-radius:50%; pointer-events:none;
    }
    .doc-hero-icon {
        width:56px; height:56px; border-radius:16px; margin:0 auto 18px;
        background:rgba(245,158,11,0.14); border:1px solid rgba(245,158,11,0.22);
        display:flex; align-items:center; justify-content:center; font-size:1.5rem;
        position:relative; z-index:1;
    }
    .doc-hero h1 {
        font-family:'Sora',sans-serif; font-size:clamp(1.6rem,3vw,2.2rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text);
        margin-bottom:10px; position:relative; z-index:1;
    }
    .doc-hero p { font-size:0.88rem; color:var(--muted); position:relative; z-index:1; }
    .updated-tag {
        display:inline-flex; align-items:center; gap:6px; font-size:0.72rem;
        font-weight:700; padding:4px 12px; border-radius:100px; margin-top:10px;
        background:rgba(245,158,11,0.08); border:1px solid rgba(245,158,11,0.18); color:#fbbf24;
    }

    .toc-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:16px;
        padding:22px 26px; margin-bottom:36px;
    }
    .toc-card h3 {
        font-family:'Sora',sans-serif; font-size:0.82rem; font-weight:700;
        letter-spacing:.1em; text-transform:uppercase; color:var(--muted); margin-bottom:14px;
    }
    .toc-list { list-style:none; padding:0; display:flex; flex-direction:column; gap:8px; }
    .toc-list li a {
        font-size:0.84rem; color:var(--muted); display:flex; align-items:center; gap:8px; transition:color .2s;
    }
    .toc-list li a::before {
        content:''; width:4px; height:4px; border-radius:50%; background:#fbbf24; flex-shrink:0; opacity:.5;
    }
    .toc-list li a:hover { color:#fbbf24; }

    .doc-body { display:flex; flex-direction:column; gap:28px; }

    .doc-section {
        background:var(--bg-1); border:1px solid var(--border); border-radius:18px;
        padding:28px 32px; scroll-margin-top:90px;
    }
    .doc-section h2 {
        font-family:'Sora',sans-serif; font-size:1.05rem; font-weight:700;
        color:var(--text); margin-bottom:16px; padding-bottom:12px;
        border-bottom:1px solid var(--border); display:flex; align-items:center; gap:10px;
    }
    .doc-section h2 .num {
        width:26px; height:26px; border-radius:7px; flex-shrink:0;
        background:rgba(245,158,11,0.12); border:1px solid rgba(245,158,11,0.2);
        display:flex; align-items:center; justify-content:center;
        font-size:0.72rem; font-weight:800; color:#fbbf24;
    }
    .doc-section p { font-size:0.88rem; color:var(--muted); line-height:1.8; margin-bottom:12px; }
    .doc-section p:last-child { margin-bottom:0; }
    .doc-section ul { list-style:none; padding:0; margin:12px 0; display:flex; flex-direction:column; gap:8px; }
    .doc-section ul li {
        font-size:0.86rem; color:var(--muted); line-height:1.6;
        display:flex; align-items:flex-start; gap:10px;
    }
    .doc-section ul li::before {
        content:''; width:5px; height:5px; border-radius:50%;
        background:#fbbf24; flex-shrink:0; margin-top:7px; opacity:.6;
    }

    /* Cookie type table */
    .cookie-table { width:100%; border-collapse:collapse; margin-top:16px; }
    .cookie-table th {
        font-family:'Sora',sans-serif; font-size:0.72rem; font-weight:700;
        letter-spacing:.06em; text-transform:uppercase; color:var(--muted);
        padding:10px 14px; text-align:left; border-bottom:1px solid var(--border);
        background:var(--bg-2);
    }
    .cookie-table th:first-child { border-radius:8px 0 0 0; }
    .cookie-table th:last-child  { border-radius:0 8px 0 0; }
    .cookie-table td {
        font-size:0.82rem; color:var(--muted); padding:12px 14px;
        border-bottom:1px solid rgba(255,255,255,0.04); vertical-align:top;
    }
    .cookie-table tr:last-child td { border-bottom:none; }
    .cookie-table td:first-child { color:var(--text); font-weight:600; }

    .highlight-box {
        background:rgba(245,158,11,0.05); border:1px solid rgba(245,158,11,0.15);
        border-left:3px solid var(--amber); border-radius:10px;
        padding:14px 18px; margin:16px 0; font-size:0.84rem; color:var(--muted); line-height:1.7;
    }

    @media(max-width:640px){ .page-wrap{padding:24px 14px 80px;} .doc-hero{padding:30px 22px;} .doc-section{padding:22px 18px;} .cookie-table{font-size:0.75rem;} }
</style>

<div class="page-wrap">

    <div class="doc-hero">
        <div class="doc-hero-icon">🍪</div>
        <h1>Cookie Policy</h1>
        <p>Learn how and why BarterBrain uses cookies on our platform.</p>
        <span class="updated-tag"><i class="bi bi-check-circle-fill"></i> Last updated: January 2024</span>
    </div>

    <div class="toc-card">
        <h3>Table of Contents</h3>
        <ul class="toc-list">
            <li><a href="#what-cookies">1. What Are Cookies</a></li>
            <li><a href="#types">2. Types of Cookies We Use</a></li>
            <li><a href="#specific">3. Specific Cookies</a></li>
            <li><a href="#manage">4. Managing Cookies</a></li>
            <li><a href="#third-party">5. Third-Party Cookies</a></li>
            <li><a href="#contact-cookie">6. Contact</a></li>
        </ul>
    </div>

    <div class="doc-body">

        <div class="doc-section" id="what-cookies">
            <h2><span class="num">1</span> What Are Cookies</h2>
            <p>Cookies are small text files stored on your device when you visit a website. They help the website remember information about your visit, making your next visit easier and the site more useful to you.</p>
            <p>BarterBrain uses cookies and similar technologies to keep you logged in, remember your preferences, and understand how our platform is being used.</p>
        </div>

        <div class="doc-section" id="types">
            <h2><span class="num">2</span> Types of Cookies We Use</h2>
            <ul>
                <li><strong style="color:var(--text);">Essential Cookies</strong> — Required for the platform to function. These cannot be disabled.</li>
                <li><strong style="color:var(--text);">Functional Cookies</strong> — Remember your preferences and settings to improve your experience.</li>
                <li><strong style="color:var(--text);">Analytics Cookies</strong> — Help us understand how users interact with the platform so we can improve it.</li>
            </ul>
            <div class="highlight-box">We do not use advertising or tracking cookies. BarterBrain is ad-free and we do not share cookie data with advertisers.</div>
        </div>

        <div class="doc-section" id="specific">
            <h2><span class="num">3</span> Specific Cookies</h2>
            <table class="cookie-table">
                <thead>
                    <tr>
                        <th>Cookie Name</th>
                        <th>Purpose</th>
                        <th>Duration</th>
                        <th>Type</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>session</td>
                        <td>Keeps you logged in during your session</td>
                        <td>Session</td>
                        <td>Essential</td>
                    </tr>
                    <tr>
                        <td>remember_me</td>
                        <td>Remembers your login if "Remember me" is checked</td>
                        <td>30 days</td>
                        <td>Functional</td>
                    </tr>
                    <tr>
                        <td>csrf_token</td>
                        <td>Protects against cross-site request forgery attacks</td>
                        <td>Session</td>
                        <td>Essential</td>
                    </tr>
                    <tr>
                        <td>ui_prefs</td>
                        <td>Stores your UI preferences (e.g. tab state)</td>
                        <td>90 days</td>
                        <td>Functional</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="doc-section" id="manage">
            <h2><span class="num">4</span> Managing Cookies</h2>
            <p>You can control and manage cookies through your browser settings. Most browsers allow you to:</p>
            <ul>
                <li>View cookies stored on your device</li>
                <li>Delete all or specific cookies</li>
                <li>Block cookies from specific or all websites</li>
                <li>Set preferences for future cookie handling</li>
            </ul>
            <p>Please note that disabling essential cookies will prevent you from logging in and using core platform features.</p>
        </div>

        <div class="doc-section" id="third-party">
            <h2><span class="num">5</span> Third-Party Cookies</h2>
            <p>BarterBrain does not use third-party advertising or tracking cookies. We load fonts from Google Fonts, which may set a minimal cookie. No other third-party cookies are used on our platform.</p>
        </div>

        <div class="doc-section" id="contact-cookie">
            <h2><span class="num">6</span> Contact</h2>
            <p>Questions about our cookie practices? Contact us at:</p>
            <ul>
                <li>Email: privacy@barterbrain.com</li>
                <li>Through the <a href="/help">Help Center</a></li>
            </ul>
        </div>

    </div>
</div>

<%- include('partials/footer') %>
