<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a; --bg-3:#1a1a30;
        --indigo:#4f46e5; --violet:#7c3aed; --il:#818cf8; --iv:#a78bfa;
        --text:#eeeeff; --muted:#7a7a9a; --border:rgba(255,255,255,0.065);
        --bf:rgba(99,102,241,0.5); --green:#10b981; --amber:#f59e0b; --red:#ef4444;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); }
    a { text-decoration:none; color:inherit; }

    .page-wrap { max-width:1200px; margin:0 auto; padding:36px 28px 100px; }

    /* ── ALERTS ── */
    .alert-bar {
        padding:12px 18px; border-radius:12px; font-size:0.86rem;
        display:flex; align-items:center; gap:10px; margin-bottom:24px;
    }
    .alert-bar.success {
        background:rgba(16,185,129,0.08); border:1px solid rgba(16,185,129,0.22);
        border-left:3px solid #10b981; color:#6ee7b7;
    }
    .alert-bar.error {
        background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.22);
        border-left:3px solid #ef4444; color:#fca5a5;
    }

    /* ── PROFILE HERO ── */
    .profile-hero {
        position:relative; overflow:hidden;
        background:linear-gradient(135deg, #1b1640 0%, #200e4a 55%, #130d2e 100%);
        border:1px solid rgba(99,102,241,0.22); border-radius:24px;
        padding:40px 44px; margin-bottom:28px;
        display:flex; align-items:flex-start; justify-content:space-between;
        flex-wrap:wrap; gap:28px;
    }

    .profile-hero::before {
        content:''; position:absolute; width:500px; height:500px;
        background:radial-gradient(circle,rgba(124,58,237,0.22),transparent 65%);
        top:-180px; right:-100px; border-radius:50%; pointer-events:none;
    }
    .profile-hero::after {
        content:''; position:absolute; width:300px; height:300px;
        background:radial-gradient(circle,rgba(79,70,229,0.16),transparent 65%);
        bottom:-100px; left:60px; border-radius:50%; pointer-events:none;
    }

    .hero-left {
        display:flex; align-items:center; gap:28px; position:relative; z-index:1; flex-wrap:wrap;
    }

    .profile-avatar {
        width:96px; height:96px; border-radius:22px; flex-shrink:0;
        background:linear-gradient(135deg,rgba(79,70,229,0.4),rgba(124,58,237,0.3));
        border:2px solid rgba(99,102,241,0.4);
        display:flex; align-items:center; justify-content:center;
        font-family:'Sora',sans-serif; font-size:2.4rem; font-weight:800;
        color:#c4b5fd; line-height:1;
    }

    .hero-info h1 {
        font-family:'Sora',sans-serif; font-size:clamp(1.5rem,2.5vw,2rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text); margin-bottom:4px;
    }

    .hero-handle {
        font-size:0.88rem; color:rgba(165,180,252,0.6); margin-bottom:14px;
    }

    .hero-meta {
        display:flex; align-items:center; gap:18px; flex-wrap:wrap;
    }

    .hero-meta-item {
        display:flex; align-items:center; gap:6px; font-size:0.82rem; color:rgba(165,180,252,0.7);
    }

    .hero-meta-item i { font-size:0.85rem; }

    .rep-pill {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.22);
        color:#fbbf24; padding:4px 12px; border-radius:100px;
        font-size:0.82rem; font-weight:700;
    }

    .hero-right { position:relative; z-index:1; }

    .btn-edit-hero {
        display:inline-flex; align-items:center; gap:8px;
        background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1);
        color:var(--text); font-size:0.85rem; font-weight:600;
        padding:10px 20px; border-radius:10px; cursor:pointer;
        transition:all .2s; white-space:nowrap;
    }
    .btn-edit-hero:hover {
        background:rgba(99,102,241,0.15); border-color:rgba(99,102,241,0.35);
        color:#a5b4fc;
    }

    /* ── STATS ROW ── */
    .stats-row {
        display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:28px;
    }

    .stat-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:18px;
        padding:20px 22px; display:flex; align-items:center; gap:14px;
        transition:border-color .25s, transform .2s;
    }
    .stat-card:hover { border-color:rgba(99,102,241,0.22); transform:translateY(-2px); }

    .stat-icon {
        width:46px; height:46px; border-radius:12px; flex-shrink:0;
        display:flex; align-items:center; justify-content:center; font-size:1.2rem;
    }
    .stat-icon.c-indigo { background:rgba(79,70,229,0.15); }
    .stat-icon.c-green  { background:rgba(16,185,129,0.13); }
    .stat-icon.c-violet { background:rgba(124,58,237,0.15); }
    .stat-icon.c-amber  { background:rgba(245,158,11,0.12); }

    .stat-info .val {
        font-family:'Sora',sans-serif; font-size:1.6rem; font-weight:800;
        letter-spacing:-0.8px; color:var(--text); line-height:1;
    }
    .stat-info .lbl { font-size:0.76rem; color:var(--muted); margin-top:3px; }

    /* ── EDIT FORM PANEL ── */
    .edit-panel {
        background:var(--bg-1); border:1px solid rgba(99,102,241,0.22);
        border-radius:18px; padding:28px; margin-bottom:28px;
        display:none;
    }
    .edit-panel.show { display:block; }

    .edit-panel h3 {
        font-family:'Sora',sans-serif; font-size:1rem; font-weight:700;
        color:var(--text); margin-bottom:20px;
        display:flex; align-items:center; gap:8px;
    }
    .edit-panel h3 i { color:var(--il); }

    .edit-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }

    .field-group { margin-bottom:0; }
    .field-label {
        display:block; font-size:0.72rem; font-weight:700; letter-spacing:.08em;
        text-transform:uppercase; color:var(--muted); margin-bottom:7px;
    }
    .field-wrap { position:relative; }
    .field-icon {
        position:absolute; left:13px; top:50%; transform:translateY(-50%);
        color:var(--muted); font-size:0.88rem; pointer-events:none; transition:color .2s;
    }
    .form-control {
        width:100%; background:#0b0b18; border:1px solid var(--border);
        border-radius:10px; color:var(--text); font-family:'DM Sans',sans-serif;
        font-size:0.88rem; padding:11px 13px 11px 38px; outline:none;
        transition:border-color .2s, box-shadow .2s;
    }
    .form-control::placeholder { color:rgba(122,122,154,0.4); }
    .form-control:focus { border-color:var(--bf); box-shadow:0 0 0 3px rgba(79,70,229,0.12); background:#0d0d1e; }
    .field-wrap:focus-within .field-icon { color:var(--il); }

    .edit-actions { display:flex; gap:10px; margin-top:20px; }

    .btn-save {
        display:inline-flex; align-items:center; gap:7px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff;
        font-family:'Sora',sans-serif; font-size:0.85rem; font-weight:700;
        padding:10px 24px; border-radius:9px; border:none; cursor:pointer;
        box-shadow:0 0 20px rgba(79,70,229,0.3); transition:all .25s;
    }
    .btn-save:hover { transform:translateY(-1px); box-shadow:0 6px 24px rgba(79,70,229,0.45); }

    .btn-cancel-form {
        display:inline-flex; align-items:center; gap:7px;
        background:rgba(255,255,255,0.04); border:1px solid var(--border);
        color:var(--muted); font-size:0.85rem; font-weight:500;
        padding:10px 20px; border-radius:9px; cursor:pointer; transition:all .2s;
    }
    .btn-cancel-form:hover { background:rgba(255,255,255,0.08); color:var(--text); }

    /* ── TWO COL LAYOUT ── */
    .profile-grid { display:grid; grid-template-columns:340px 1fr; gap:20px; align-items:start; }

    /* ── SECTION CARDS ── */
    .sec-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:18px;
        padding:24px; margin-bottom:18px;
    }
    .sec-card:last-child { margin-bottom:0; }

    .sec-head {
        display:flex; align-items:center; gap:9px; margin-bottom:20px;
        padding-bottom:14px; border-bottom:1px solid var(--border);
    }

    .sec-head-icon {
        width:32px; height:32px; border-radius:9px;
        display:flex; align-items:center; justify-content:center; font-size:0.9rem; flex-shrink:0;
    }
    .sec-head-icon.c-indigo { background:rgba(79,70,229,0.15); }
    .sec-head-icon.c-violet { background:rgba(124,58,237,0.15); }
    .sec-head-icon.c-green  { background:rgba(16,185,129,0.13); }
    .sec-head-icon.c-amber  { background:rgba(245,158,11,0.12); }
    .sec-head-icon.c-red    { background:rgba(239,68,68,0.1); }

    .sec-head h2 {
        font-family:'Sora',sans-serif; font-size:0.92rem; font-weight:700;
        color:var(--text); flex:1; letter-spacing:-0.2px;
    }

    .sec-head .sec-action {
        font-size:0.75rem; font-weight:700; color:var(--il);
        background:rgba(79,70,229,0.1); border:1px solid rgba(99,102,241,0.2);
        padding:4px 12px; border-radius:100px; transition:all .2s; white-space:nowrap;
    }
    .sec-head .sec-action:hover { background:rgba(79,70,229,0.2); }

    /* Info rows */
    .info-row {
        display:flex; align-items:flex-start; gap:14px;
        padding:11px 0; border-bottom:1px solid rgba(255,255,255,0.04);
    }
    .info-row:last-child { border-bottom:none; }

    .info-icon { width:20px; flex-shrink:0; text-align:center; color:var(--il); font-size:0.85rem; margin-top:1px; opacity:.7; }
    .info-label { font-size:0.8rem; color:var(--muted); font-weight:500; min-width:75px; flex-shrink:0; }
    .info-val { font-size:0.85rem; color:var(--text); font-weight:500; word-break:break-all; }

    /* Password form */
    .pwd-form .field-group { margin-bottom:14px; }
    .pwd-form .field-group:last-of-type { margin-bottom:0; }

    .btn-pwd {
        width:100%; display:flex; align-items:center; justify-content:center; gap:7px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed); color:#fff;
        font-family:'Sora',sans-serif; font-size:0.85rem; font-weight:700;
        padding:11px; border-radius:9px; border:none; cursor:pointer;
        box-shadow:0 0 18px rgba(79,70,229,0.28); transition:all .25s; margin-top:16px;
    }
    .btn-pwd:hover { transform:translateY(-1px); box-shadow:0 6px 22px rgba(79,70,229,0.42); }

    /* Skill tags */
    .skills-cloud { display:flex; flex-wrap:wrap; gap:8px; }

    .skill-tag {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(79,70,229,0.1); border:1px solid rgba(99,102,241,0.2);
        color:var(--il); font-size:0.8rem; font-weight:600;
        padding:5px 13px; border-radius:100px; transition:all .2s;
    }
    .skill-tag:hover { background:rgba(79,70,229,0.18); }
    .skill-tag i { font-size:0.72rem; opacity:.7; }

    .skill-tag.green {
        background:rgba(16,185,129,0.08); border-color:rgba(16,185,129,0.2); color:#34d399;
    }
    .skill-tag.green:hover { background:rgba(16,185,129,0.15); }

    .view-all-link {
        display:inline-flex; align-items:center; gap:5px;
        font-size:0.78rem; font-weight:600; color:var(--il);
        margin-top:14px; transition:gap .2s, color .2s;
    }
    .view-all-link:hover { color:var(--iv); gap:8px; }

    /* Review cards */
    .review-card {
        background:var(--bg-2); border:1px solid var(--border); border-radius:12px;
        padding:16px 18px; margin-bottom:10px;
        border-left:3px solid rgba(99,102,241,0.4);
        transition:border-color .2s;
    }
    .review-card:hover { border-color:rgba(99,102,241,0.5); border-left-color:var(--il); }
    .review-card:last-child { margin-bottom:0; }

    .review-stars { display:flex; gap:2px; margin-bottom:8px; }
    .review-stars .star-f { color:#fbbf24; font-size:0.9rem; }
    .review-stars .star-e { color:rgba(251,191,36,0.2); font-size:0.9rem; }

    .review-comment {
        font-size:0.83rem; color:var(--muted); line-height:1.6;
        margin-bottom:10px; font-style:italic;
    }

    .review-footer {
        display:flex; align-items:center; gap:14px; flex-wrap:wrap;
    }

    .review-footer span {
        font-size:0.72rem; color:rgba(122,122,154,0.6);
        display:flex; align-items:center; gap:4px;
    }

    /* Empty states */
    .empty-mini {
        display:flex; flex-direction:column; align-items:center;
        padding:24px 12px; text-align:center; gap:8px;
    }
    .empty-mini-icon {
        width:40px; height:40px; border-radius:11px;
        background:rgba(255,255,255,0.04); border:1px solid var(--border);
        display:flex; align-items:center; justify-content:center; font-size:1.1rem; opacity:.4;
    }
    .empty-mini p { font-size:0.8rem; color:var(--muted); max-width:180px; line-height:1.5; }
    .empty-mini a {
        font-size:0.78rem; font-weight:700; color:var(--il);
        background:rgba(79,70,229,0.1); border:1px solid rgba(99,102,241,0.2);
        padding:5px 14px; border-radius:100px; transition:all .2s;
    }
    .empty-mini a:hover { background:rgba(79,70,229,0.2); }

    /* Responsive */
    @media(max-width:1024px) {
        .profile-grid { grid-template-columns:1fr; }
        .stats-row { grid-template-columns:repeat(2,1fr); }
    }
    @media(max-width:640px) {
        .page-wrap { padding:20px 14px 80px; }
        .profile-hero { padding:26px 22px; }
        .stats-row { grid-template-columns:1fr 1fr; }
        .edit-grid { grid-template-columns:1fr; }
    }
</style>

<div class="page-wrap">

    <!-- Alerts -->
    <% if (locals.error) { %>
        <div class="alert-bar error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
        </div>
    <% } %>
    <% if (locals.success) { %>
        <div class="alert-bar success">
            <i class="bi bi-check-circle-fill"></i> <%= success %>
        </div>
    <% } %>

    <!-- ── PROFILE HERO ── -->
    <div class="profile-hero">
        <div class="hero-left">
            <div class="profile-avatar">
                <%= user && user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
            </div>
            <div class="hero-info">
                <h1><%= user && user.name ? user.name : 'User' %></h1>
                <p class="hero-handle">@<%= user && user.username ? user.username : 'username' %></p>
                <div class="hero-meta">
                    <div class="rep-pill">
                        <i class="bi bi-star-fill"></i>
                        <%= user && user.reputation_score ? Number(user.reputation_score).toFixed(1) : '0.0' %> reputation
                    </div>
                    <div class="hero-meta-item">
                        <i class="bi bi-calendar3"></i>
                        Joined <%= user && user.created_at ? new Date(user.created_at).toLocaleDateString('en-US',{month:'short',year:'numeric'}) : 'recently' %>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-right">
            <button class="btn-edit-hero" onclick="toggleEditForm()">
                <i class="bi bi-pencil-square"></i> Edit Profile
            </button>
        </div>
    </div>

    <!-- ── STATS ROW ── -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon c-indigo">💼</div>
            <div class="stat-info">
                <div class="val"><%= offers ? offers.length : 0 %></div>
                <div class="lbl">Skills Offered</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon c-green">📋</div>
            <div class="stat-info">
                <div class="val"><%= requests ? requests.length : 0 %></div>
                <div class="lbl">Skills Wanted</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon c-violet">⚡</div>
            <div class="stat-info">
                <div class="val"><%= matches ? matches.length : 0 %></div>
                <div class="lbl">Total Matches</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon c-amber">⭐</div>
            <div class="stat-info">
                <div class="val"><%= reviews ? reviews.length : 0 %></div>
                <div class="lbl">Reviews</div>
            </div>
        </div>
    </div>

    <!-- ── EDIT PANEL ── -->
    <div id="editForm" class="edit-panel">
        <h3><i class="bi bi-pencil-square"></i> Edit Profile Information</h3>
        <form action="/profile/update" method="POST">
            <div class="edit-grid">
                <div class="field-group">
                    <label class="field-label" for="ep-name">Full Name</label>
                    <div class="field-wrap">
                        <input type="text" class="form-control" id="ep-name" name="full_name"
                               value="<%= user.full_name %>" required>
                        <i class="bi bi-person field-icon"></i>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label" for="ep-user">Username</label>
                    <div class="field-wrap">
                        <input type="text" class="form-control" id="ep-user" name="username"
                               value="<%= user.username %>" required>
                        <i class="bi bi-at field-icon"></i>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label" for="ep-email">Email</label>
                    <div class="field-wrap">
                        <input type="email" class="form-control" id="ep-email" name="email"
                               value="<%= user.email %>" required>
                        <i class="bi bi-envelope field-icon"></i>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label" for="ep-phone">Phone Number</label>
                    <div class="field-wrap">
                        <input type="tel" class="form-control" id="ep-phone" name="phone_number"
                               value="<%= user.phone_number || '' %>" placeholder="Optional">
                        <i class="bi bi-phone field-icon"></i>
                    </div>
                </div>
            </div>
            <div class="edit-actions">
                <button type="submit" class="btn-save"><i class="bi bi-check-lg"></i> Save Changes</button>
                <button type="button" class="btn-cancel-form" onclick="toggleEditForm()">Cancel</button>
            </div>
        </form>
    </div>

    <!-- ── TWO-COLUMN GRID ── -->
    <div class="profile-grid">

        <!-- LEFT COLUMN -->
        <div>
            <!-- Contact Info -->
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-indigo"><i class="bi bi-person-lines-fill" style="color:var(--il);"></i></div>
                    <h2>Contact Information</h2>
                </div>
                <div class="info-row">
                    <i class="bi bi-envelope info-icon"></i>
                    <span class="info-label">Email</span>
                    <span class="info-val"><%= user.email %></span>
                </div>
                <div class="info-row">
                    <i class="bi bi-telephone info-icon"></i>
                    <span class="info-label">Phone</span>
                    <span class="info-val"><%= user.phone_number || 'Not provided' %></span>
                </div>
                <div class="info-row">
                    <i class="bi bi-geo-alt info-icon"></i>
                    <span class="info-label">Timezone</span>
                    <span class="info-val" id="tz">—</span>
                </div>
            </div>

            <!-- Security / Change Password -->
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-red"><i class="bi bi-shield-lock-fill" style="color:#f87171;"></i></div>
                    <h2>Security</h2>
                </div>
                <form action="/profile/change-password" method="POST" class="pwd-form">
                    <div class="field-group">
                        <label class="field-label">Current Password</label>
                        <div class="field-wrap">
                            <input type="password" class="form-control" name="current_password" placeholder="••••••••" required>
                            <i class="bi bi-lock field-icon"></i>
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">New Password</label>
                        <div class="field-wrap">
                            <input type="password" class="form-control" name="new_password" placeholder="••••••••" required>
                            <i class="bi bi-lock-fill field-icon"></i>
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Confirm New Password</label>
                        <div class="field-wrap">
                            <input type="password" class="form-control" name="confirm_password" placeholder="••••••••" required>
                            <i class="bi bi-shield-check field-icon"></i>
                        </div>
                    </div>
                    <button type="submit" class="btn-pwd">
                        <i class="bi bi-arrow-repeat"></i> Update Password
                    </button>
                </form>
            </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div>
            <!-- Skills Offered -->
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-indigo"><i class="bi bi-briefcase-fill" style="color:var(--il);"></i></div>
                    <h2>Skills I'm Offering</h2>
                    <a href="/offers/new" class="sec-action">+ Add New</a>
                </div>
                <% if (offers && offers.length > 0) { %>
                    <div class="skills-cloud">
                        <% offers.forEach(offer => { %>
                            <span class="skill-tag"><i class="bi bi-tag"></i><%= offer.skill_name %></span>
                        <% }) %>
                    </div>
                    <a href="/offers" class="view-all-link">View all offers <i class="bi bi-arrow-right"></i></a>
                <% } else { %>
                    <div class="empty-mini">
                        <div class="empty-mini-icon">💼</div>
                        <p>You haven't offered any skills yet</p>
                        <a href="/offers/new">Add Your First Skill</a>
                    </div>
                <% } %>
            </div>

            <!-- Skills Wanted -->
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-green"><i class="bi bi-journal-bookmark-fill" style="color:#34d399;"></i></div>
                    <h2>Skills I Want to Learn</h2>
                    <a href="/requests/new" class="sec-action">+ Add New</a>
                </div>
                <% if (requests && requests.length > 0) { %>
                    <div class="skills-cloud">
                        <% requests.forEach(request => { %>
                            <span class="skill-tag green"><i class="bi bi-tag"></i><%= request.skill_name %></span>
                        <% }) %>
                    </div>
                    <a href="/requests" class="view-all-link">View all requests <i class="bi bi-arrow-right"></i></a>
                <% } else { %>
                    <div class="empty-mini">
                        <div class="empty-mini-icon">📋</div>
                        <p>You haven't requested any skills yet</p>
                        <a href="/requests/new">Request a Skill</a>
                    </div>
                <% } %>
            </div>

            <!-- Recent Reviews -->
            <div class="sec-card">
                <div class="sec-head">
                    <div class="sec-head-icon c-amber"><i class="bi bi-chat-square-text-fill" style="color:#fbbf24;"></i></div>
                    <h2>Recent Reviews</h2>
                </div>
                <% if (reviews && reviews.length > 0) { %>
                    <% reviews.slice(0,3).forEach(review => { %>
                        <div class="review-card">
                            <div class="review-stars">
                                <% for(let i=0;i<review.rating;i++) { %><span class="star-f">★</span><% } %>
                                <% for(let i=review.rating;i<5;i++) { %><span class="star-e">★</span><% } %>
                            </div>
                            <p class="review-comment">"<%= review.comment || 'No comment left' %>"</p>
                            <div class="review-footer">
                                <span><i class="bi bi-person"></i> <%= review.reviewer_name || 'Anonymous' %></span>
                                <span><i class="bi bi-calendar3"></i> <%= new Date(review.created_at).toLocaleDateString() %></span>
                            </div>
                        </div>
                    <% }) %>
                    <% if (reviews.length > 3) { %>
                        <a href="#" class="view-all-link" style="margin-top:14px;">
                            View all <%= reviews.length %> reviews <i class="bi bi-arrow-right"></i>
                        </a>
                    <% } %>
                <% } else { %>
                    <div class="empty-mini">
                        <div class="empty-mini-icon">⭐</div>
                        <p>No reviews yet — complete skill exchanges to earn them!</p>
                    </div>
                <% } %>
            </div>
        </div>

    </div><!-- end profile-grid -->
</div>

<script>
    // Timezone
    document.getElementById('tz').textContent = Intl.DateTimeFormat().resolvedOptions().timeZone;

    // Toggle edit panel
    function toggleEditForm() {
        document.getElementById('editForm').classList.toggle('show');
    }

    // Auto-fade alerts
    setTimeout(() => {
        document.querySelectorAll('.alert-bar').forEach(el => {
            el.style.transition = 'opacity .5s';
            el.style.opacity = '0';
            setTimeout(() => el.remove(), 500);
        });
    }, 5000);
</script>

<%- include('partials/footer') %>
