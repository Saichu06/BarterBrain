<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a;
        --indigo:#4f46e5; --violet:#7c3aed; --il:#818cf8; --iv:#a78bfa;
        --text:#eeeeff; --muted:#7a7a9a; --border:rgba(255,255,255,0.065);
        --bf:rgba(99,102,241,0.5); --amber:#f59e0b;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; }
    a { text-decoration:none; }

    .page-wrap { max-width:640px; margin:0 auto; padding:48px 28px 100px; }

    .breadcrumb {
        display:flex; align-items:center; gap:8px;
        font-size:0.78rem; color:var(--muted); margin-bottom:28px;
    }
    .breadcrumb a { color:var(--muted); transition:color .2s; }
    .breadcrumb a:hover { color:var(--il); }
    .breadcrumb i { font-size:0.7rem; opacity:.5; }

    .form-card { background:var(--bg-1); border:1px solid var(--border); border-radius:22px; overflow:hidden; }

    .form-card-header {
        padding:28px 32px; border-bottom:1px solid var(--border);
        background:linear-gradient(135deg,rgba(245,158,11,0.07),rgba(251,191,36,0.04));
        display:flex; align-items:center; gap:14px;
    }

    .form-header-icon {
        width:48px; height:48px; border-radius:14px;
        background:rgba(245,158,11,0.14); border:1px solid rgba(245,158,11,0.22);
        display:flex; align-items:center; justify-content:center; font-size:1.4rem; flex-shrink:0;
    }

    .form-card-header h1 {
        font-family:'Sora',sans-serif; font-size:1.25rem; font-weight:800;
        letter-spacing:-0.4px; color:var(--text); margin-bottom:3px;
    }
    .form-card-header p { font-size:0.82rem; color:var(--muted); }

    .form-body { padding:32px; }

    /* Match summary */
    .match-summary {
        background:var(--bg-2); border:1px solid var(--border);
        border-radius:14px; padding:18px 20px; margin-bottom:28px;
    }

    .summary-label {
        font-size:0.65rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
        color:var(--muted); margin-bottom:12px; display:block;
    }

    .summary-row {
        display:flex; align-items:flex-start; gap:10px; margin-bottom:10px;
    }
    .summary-row:last-child { margin-bottom:0; }

    .sum-side-badge {
        font-size:0.63rem; font-weight:700; padding:2px 9px; border-radius:100px;
        flex-shrink:0; margin-top:2px;
    }
    .sum-side-badge.offer   { background:rgba(79,70,229,0.12); color:var(--il); border:1px solid rgba(99,102,241,0.2); }
    .sum-side-badge.request { background:rgba(16,185,129,0.1);  color:#34d399;   border:1px solid rgba(16,185,129,0.2); }

    .sum-info strong { display:block; font-size:0.85rem; font-weight:600; color:var(--text); margin-bottom:1px; }
    .sum-info span   { font-size:0.76rem; color:var(--muted); }

    /* Error */
    .error-alert {
        background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.22);
        border-left:3px solid #ef4444; color:#fca5a5; padding:12px 16px;
        border-radius:10px; font-size:0.85rem; margin-bottom:24px;
        display:flex; align-items:center; gap:10px;
    }

    /* Field */
    .field-group { margin-bottom:26px; }

    .field-label {
        display:block; font-size:0.74rem; font-weight:700;
        letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin-bottom:10px;
    }

    /* Star rating */
    .star-rating {
        display:flex; flex-direction:row-reverse; justify-content:flex-end; gap:6px;
    }

    .star-rating input { display:none; }

    .star-rating label {
        font-size:2.2rem; color:rgba(251,191,36,0.2); cursor:pointer;
        transition:color .15s, transform .15s;
        line-height:1;
    }

    .star-rating input:checked ~ label,
    .star-rating label:hover,
    .star-rating label:hover ~ label {
        color:#fbbf24;
    }

    .star-rating label:hover { transform:scale(1.15); }

    .rating-hint { font-size:0.75rem; color:var(--muted); margin-top:8px; }

    /* Textarea */
    .form-control {
        width:100%; background:#0b0b18; border:1px solid var(--border);
        border-radius:11px; color:var(--text); font-family:'DM Sans',sans-serif;
        font-size:0.9rem; padding:12px 14px; outline:none; resize:vertical;
        min-height:110px; transition:border-color .2s, box-shadow .2s;
    }
    .form-control::placeholder { color:rgba(122,122,154,0.4); }
    .form-control:focus { border-color:var(--bf); box-shadow:0 0 0 3px rgba(79,70,229,0.12); background:#0d0d1e; }

    /* Actions */
    .form-actions { display:flex; gap:10px; margin-top:4px; }

    .btn-submit {
        flex:1; display:flex; align-items:center; justify-content:center; gap:8px;
        background:linear-gradient(135deg,#d97706,#f59e0b); color:#1a0e00;
        font-family:'Sora',sans-serif; font-size:0.9rem; font-weight:800;
        padding:13px; border-radius:11px; border:none; cursor:pointer;
        box-shadow:0 0 24px rgba(245,158,11,0.3); transition:all .25s;
    }
    .btn-submit:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(245,158,11,0.45); }

    .btn-cancel {
        display:flex; align-items:center; justify-content:center; gap:6px;
        background:rgba(255,255,255,0.04); border:1px solid var(--border);
        color:var(--muted); font-size:0.88rem; font-weight:500;
        padding:13px 22px; border-radius:11px; transition:all .2s;
    }
    .btn-cancel:hover { background:rgba(255,255,255,0.07); color:var(--text); }

    @media(max-width:640px){ .page-wrap{padding:24px 14px 80px;} .form-body{padding:22px;} .form-card-header{padding:22px;} }
</style>

<div class="page-wrap">
    <div class="breadcrumb">
        <a href="/matches">Matches</a>
        <i class="bi bi-chevron-right"></i>
        <span>Leave Review</span>
    </div>

    <div class="form-card">
        <div class="form-card-header">
            <div class="form-header-icon">⭐</div>
            <div>
                <h1>Leave a Review</h1>
                <p>Share your experience with this skill exchange.</p>
            </div>
        </div>

        <div class="form-body">
            <% if (locals.error) { %>
                <div class="error-alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
                </div>
            <% } %>

            <!-- Match summary -->
            <div class="match-summary">
                <span class="summary-label">Skill Exchange Summary</span>
                <div class="summary-row">
                    <span class="sum-side-badge offer">Offer</span>
                    <div class="sum-info">
                        <strong><%= match.offer_skill_name %></strong>
                        <span>by <%= match.offer_user_name %></span>
                    </div>
                </div>
                <div class="summary-row">
                    <span class="sum-side-badge request">Request</span>
                    <div class="sum-info">
                        <strong><%= match.request_skill_name %></strong>
                        <span>by <%= match.request_user_name %></span>
                    </div>
                </div>
            </div>

            <form action="/matches/<%= match.match_id %>/review" method="POST">
                <div class="field-group">
                    <label class="field-label">Your Rating</label>
                    <div class="star-rating">
                        <input type="radio" name="rating" value="5" id="star5" required>
                        <label for="star5" title="5 stars">★</label>
                        <input type="radio" name="rating" value="4" id="star4">
                        <label for="star4" title="4 stars">★</label>
                        <input type="radio" name="rating" value="3" id="star3">
                        <label for="star3" title="3 stars">★</label>
                        <input type="radio" name="rating" value="2" id="star2">
                        <label for="star2" title="2 stars">★</label>
                        <input type="radio" name="rating" value="1" id="star1">
                        <label for="star1" title="1 star">★</label>
                    </div>
                    <p class="rating-hint" id="rating-hint">Click a star to rate</p>
                </div>

                <div class="field-group">
                    <label class="field-label" for="comment">
                        Comment <span style="text-transform:none;letter-spacing:0;font-weight:400;color:rgba(122,122,154,0.5);">(optional)</span>
                    </label>
                    <textarea name="comment" id="comment" class="form-control"
                        placeholder="Share your experience — what went well, what you learned…"></textarea>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-star-fill"></i> Submit Review
                    </button>
                    <a href="/matches" class="btn-cancel">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const hints = ['', 'Poor experience', 'Below average', 'Good exchange', 'Great experience', 'Outstanding!'];
    document.querySelectorAll('.star-rating input').forEach(input => {
        input.addEventListener('change', () => {
            document.getElementById('rating-hint').textContent = hints[input.value] || '';
        });
    });
</script>

<%- include('partials/footer') %>
