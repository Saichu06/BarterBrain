<%- include('partials/header') %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');
    :root {
        --bg:#07070f; --bg-1:#0e0e1c; --bg-2:#13132a; --bg-3:#1a1a30;
        --indigo:#4f46e5; --violet:#7c3aed; --il:#818cf8; --iv:#a78bfa;
        --text:#eeeeff; --muted:#7a7a9a; --border:rgba(255,255,255,0.065);
        --bh:rgba(99,102,241,0.35); --green:#10b981; --amber:#f59e0b; --red:#ef4444;
    }
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); }
    a { text-decoration:none; }

    .page-wrap { max-width:1200px; margin:0 auto; padding:36px 28px 100px; }

    /* PAGE HEADER */
    .page-top {
        display:flex; align-items:flex-end; justify-content:space-between;
        flex-wrap:wrap; gap:16px; margin-bottom:32px;
    }
    .page-top h1 {
        font-family:'Sora',sans-serif; font-size:clamp(1.5rem,2.5vw,2rem);
        font-weight:800; letter-spacing:-0.8px; color:var(--text);
    }
    .page-top h1 span {
        background:linear-gradient(120deg,var(--il),var(--iv));
        -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .page-sub { font-size:0.86rem; color:var(--muted); margin-top:4px; }

    .btn-new {
        display:inline-flex; align-items:center; gap:8px;
        background:linear-gradient(135deg,#4f46e5,#7c3aed);
        color:#fff; font-family:'Sora',sans-serif; font-size:0.85rem;
        font-weight:700; padding:10px 22px; border-radius:10px; border:none;
        box-shadow:0 0 24px rgba(79,70,229,0.35); transition:all .25s; cursor:pointer;
    }
    .btn-new:hover { transform:translateY(-2px); box-shadow:0 8px 32px rgba(79,70,229,0.5); color:#fff; }

    /* TABS */
    .tabs-bar {
        display:flex; gap:6px; margin-bottom:24px;
        background:var(--bg-1); border:1px solid var(--border);
        border-radius:12px; padding:5px; width:fit-content;
    }
    .tab-btn {
        background:transparent; border:none; cursor:pointer;
        font-family:'DM Sans',sans-serif; font-size:0.82rem; font-weight:600;
        color:var(--muted); padding:8px 18px; border-radius:8px; transition:all .2s;
    }
    .tab-btn.active {
        background:linear-gradient(135deg,rgba(79,70,229,0.25),rgba(124,58,237,0.18));
        color:var(--il); border:1px solid rgba(99,102,241,0.3);
    }
    .tab-btn:hover:not(.active) { color:var(--text); background:rgba(255,255,255,0.04); }

    /* MATCHES GRID */
    .matches-grid {
        display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:16px;
    }

    .match-card {
        background:var(--bg-1); border:1px solid var(--border); border-radius:18px;
        padding:22px; display:flex; flex-direction:column; gap:16px;
        transition:border-color .25s, transform .25s, box-shadow .25s;
    }
    .match-card:hover {
        border-color:rgba(99,102,241,0.22); transform:translateY(-3px);
        box-shadow:0 16px 40px rgba(0,0,0,0.35);
    }

    /* status badge */
    .status-badge {
        display:inline-flex; align-items:center; gap:5px;
        padding:3px 11px; border-radius:100px;
        font-size:0.7rem; font-weight:700; letter-spacing:.05em; text-transform:capitalize;
    }
    .status-badge::before { content:''; width:5px; height:5px; border-radius:50%; }
    .status-badge.pending  { background:rgba(245,158,11,0.1); color:#fbbf24; border:1px solid rgba(245,158,11,0.22); }
    .status-badge.pending::before  { background:#fbbf24; box-shadow:0 0 4px #fbbf24; }
    .status-badge.accepted { background:rgba(16,185,129,0.1); color:#34d399; border:1px solid rgba(16,185,129,0.22); }
    .status-badge.accepted::before { background:#34d399; }
    .status-badge.completed{ background:rgba(59,130,246,0.1); color:#60a5fa; border:1px solid rgba(59,130,246,0.18); }
    .status-badge.completed::before{ background:#60a5fa; }

    /* match body */
    .match-body {
        display:grid; grid-template-columns:1fr auto 1fr; gap:10px; align-items:center;
    }
    .match-side {
        background:var(--bg-2); border:1px solid var(--border);
        border-radius:12px; padding:14px;
    }
    .match-side .side-label {
        font-size:0.65rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
        color:var(--muted); margin-bottom:6px;
    }
    .match-side h4 {
        font-family:'Sora',sans-serif; font-size:0.88rem; font-weight:700;
        color:var(--text); margin-bottom:5px;
    }
    .match-side .user-tag {
        font-size:0.74rem; color:var(--muted); display:flex; align-items:center; gap:5px;
    }
    .match-side .user-tag i { color:var(--il); opacity:.6; }

    .match-arrow {
        font-size:1.1rem; color:var(--muted); opacity:.4; text-align:center;
    }

    /* match actions */
    .match-actions { display:flex; flex-wrap:wrap; gap:8px; margin-top:2px; }
    .match-actions form { margin:0; }

    .btn-accept {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(16,185,129,0.12); border:1px solid rgba(16,185,129,0.25);
        color:#34d399; font-size:0.8rem; font-weight:700;
        padding:7px 16px; border-radius:8px; cursor:pointer; transition:all .2s;
    }
    .btn-accept:hover { background:rgba(16,185,129,0.2); transform:translateY(-1px); }

    .btn-contact {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(79,70,229,0.12); border:1px solid rgba(99,102,241,0.25);
        color:var(--il); font-size:0.8rem; font-weight:700;
        padding:7px 16px; border-radius:8px; cursor:pointer; transition:all .2s;
    }
    .btn-contact:hover { background:rgba(79,70,229,0.22); transform:translateY(-1px); }

    .btn-complete {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(59,130,246,0.12); border:1px solid rgba(59,130,246,0.22);
        color:#60a5fa; font-size:0.8rem; font-weight:700;
        padding:7px 16px; border-radius:8px; cursor:pointer; transition:all .2s;
    }
    .btn-complete:hover { background:rgba(59,130,246,0.22); transform:translateY(-1px); }

    .btn-review {
        display:inline-flex; align-items:center; gap:6px;
        background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.22);
        color:#fbbf24; font-size:0.8rem; font-weight:700;
        padding:7px 16px; border-radius:8px; transition:all .2s;
    }
    .btn-review:hover { background:rgba(245,158,11,0.2); transform:translateY(-1px); color:#fbbf24; }

    /* contact info */
    .contact-info {
        background:var(--bg-2); border:1px solid rgba(99,102,241,0.2);
        border-radius:10px; padding:14px 16px; margin-top:4px; width:100%;
    }
    .contact-info p { font-size:0.82rem; color:var(--muted); margin-bottom:5px; }
    .contact-info p:last-child { margin-bottom:0; }
    .contact-info strong { color:var(--text); }
    .contact-info a { color:var(--il); }
    .hidden { display:none !important; }

    /* empty state */
    .empty-wrap {
        display:flex; flex-direction:column; align-items:center; justify-content:center;
        padding:80px 20px; text-align:center; gap:16px;
    }
    .empty-icon-big {
        width:64px; height:64px; border-radius:18px;
        background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.18);
        display:flex; align-items:center; justify-content:center; font-size:1.8rem;
    }
    .empty-wrap h3 { font-family:'Sora',sans-serif; font-size:1.05rem; font-weight:700; color:var(--text); }
    .empty-wrap p  { font-size:0.86rem; color:var(--muted); max-width:280px; line-height:1.6; }

    @media(max-width:640px){
        .page-wrap{padding:22px 14px 80px;}
        .match-body{grid-template-columns:1fr; }
        .match-arrow{transform:rotate(90deg);}
    }
</style>

<div class="page-wrap">
    <div class="page-top">
        <div>
            <h1>My <span>Matches</span></h1>
            <p class="page-sub">Track and manage all your skill exchange connections.</p>
        </div>
        <a href="/matches/potential" class="btn-new">
            <i class="bi bi-search"></i> Find New Matches
        </a>
    </div>

    <% if (locals.matches && matches.length > 0) { %>
        <div class="tabs-bar">
            <button class="tab-btn active" data-status="all">All</button>
            <button class="tab-btn" data-status="pending">Pending</button>
            <button class="tab-btn" data-status="accepted">Accepted</button>
            <button class="tab-btn" data-status="completed">Completed</button>
        </div>

        <div class="matches-grid">
            <% matches.forEach(match => { %>
                <div class="match-card" data-status="<%= match.status %>">
                    <div style="display:flex;align-items:center;justify-content:space-between;">
                        <span class="status-badge <%= match.status %>"><%= match.status %></span>
                    </div>

                    <div class="match-body">
                        <div class="match-side">
                            <div class="side-label">Offer</div>
                            <h4><%= match.offer_skill_name %></h4>
                            <div class="user-tag"><i class="bi bi-person-fill"></i> <%= match.offer_user_name %></div>
                        </div>
                        <div class="match-arrow">⇄</div>
                        <div class="match-side">
                            <div class="side-label">Request</div>
                            <h4><%= match.request_skill_name %></h4>
                            <div class="user-tag"><i class="bi bi-person-fill"></i> <%= match.request_user_name %></div>
                        </div>
                    </div>

                    <div class="match-actions">
                        <% if (match.status === 'pending' && match.offer_user_id === user.id) { %>
                            <form action="/matches/<%= match.match_id %>/accept" method="POST">
                                <button type="submit" class="btn-accept"><i class="bi bi-check-lg"></i> Accept</button>
                            </form>
                        <% } %>

                        <% if (match.status === 'accepted') { %>
                            <% if (match.offer_user_id === user.id || match.request_user_id === user.id) { %>
                                <button class="btn-contact" onclick="showContact('<%= match.match_id %>')">
                                    <i class="bi bi-telephone-fill"></i> Show Contact
                                </button>
                                <div id="contact-<%= match.match_id %>" class="contact-info hidden"></div>
                            <% } %>
                            <form action="/matches/<%= match.match_id %>/complete" method="POST">
                                <button type="submit" class="btn-complete" onclick="return confirm('Mark this exchange as complete?')">
                                    <i class="bi bi-check-circle-fill"></i> Complete
                                </button>
                            </form>
                        <% } %>

                        <% if (match.status === 'completed') { %>
                            <a href="/matches/<%= match.match_id %>/review" class="btn-review">
                                <i class="bi bi-star-fill"></i> Leave Review
                            </a>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-wrap">
            <div class="empty-icon-big">⚡</div>
            <h3>No matches yet</h3>
            <p>You don't have any matches yet. Find people with the skills you need!</p>
            <a href="/matches/potential" class="btn-new">Find Matches Now</a>
        </div>
    <% } %>
</div>

<script>
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const status = btn.dataset.status;
            document.querySelectorAll('.match-card').forEach(card => {
                card.style.display = (status === 'all' || card.dataset.status === status) ? 'flex' : 'none';
            });
        });
    });

    async function showContact(matchId) {
        console.log('Show contact clicked for match:', matchId);
        const contactDiv = document.getElementById('contact-' + matchId);
        const button = event.target.closest('button');
        if (contactDiv.classList.contains('hidden')) {
            try {
                button.textContent = 'Loading...';
                button.disabled = true;
                const response = await fetch('/api/match/' + matchId + '/contact');
                const data = await response.json();
                console.log('Contact data received:', data);
                if (response.ok) {
                    contactDiv.innerHTML = `
                        <p><strong>${data.name}</strong></p>
                        <p>📧 Email: <a href="mailto:${data.email}">${data.email}</a></p>
                        <p>📞 Phone: ${data.phone}</p>`;
                    contactDiv.classList.remove('hidden');
                    button.innerHTML = '<i class="bi bi-eye-slash-fill"></i> Hide Contact';
                } else {
                    alert('Error: ' + (data.error || 'Failed to load contact info'));
                    button.innerHTML = '<i class="bi bi-telephone-fill"></i> Show Contact';
                }
            } catch (error) {
                console.error('Error loading contact info:', error);
                alert('Failed to load contact information. Please try again.');
                button.innerHTML = '<i class="bi bi-telephone-fill"></i> Show Contact';
            } finally {
                button.disabled = false;
            }
        } else {
            contactDiv.classList.add('hidden');
            button.innerHTML = '<i class="bi bi-telephone-fill"></i> Show Contact';
        }
    }
</script>

<%- include('partials/footer') %>
